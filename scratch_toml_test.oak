std := import('std')
toml := import('data-toml')

text := 'title = "HELLO"
date = "2026-04-19"
body = """
A post with "double quotes", and backslash \\ for flavor.

Line breaks kept.
"""
'

out := toml.parse(text)
std.println('title=' + out.title)
std.println('date=' + out.date)
std.println('body=<' + out.body + '>')

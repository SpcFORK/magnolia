syntax := import('syntax')

file := ___runtime_lib('gui-draw')
if file {
	? -> print('No runtime lib gui-draw' + char(10))
	_ -> {
		print('Read ' + string(len(file)) + ' bytes from runtime lib' + char(10))
		nodes := syntax.parse(file)
		if type(nodes) = :object & nodes.type = :error {
			true -> print('Parse error: ' + nodes.error + char(10))
			_ -> print('Parsed ' + string(len(nodes)) + ' nodes successfully' + char(10))
		}
	}
}

path := import('path')

fn say(s) print(s + char(10))

say('PWD = ' + string(env().PWD))
say('abs?("main.oak") = ' + string(path.abs?('main.oak')))
say('resolve("main.oak") = ' + string(path.resolve('main.oak')))

// Test what happens with path resolution on Windows
say('dir("main.oak") = "' + string(path.dir('main.oak')) + '"')
say('resolve("comps/save", "") = "' + string(path.resolve('comps/save', '')) + '"')

// Check ___runtime_lib? for local file names
say('rt?(comps/save) = ' + string(___runtime_lib?('comps/save')))
say('rt?(boot) = ' + string(___runtime_lib?('boot')))
say('rt?(ico) = ' + string(___runtime_lib?('ico')))
say('rt?(scenes/core) = ' + string(___runtime_lib?('scenes/core')))

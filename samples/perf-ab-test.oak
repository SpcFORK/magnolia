// A/B Engine Test Harness
// Tests every benchmark with BOTH bytecode() and interpreter() wrappers,
// plus a raw (no-wrapper) baseline, repeated N times for statistical accuracy.
//
// Run in BOTH modes to get the full picture:
//   magnolia samples/perf-ab-test.oak
//   magnolia --bytecode samples/perf-ab-test.oak

std := import('std')
{
	println: println
	range: range
	map: map
	each: each
	filter: filter
	reduce: reduce
	append: append
	slice: slice
} := std
{ printf: printf } := import('fmt')
{ sort: sort } := import('sort')

// ── helpers ──────────────────────────────────────────────────

RUNS := 5

fn repeat(s, n) {
	fn sub(i, acc) if i {
		n -> acc
		_ -> sub(i + 1, acc + s)
	}
	sub(0, '')
}

fn median(xs) {
	sorted := sort(xs)
	n := len(sorted)
	if n % 2 {
		0 -> (sorted.(n / 2 - 1) + sorted.(n / 2)) / 2
		_ -> sorted.(int(n / 2))
	}
}

fn minVal(xs) {
	xs |> reduce(xs.0, fn(a, b) if a < b { true -> a, _ -> b })
}

fn timeNsMulti(label, fnRun) {
	times := []
	fn runN(i) if i {
		RUNS -> ?
		_ -> {
			start := nanotime()
			fnRun()
			elapsed := nanotime() - start
			times << elapsed
			runN(i + 1)
		}
	}
	runN(0)
	med := median(times)
	best := minVal(times)
	ms := med / 1000000
	bestMs := best / 1000000
	{ label: label, median: med, best: best, ms: ms, bestMs: bestMs }
}

fn padRight(s, w) {
	fn sub(cur) if len(cur) < w {
		true -> sub(cur + ' ')
		_ -> cur
	}
	sub(s)
}

fn padLeft(s, w) {
	fn sub(cur) if len(cur) < w {
		true -> sub(' ' + cur)
		_ -> cur
	}
	sub(s)
}

results := []

fn runTest(name, rawFn, bcFn, interpFn) {
	println('')
	println('  Testing: ' + name)
	rRaw := timeNsMulti('raw', rawFn)
	rBC := timeNsMulti('bytecode', bcFn)
	rInt := timeNsMulti('interp', interpFn)

	// Determine winner by median
	bestTime := rRaw.median
	winner := 'raw'
	if rBC.median < bestTime {
		true -> {
			bestTime <- rBC.median
			winner <- 'bytecode'
		}
		_ -> ?
	}
	if rInt.median < bestTime {
		true -> {
			bestTime <- rInt.median
			winner <- 'interp'
		}
		_ -> ?
	}

	printf('    raw:      {{ 0 }} ms (best {{ 1 }} ms)', rRaw.ms, rRaw.bestMs)
	printf('    bytecode: {{ 0 }} ms (best {{ 1 }} ms)', rBC.ms, rBC.bestMs)
	printf('    interp:   {{ 0 }} ms (best {{ 1 }} ms)', rInt.ms, rInt.bestMs)
	printf('    WINNER:   {{ 0 }}', winner)

	results << {
		name: name
		raw: rRaw.ms
		bc: rBC.ms
		interp: rInt.ms
		winner: winner
	}
}

// ═══════════════════════════════════════════════════════════════
// BENCHMARKS
// ═══════════════════════════════════════════════════════════════

println('═══ A/B Engine Test (' + string(RUNS) + ' runs each, median) ═══')

// ── 1. Int Arithmetic (200k) ──────────────────────────────────

fn _arithBody(n) {
	fn sub(i, acc) if i {
		n -> acc
		_ -> sub(i + 1, acc + i * 3 - i / 2 + 7)
	}
	sub(0, 0)
}

runTest(
	'int arithmetic (200k)'
	fn() _arithBody(200000)
	fn() with bytecode([200000]) fn(n) {
		fn sub(i, acc) if i {
			n -> acc
			_ -> sub(i + 1, acc + i * 3 - i / 2 + 7)
		}
		sub(0, 0)
	}
	fn() with interpreter([200000]) fn(n) {
		fn sub(i, acc) if i {
			n -> acc
			_ -> sub(i + 1, acc + i * 3 - i / 2 + 7)
		}
		sub(0, 0)
	}
)

// ── 2. Float Arithmetic (200k) ────────────────────────────────

runTest(
	'float arithmetic (200k)'
	fn() {
		fn sub(i, acc) if i {
			200000 -> acc
			_ -> sub(i + 1, acc + (i * 3.14) - (i / 2.72) + 1.618)
		}
		sub(0, 0.0)
	}
	fn() with bytecode([200000]) fn(n) {
		fn sub(i, acc) if i {
			n -> acc
			_ -> sub(i + 1, acc + (i * 3.14) - (i / 2.72) + 1.618)
		}
		sub(0, 0.0)
	}
	fn() with interpreter([200000]) fn(n) {
		fn sub(i, acc) if i {
			n -> acc
			_ -> sub(i + 1, acc + (i * 3.14) - (i / 2.72) + 1.618)
		}
		sub(0, 0.0)
	}
)

// ── 3. Fib(20) Naive ─────────────────────────────────────────

runTest(
	'fib(20) naive'
	fn() {
		fn fibN(x) if x <= 1 {
			true -> x
			_ -> fibN(x - 1) + fibN(x - 2)
		}
		fibN(20)
	}
	fn() with bytecode([20]) fn(n) {
		fn fibN(x) if x <= 1 {
			true -> x
			_ -> fibN(x - 1) + fibN(x - 2)
		}
		fibN(n)
	}
	fn() with interpreter([20]) fn(n) {
		fn fibN(x) if x <= 1 {
			true -> x
			_ -> fibN(x - 1) + fibN(x - 2)
		}
		fibN(n)
	}
)

// ── 4. Fib(1000) Tail-Recursive ──────────────────────────────

runTest(
	'fib(1000) tail-recursive'
	fn() {
		fn sub(i, a, b) if i {
			0 -> a
			_ -> sub(i - 1, b, a + b)
		}
		sub(1000, 0, 1)
	}
	fn() with bytecode([1000]) fn(n) {
		fn sub(i, a, b) if i {
			0 -> a
			_ -> sub(i - 1, b, a + b)
		}
		sub(n, 0, 1)
	}
	fn() with interpreter([1000]) fn(n) {
		fn sub(i, a, b) if i {
			0 -> a
			_ -> sub(i - 1, b, a + b)
		}
		sub(n, 0, 1)
	}
)

// ── 5. Build List (2k) ──────────────────────────────────────

runTest(
	'build list (2k push)'
	fn() {
		xs := []
		fn sub(i) if i {
			2000 -> xs
			_ -> {
				xs << i
				sub(i + 1)
			}
		}
		sub(0)
	}
	fn() with bytecode([2000]) fn(limit) {
		xs := []
		fn sub(i) if i {
			limit -> xs
			_ -> {
				xs << i
				sub(i + 1)
			}
		}
		sub(0)
	}
	fn() with interpreter([2000]) fn(limit) {
		xs := []
		fn sub(i) if i {
			limit -> xs
			_ -> {
				xs << i
				sub(i + 1)
			}
		}
		sub(0)
	}
)

// ── 6. Map (10k) ─────────────────────────────────────────────

bigList := range(10000)

runTest(
	'map (10k)'
	fn() bigList |> map(fn(x) x * 2 + 1)
	fn() with bytecode([bigList]) fn(xs) xs |> map(fn(x) x * 2 + 1)
	fn() with interpreter([bigList]) fn(xs) xs |> map(fn(x) x * 2 + 1)
)

// ── 7. Filter (10k) ──────────────────────────────────────────

runTest(
	'filter (10k)'
	fn() bigList |> filter(fn(x) x % 3 = 0)
	fn() with bytecode([bigList]) fn(xs) xs |> filter(fn(x) x % 3 = 0)
	fn() with interpreter([bigList]) fn(xs) xs |> filter(fn(x) x % 3 = 0)
)


// ── 14. Compose Chain (10k) ─────────────────────────────────

runTest(
	'compose chain (10k)'
	fn() {
		fn comp(f, g) fn(x) f(g(x))
		double := fn(x) x * 2
		inc := fn(x) x + 1
		dblInc := comp(double, inc)
		fn sub(i, acc) if i {
			10000 -> acc
			_ -> sub(i + 1, acc + dblInc(i))
		}
		sub(0, 0)
	}
	fn() with bytecode([10000]) fn(limit) {
		fn comp(f, g) fn(x) f(g(x))
		double := fn(x) x * 2
		inc := fn(x) x + 1
		dblInc := comp(double, inc)
		fn sub(i, acc) if i {
			limit -> acc
			_ -> sub(i + 1, acc + dblInc(i))
		}
		sub(0, 0)
	}
	fn() with interpreter([10000]) fn(limit) {
		fn comp(f, g) fn(x) f(g(x))
		double := fn(x) x * 2
		inc := fn(x) x + 1
		dblInc := comp(double, inc)
		fn sub(i, acc) if i {
			limit -> acc
			_ -> sub(i + 1, acc + dblInc(i))
		}
		sub(0, 0)
	}
)

// ── 15. Sort (2k) ───────────────────────────────────────────

unsorted := range(2000) |> map(fn(_) int(rand() * 10000))

runTest(
	'sort 2k random ints'
	fn() sort(unsorted)
	fn() with bytecode([unsorted]) fn(xs) sort(xs)
	fn() with interpreter([unsorted]) fn(xs) sort(xs)
)

// ── 16. FizzBuzz Pattern Match (20k) ────────────────────────

runTest(
	'fizzbuzz classify (20k)'
	fn() {
		fn cls(n) if n % 15 {
			0 -> :fizzbuzz
			_ -> if n % 3 {
				0 -> :fizz
				_ -> if n % 5 {
					0 -> :buzz
					_ -> n
				}
			}
		}
		fn sub(i, fb, f, b) if i {
			20000 -> [fb, f, b]
			_ -> if cls(i) {
				:fizzbuzz -> sub(i + 1, fb + 1, f, b)
				:fizz -> sub(i + 1, fb, f + 1, b)
				:buzz -> sub(i + 1, fb, f, b + 1)
				_ -> sub(i + 1, fb, f, b)
			}
		}
		sub(1, 0, 0, 0)
	}
	fn() with bytecode([20000]) fn(limit) {
		fn cls(n) if n % 15 {
			0 -> :fizzbuzz
			_ -> if n % 3 {
				0 -> :fizz
				_ -> if n % 5 {
					0 -> :buzz
					_ -> n
				}
			}
		}
		fn sub(i, fb, f, b) if i {
			limit -> [fb, f, b]
			_ -> if cls(i) {
				:fizzbuzz -> sub(i + 1, fb + 1, f, b)
				:fizz -> sub(i + 1, fb, f + 1, b)
				:buzz -> sub(i + 1, fb, f, b + 1)
				_ -> sub(i + 1, fb, f, b)
			}
		}
		sub(1, 0, 0, 0)
	}
	fn() with interpreter([20000]) fn(limit) {
		fn cls(n) if n % 15 {
			0 -> :fizzbuzz
			_ -> if n % 3 {
				0 -> :fizz
				_ -> if n % 5 {
					0 -> :buzz
					_ -> n
				}
			}
		}
		fn sub(i, fb, f, b) if i {
			limit -> [fb, f, b]
			_ -> if cls(i) {
				:fizzbuzz -> sub(i + 1, fb + 1, f, b)
				:fizz -> sub(i + 1, fb, f + 1, b)
				:buzz -> sub(i + 1, fb, f, b + 1)
				_ -> sub(i + 1, fb, f, b)
			}
		}
		sub(1, 0, 0, 0)
	}
)

// ── 17. Sieve of Eratosthenes (10k) ─────────────────────────

fn _sieveBody(limit) {
	flags := range(limit) |> map(fn(_) true)
	flags.0 := false
	flags.1 := false

	fn outer(i) if i * i < limit {
		true -> {
			if flags.(i) {
				true -> {
					fn inner(j) if j < limit {
						true -> {
							flags.(j) := false
							inner(j + i)
						}
						_ -> ?
					}
					inner(i * i)
				}
				_ -> ?
			}
			outer(i + 1)
		}
		_ -> ?
	}
	outer(2)

	primes := []
	fn collect(i) if i < limit {
		true -> {
			if flags.(i) {
				true -> primes << i
				_ -> ?
			}
			collect(i + 1)
		}
		_ -> ?
	}
	collect(0)
	primes
}

runTest(
	'sieve (10k)'
	fn() _sieveBody(10000)
	fn() with bytecode([10000]) fn(limit) {
		flags := range(limit) |> map(fn(_) true)
		flags.0 := false
		flags.1 := false

		fn outer(i) if i * i < limit {
			true -> {
				if flags.(i) {
					true -> {
						fn inner(j) if j < limit {
							true -> {
								flags.(j) := false
								inner(j + i)
							}
							_ -> ?
						}
						inner(i * i)
					}
					_ -> ?
				}
				outer(i + 1)
			}
			_ -> ?
		}
		outer(2)

		primes := []
		fn collect(i) if i < limit {
			true -> {
				if flags.(i) {
					true -> primes << i
					_ -> ?
				}
				collect(i + 1)
			}
			_ -> ?
		}
		collect(0)
		primes
	}
	fn() with interpreter([10000]) fn(limit) {
		flags := range(limit) |> map(fn(_) true)
		flags.0 := false
		flags.1 := false

		fn outer(i) if i * i < limit {
			true -> {
				if flags.(i) {
					true -> {
						fn inner(j) if j < limit {
							true -> {
								flags.(j) := false
								inner(j + i)
							}
							_ -> ?
						}
						inner(i * i)
					}
					_ -> ?
				}
				outer(i + 1)
			}
			_ -> ?
		}
		outer(2)

		primes := []
		fn collect(i) if i < limit {
			true -> {
				if flags.(i) {
					true -> primes << i
					_ -> ?
				}
				collect(i + 1)
			}
			_ -> ?
		}
		collect(0)
		primes
	}
)

// ═══════════════════════════════════════════════════════════════
// RESULTS TABLE
// ═══════════════════════════════════════════════════════════════

println('')
println('═══ RESULTS (median ms, ' + string(RUNS) + ' runs) ═══')
println('')

hdr := '│ ' + padRight('Test', 28) + ' │ ' + padLeft('raw', 9) + ' │ ' + padLeft('bytecode', 9) + ' │ ' + padLeft('interp', 9) + ' │ ' + padLeft('WINNER', 10) + ' │'
sep := '├' + repeat('─', 30) + '┼' + repeat('─', 11) + '┼' + repeat('─', 11) + '┼' + repeat('─', 11) + '┼' + repeat('─', 12) + '┤'
println('┌' + repeat('─', 30) + '┬' + repeat('─', 11) + '┬' + repeat('─', 11) + '┬' + repeat('─', 11) + '┬' + repeat('─', 12) + '┐')
println(hdr)
println(sep)
results |> each(fn(r) {
	println('│ ' + padRight(r.name, 28) + ' │ ' + padLeft(string(r.raw), 9) + ' │ ' + padLeft(string(r.bc), 9) + ' │ ' + padLeft(string(r.interp), 9) + ' │ ' + padLeft(r.winner, 10) + ' │')
})
println('└' + repeat('─', 30) + '┴' + repeat('─', 11) + '┴' + repeat('─', 11) + '┴' + repeat('─', 11) + '┴' + repeat('─', 12) + '┘')

// Summary counts
bcWins := 0
intWins := 0
rawWins := 0
results |> each(fn(r) if r.winner {
	'bytecode' -> bcWins <- bcWins + 1
	'interp' -> intWins <- intWins + 1
	'raw' -> rawWins <- rawWins + 1
	_ -> ?
})
println('')
printf('  bytecode wins: {{ 0 }}', bcWins)
printf('  interp wins:   {{ 0 }}', intWins)
printf('  raw wins:      {{ 0 }}', rawWins)
println('')
println('Done.')

	'string slice (5k)'
	fn() {
		fn sub(i) if i {
			500 -> ?
			_ -> {
				longStr |> slice(i, i + 10)
				sub(i + 1)
			}
		}
		sub(0)
	}
	fn() with bytecode([longStr, 500]) fn(s, limit) {
		fn sub(i) if i {
			limit -> ?
			_ -> {
				s |> slice(i, i + 10)
				sub(i + 1)
			}
		}

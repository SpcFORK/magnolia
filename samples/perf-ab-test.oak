runTest(
	'reduce sum (10k)'
	fn() bigList |> reduce(0, fn(a, b) a + b)
	fn() with bytecode([bigList]) fn(xs) xs |> reduce(0, fn(a, b) a + b)
	fn() with interpreter([bigList]) fn(xs) xs |> reduce(0, fn(a, b) a + b)
)


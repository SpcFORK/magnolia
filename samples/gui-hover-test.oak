// Test sample: mouse hover/leave tracking
// Opens a window and logs hover/leave events to verify WM_MOUSEHOVER / WM_MOUSELEAVE.

{
	println: println
	string: string
} := import('std')
{
	printf: printf
} := import('fmt')

gui := import('GUI')

fn main() {
	window := gui.createWindow('Hover/Leave Test', 400, 300, {
		layer2D: 'auto'
		threading: true
	})
	if window.type != :ok -> {
		println('Failed to create window: ' + string(window))
		exit(1)
	}

	state := {
		hoverCount: 0
		leaveCount: 0
		lastEvent: 'none'
		mx: 0
		my: 0
	}

	gui.show(window)

	gui.onMouseHover(window, fn(x, y) {
		state.hoverCount <- state.hoverCount + 1
		state.lastEvent <- 'hover'
		state.mx <- x
		state.my <- y
		printf('HOVER #{{ 0 }} at ({{ 1 }}, {{ 2 }})\n', state.hoverCount, x, y)
	})

	gui.onMouseLeave(window, fn() {
		state.leaveCount <- state.leaveCount + 1
		state.lastEvent <- 'leave'
		printf('LEAVE #{{ 0 }}\n', state.leaveCount)
	})

	fn draw(win) {
		frame := gui.beginFrame(win)
		if frame.type = :ok -> {
			bg := gui.rgb(20, 25, 35)
			gui.draw(win, { shape: :rect, x: 0, y: 0, width: win.width, height: win.height, color: bg })
			gui.draw(win, { shape: :text, x: 20, y: 24, text: 'Mouse Hover/Leave Test', color: gui.rgb(255, 255, 255) })
			gui.draw(win, { shape: :text, x: 20, y: 52, text: 'Last event: ' + state.lastEvent, color: gui.rgb(180, 220, 255) })
			gui.draw(win, { shape: :text, x: 20, y: 76, text: 'Hovers: ' + string(state.hoverCount) + '  Leaves: ' + string(state.leaveCount), color: gui.rgb(160, 200, 160) })
			if state.lastEvent = 'hover' -> {
				gui.draw(win, { shape: :text, x: 20, y: 100, text: 'Pos: (' + string(state.mx) + ', ' + string(state.my) + ')', color: gui.rgb(255, 210, 120) })
			}
			gui.draw(win, { shape: :text, x: 20, y: 140, text: 'Move mouse in/out of window to test.', color: gui.rgb(140, 140, 160) })
			gui.draw(win, { shape: :text, x: 20, y: 164, text: 'Close window to exit.', color: gui.rgb(140, 140, 160) })
			gui.endFrame(win)
		}
	}

	draw(window)
	gui.run(window, ?, fn(win, _dt) draw(win))
	println('Test complete.')
	gui.close(window)
}

main()

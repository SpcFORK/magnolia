#!/usr/bin/env oak

// Test Framework Examples
// Demonstrates the built-in unit testing library

{
	println: println
	string: string
	len: len
	map: map
	filter: filter
	reduce: reduce
} := import('std')
Suite := import('test')

fn main() {
	println('=== Test Framework Examples ===')
	println('')

	// Create a test suite
	t := Suite('Math & Collections')

	// 1. Equality tests
	t.eq('addition', 2 + 2, 4)
	t.eq('subtraction', 10 - 3, 7)
	t.eq('multiplication', 6 * 7, 42)
	t.eq('string concat', 'hello' + ' ' + 'world', 'hello world')
	t.eq('list length', len([1, 2, 3]), 3)

	// 2. Approximate equality (for floats)
	t.approx('pi approx', 3.14159, 3.14159)
	t.approx('float division', 1 / 3, 0.333333333)
	t.approx('custom epsilon', 1.001, 1.0, 0.01)

	// 3. Boolean assertions
	t.assert('true is true', true)
	t.assert('5 > 3', 5 > 3)
	t.assert('empty string is falsy', '' = '')
	t.assert('list contains item', filter([1, 2, 3], fn(n) n = 2) |> len() > 0)

	// 4. Collection tests
	nums := [1, 2, 3, 4, 5]
	t.eq('map squares', map(nums, fn(n) n * n), [1, 4, 9, 16, 25])
	t.eq('filter evens', filter(nums, fn(n) n % 2 = 0), [2, 4])
	t.eq('reduce sum', reduce(nums, 0, fn(a, n) a + n), 15)

	// 5. Skipped test
	t.skip('todo: implement later', ?, ?)

	// Print results
	t.report()
}

main()

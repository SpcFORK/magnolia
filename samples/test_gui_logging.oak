// Test sample for GUI logging helper behavior.
// Run: magnolia samples/test_gui_logging.oak

{
	string: string
} := import('std')
{
	new: new
} := import('test')

fn formatLogLine(ts, level, message) '[' + string(ts) + '] ' + level + ' ' + message
fn shouldLogTick?(tick, every) (every > 0) & (tick % every = 0)

suite := new('GUI Logging Sample Tests')

suite.eq('formatLogLine basic',
	formatLogLine(1700000000, 'INFO', 'started'),
	'[1700000000] INFO started')

suite.eq('formatLogLine keeps punctuation',
	formatLogLine(42, 'WARN', 'window resize: 1024x768'),
	'[42] WARN window resize: 1024x768')

suite.eq('shouldLogTick? true on schedule',
	[
		shouldLogTick?(90, 90)
		shouldLogTick?(180, 90)
	],
	[true, true])

suite.eq('shouldLogTick? false off schedule',
	[
		shouldLogTick?(91, 90)
		shouldLogTick?(89, 90)
		shouldLogTick?(8, 0)
	],
	[false, false, false])

suite.report()
suite.exit()

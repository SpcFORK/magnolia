{
  "name": "oak",
  "displayName": "Oaklang",
  "description": "Oak language support for VS Code",
  "version": "0.0.1",
  "engines": {
    "vscode": "^1.109.0"
  },
  "categories": [
    "Programming Languages"
  ],
  "contributes": {
    "languages": [{
      "id": "oakl",
      "aliases": ["Oaklang", "oakl"],
      "extensions": [".oak",".ok",".mag",".mg"],
      "configuration": "./language-configuration.json"
    }],
    "grammars": [{
      "language": "oakl",
      "scopeName": "source.oak",
      "path": "./syntaxes/oak.tmLanguage.json"
    }]
  }
}

{
    "$schema": "https://raw.githubusercontent.com/martinring/tmlanguage/master/tmlanguage.json",
    "name": "Oak",
    "scopeName": "source.oak",
    "fileTypes": ["oak"],
    "patterns": [
        {
            "include": "#comments"
        },
        {
            "include": "#strings"
        },
        {
            "include": "#atoms"
        },
        {
            "include": "#numbers"
        },
        {
            "include": "#keywords"
        },
        {
            "include": "#conditionals"
        },
        {
            "include": "#functions"
        },
        {
            "include": "#booleans"
        },
        {
            "include": "#constants"
        },
        {
            "include": "#function-calls"
        },
        {
            "include": "#operators"
        },
        {
            "match": "[()\\[\\]{}]",
            "name": "punctuation.bracket.oak"
        }
    ],
    "repository": {
        "comments": {
            "patterns": [
                {
                    "name": "comment.line.double-slash.oak",
                    "begin": "//",
                    "end": "$",
                    "patterns": [
                        {
                            "include": "#todo"
                        }
                    ]
                },
                {
                    "name": "comment.block.oak",
                    "begin": "/\\*",
                    "end": "\\*/",
                    "patterns": [
                        {
                            "include": "#todo"
                        }
                    ]
                },
                {
                    "name": "comment.line.shebang.oak",
                    "match": "^#!.*$",
                    "patterns": [
                        {
                            "include": "#todo"
                        }
                    ]
                }
            ]
        },
        "todo": {
            "match": "\\b(TODO|NOTE|XXX)(?:\\([^)]*\\))?",
            "name": "keyword.todo"
        },
        "strings": {
            "name": "string.quoted.single.oak",
            "begin": "'",
            "beginCaptures": {
                "0": {
                    "name": "punctuation.definition.string.begin.oak"
                }
            },
            "end": "'",
            "endCaptures": {
                "0": {
                    "name": "punctuation.definition.string.end.oak"
                }
            },
            "patterns": [
                {
                    "name": "constant.character.escape.oak",
                    "match": "\\\\."
                }
            ]
        },
        "atoms": {
            "match": ":[A-Za-z_!][A-Za-z0-9_!?\\-]*",
            "name": "constant.other.symbol.oak"
        },
        "numbers": {
            "match": "\\d+\\.\\d+|\\d+",
            "name": "constant.numeric.oak"
        },
        "keywords": {
            "match": "\\b(if|fn|with|cs)\\b",
            "name": "keyword.control.oak"
        },
        "conditionals": {
            "patterns": [
                {
                    "match": "->",
                    "name": "keyword.control.conditional.oak"
                }
            ]
        },
        "functions": {
            "patterns": [
                {
                    "match": "\\|>",
                    "name": "keyword.function.oak"
                }
            ]
        },
        "booleans": {
            "match": "\\b(true|false)\\b",
            "name": "constant.language.boolean.oak"
        },
        "constants": {
            "match": "\\b_\\b",
            "name": "constant.language.oak"
        },
        "function-calls": {
            "patterns": [
                {
                    "match": "\\b(import|int|float|atom|string|codepoint|char|type|name|csof|len|keys|___stdlibs|args|env|time|nanotime|rand|srand|wait|exit|exec|sysproc|syscall|utf16|bits|addr|pointer|memread|memwrite|go|lock_thread|unlock_thread|win_msg_loop|make_chan|chan_send|chan_recv|input|print|ls|rm|mkdir|stat|open|close|read|write|listen|req|ws_dial|ws_send|ws_recv|ws_close|ws_listen|sin|cos|tan|asin|acos|atan|pow|log|___runtime_lib|___runtime_lib\\?|___runtime_gc|___runtime_mem|___runtime_proc|___runtime_go_version|___runtime_sys_info)\\s*(\\()",
                    "name": "meta.function-call.oak",
                    "captures": {
                        "1": {
                            "name": "support.function.builtin.oak"
                        },
                        "2": {
                            "name": "punctuation.section.arguments.begin.oak"
                        }
                    }
                },
                {
                    "match": "\\b([A-Za-z_!][A-Za-z0-9_!?]*)\\s*(\\()",
                    "name": "meta.function-call.oak",
                    "captures": {
                        "1": {
                            "name": "entity.name.function.oak"
                        },
                        "2": {
                            "name": "punctuation.section.arguments.begin.oak"
                        }
                    }
                }
            ]
        },
        "operators": {
            "match": "\\*\\*|==|>=|<=|!=|>>|<<|:=|<-|~|\\+|\\-|\\*|\\/|%|\\&|\\||\\^|>|<|=|\\.",
            "name": "keyword.operator.oak"
        }
    }
}

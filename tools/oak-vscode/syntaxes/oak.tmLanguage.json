{
  "$schema": "https://raw.githubusercontent.com/martinring/tmlanguage/master/tmlanguage.json",
  "name": "Oak",
  "scopeName": "source.oak",
  "fileTypes": ["oak"],
  "patterns": [
    {
      "include": "#comments"
    },
    {
      "include": "#strings"
    },
    {
      "include": "#atoms"
    },
    {
      "include": "#numbers"
    },
    {
      "include": "#conditionals"
    },
    {
      "include": "#functions"
    },
    {
      "include": "#booleans"
    },
    {
      "include": "#constants"
    },
    {
      "include": "#function-calls"
    },
    {
      "include": "#operators"
    },
    {
      "match": "[()\\[\\]{}]",
      "name": "punctuation.bracket.oak"
    }
  ],
  "repository": {
    "comments": {
      "patterns": [
        {
          "name": "comment.line.double-slash.oak",
          "begin": "//",
          "end": "$",
          "patterns": [
            {
              "include": "#todo"
            }
          ]
        },
        {
          "name": "comment.block.oak",
          "begin": "/\\*",
          "end": "\\*/",
          "patterns": [
            {
              "include": "#todo"
            }
          ]
        },
        {
          "name": "comment.line.shebang.oak",
          "match": "^#!.*$",
          "patterns": [
            {
              "include": "#todo"
            }
          ]
        }
      ]
    },
    "todo": {
      "match": "\\b(TODO|NOTE|XXX)(?:\\([^)]*\\))?",
      "name": "keyword.todo"
    },
    "strings": {
      "name": "string.quoted.single.oak",
      "begin": "'",
      "beginCaptures": {
        "0": {
          "name": "punctuation.definition.string.begin.oak"
        }
      },
      "end": "'",
      "endCaptures": {
        "0": {
          "name": "punctuation.definition.string.end.oak"
        }
      },
      "patterns": [
        {
          "name": "constant.character.escape.oak",
          "match": "\\\\."
        }
      ]
    },
    "atoms": {
      "match": ":[A-Za-z_!][A-Za-z0-9_!?]*",
      "name": "constant.other.symbol.oak"
    },
    "numbers": {
      "match": "\\d+\\.\\d+|\\d+",
      "name": "constant.numeric.oak"
    },
    "conditionals": {
      "patterns": [
        {
          "match": "\\bif\\b",
          "name": "keyword.control.conditional.oak"
        },
        {
          "match": "->",
          "name": "keyword.control.conditional.oak"
        }
      ]
    },
    "functions": {
      "patterns": [
        {
          "match": "\\b(fn|with)\\b",
          "name": "keyword.function.oak"
        },
        {
          "match": "\\|>",
          "name": "keyword.function.oak"
        }
      ]
    },
    "booleans": {
      "match": "\\b(true|false)\\b",
      "name": "constant.language.boolean.oak"
    },
    "constants": {
      "match": "\\b_\\b",
      "name": "constant.language.oak"
    },
    "function-calls": {
      "patterns": [
        {
          "match": "\\b(import|string|int|float|atom|codepoint|char|type|len|keys|args|env|time|nanotime|exit|rand|wait|exec|input|print|ls|mkdir|rm|stat|open|close|read|write|listen|req|sin|cos|tan|asin|acos|atan|pow|log)\\s*(\\()",
          "name": "meta.function-call.oak",
          "captures": {
            "1": {
              "name": "support.function.builtin.oak"
            },
            "2": {
              "name": "punctuation.section.arguments.begin.oak"
            }
          }
        },
        {
          "match": "\\b([A-Za-z_!][A-Za-z0-9_!?]*)\\s*(\\()",
          "name": "meta.function-call.oak",
          "captures": {
            "1": {
              "name": "entity.name.function.oak"
            },
            "2": {
              "name": "punctuation.section.arguments.begin.oak"
            }
          }
        }
      ]
    },
    "operators": {
      "match": "~|\\+|\\-|\\*|\\/|%|\\&|\\||\\^|>|<|=|>=|<=|!=|\\.|:=|<-|<<",
      "name": "keyword.operator.oak"
    }
  }
}
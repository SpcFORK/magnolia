{
    println: println
    string: string
} := import('std')

gui := import('GUI')

println('Creating window...')
window := gui.createWindow('Test Graphing', 980, 580, {
    frameMs: 16
    updateOnDispatch: false
    icon: './build/magnolia.ico'
    taskbarIcon: './build/magnolia.ico'
    windowIcon: './build/magnolia.ico'
})
println('Window type: ' + string(window.type))
println('Window backend: ' + string(window.backend))

if window.type {
    :ok -> {
        println('Window created OK, showing...')
        gui.show(window)
        println('Window shown, running...')
        gui.run(window, ?, fn(win, dt) {
            println('Frame dt=' + string(dt))
            if gui.beginFrame(win).type = :ok -> {
                gui.fillRect(win, 0, 0, win.width, win.height, gui.rgb(20, 20, 40))
                gui.drawText(win, 24, 40, 'graphing debug test')
                gui.endFrame(win)
            }
        })
        println('Run exited')
        gui.close(window)
    }
    _ -> println('Could not create window: ' + string(window))
}
println('Done')
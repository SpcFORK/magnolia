// wasm-vm-runtime -- WebAssembly Text format VM runtime generator
//
// Generates a complete, self-contained WAT module that contains a bytecode
// interpreter for Oak programs. The module embeds compiled bytecode,
// a constant pool, and function templates in linear memory, and implements
// a stack-based VM that executes them without requiring an external Oak
// interpreter.
//
// Host imports required (minimal I/O only):
//   env.print_string(ptr, len)  — write bytes to stdout
//   env.exit(code)              — terminate execution
//
// Memory layout (offsets computed per-program):
//   [0x0000 .. VSTACK_END)  Value stack — 8 bytes per entry (type:i32, val:i32)
//   [VSTACK_END .. CSTACK_END)  Call/frame stack
//   [CSTACK_END .. BYTECODE_END)  Bytecode program
//   [BYTECODE_END .. CONSTPOOL_END)  Constant pool
//   [CONSTPOOL_END .. FNTABLE_END)  Function template table
//   [FNTABLE_END .. )  Heap (bump-allocated, grows upward)

std := import('std')
map := std.map
each := std.each
len := std.len
str := import('str')
join := str.join
fmt := import('fmt')
format := fmt.format

// Memory region sizes (in bytes)
VSTACK_SIZE  := 16384   // 16KB = 2048 value slots
CSTACK_SIZE  := 16384   // 16KB for call frames
PAGE_SIZE    := 65536   // WASM page = 64KB

// generateVMWat produces the complete WAT source for the VM module.
//
// Parameters:
//   bytecodeWAT   — WAT-escaped bytecode data string
//   bytecodeLen   — byte length of bytecode
//   constpoolWAT  — WAT-escaped constant pool data string
//   constpoolLen  — byte length of constant pool
//   fntableWAT    — WAT-escaped function table data string
//   fntableLen    — byte length of function table
fn generateVMWat(bytecodeWAT, bytecodeLen, constpoolWAT, constpoolLen, fntableWAT, fntableLen) {

	// Compute memory addresses
	vstackBase    := 0
	vstackEnd     := vstackBase + VSTACK_SIZE
	cstackBase    := vstackEnd
	cstackEnd     := cstackBase + CSTACK_SIZE
	bytecodeBase  := cstackEnd
	bytecodeEnd   := bytecodeBase + bytecodeLen
	constpoolBase := bytecodeEnd
	constpoolEnd  := constpoolBase + constpoolLen
	fntableBase   := constpoolEnd
	fntableEnd    := fntableBase + fntableLen
	heapStart     := fntableEnd
	// Align heap to 16-byte boundary
	heapStart <- if heapStart % 16 > 0 {
		true -> heapStart + 16 - (heapStart % 16)
		_ -> heapStart
	}

	totalBytes  := heapStart + 65536  // 64KB initial heap
	memoryPages := int(totalBytes / PAGE_SIZE)
	if totalBytes % PAGE_SIZE > 0 -> memoryPages <- memoryPages + 1
	if memoryPages < 1 -> memoryPages <- 1

	// Helper to emit i32.const
	fn ic(v) 'i32.const ' << string(v)

	// Build the WAT module
	';; Oak WASM VM — generated by oak build --wasm
;; Bytecode VM: no external Oak interpreter required
(module

  ;; ---- Host imports (I/O only) ----
  (import "env" "print_string" (func $host_print (param i32 i32)))
  (import "env" "exit" (func $host_exit (param i32)))

  ;; ---- Memory ----
  (memory (export "memory") ' << string(memoryPages) << ')

  ;; ---- Data segments ----
  ;; Bytecode at offset ' << string(bytecodeBase) << '
  (data (' << ic(bytecodeBase) << ') "' << bytecodeWAT << '")
  ;; Constant pool at offset ' << string(constpoolBase) << '
  (data (' << ic(constpoolBase) << ') "' << constpoolWAT << '")
  ;; Function table at offset ' << string(fntableBase) << '
  (data (' << ic(fntableBase) << ') "' << fntableWAT << '")

  ;; ---- Globals ----
  (global $pc  (mut i32) (' << ic(bytecodeBase) << '))   ;; program counter (absolute addr)
  (global $sp  (mut i32) (' << ic(vstackBase) << '))     ;; value stack pointer
  (global $csp (mut i32) (' << ic(cstackBase) << '))     ;; call stack pointer
  (global $hp  (mut i32) (' << ic(heapStart) << '))      ;; heap pointer

  ;; Memory layout constants (exported for host inspection)
  (global $vstack_base   (export "vstack_base")   i32 (' << ic(vstackBase) << '))
  (global $cstack_base   (export "cstack_base")   i32 (' << ic(cstackBase) << '))
  (global $bytecode_base (export "bytecode_base") i32 (' << ic(bytecodeBase) << '))
  (global $constpool_base(export "constpool_base")i32 (' << ic(constpoolBase) << '))
  (global $fntable_base  (export "fntable_base")  i32 (' << ic(fntableBase) << '))
  (global $heap_start    (export "heap_start")    i32 (' << ic(heapStart) << '))

  ;; ---- Bump allocator ----
  (func $alloc (param $size i32) (result i32)
    (local $ptr i32)
    ;; Align size to 8 bytes
    (local.set $size (i32.and
      (i32.add (local.get $size) (i32.const 7))
      (i32.const -8)))
    (local.set $ptr (global.get $hp))
    (global.set $hp (i32.add (global.get $hp) (local.get $size)))
    ;; Grow memory if needed
    (if (i32.gt_u (global.get $hp) (i32.mul (memory.size) (i32.const 65536)))
      (then
        (drop (memory.grow (i32.const 1)))
      )
    )
    (local.get $ptr)
  )

  ;; ---- Value stack operations ----
  ;; Each stack entry is 8 bytes: [type:i32 @ sp+0] [payload:i32 @ sp+4]

  (func $push_val (param $type i32) (param $val i32)
    (i32.store (global.get $sp) (local.get $type))
    (i32.store (i32.add (global.get $sp) (i32.const 4)) (local.get $val))
    (global.set $sp (i32.add (global.get $sp) (i32.const 8)))
  )

  (func $peek_type (result i32)
    (i32.load (i32.sub (global.get $sp) (i32.const 8)))
  )

  (func $peek_val (result i32)
    (i32.load (i32.sub (global.get $sp) (i32.const 4)))
  )

  (func $pop_type (result i32)
    (global.set $sp (i32.sub (global.get $sp) (i32.const 8)))
    (i32.load (global.get $sp))
  )

  (func $pop_val (result i32)
    ;; Must be called immediately after pop_type
    (i32.load (i32.add (global.get $sp) (i32.const 4)))
  )

  ;; Pop a full tagged value, returning type in first result
  ;; We use a global to pass the second value since WASM MVP has single returns
  (global $tmp_val (mut i32) (i32.const 0))

  (func $pop_tagged (result i32)
    (local $t i32)
    (global.set $sp (i32.sub (global.get $sp) (i32.const 8)))
    (local.set $t (i32.load (global.get $sp)))
    (global.set $tmp_val (i32.load (i32.add (global.get $sp) (i32.const 4))))
    (local.get $t)
  )

  ;; ---- Bytecode fetch helpers ----

  (func $fetch_u8 (result i32)
    (local $v i32)
    (local.set $v (i32.load8_u (global.get $pc)))
    (global.set $pc (i32.add (global.get $pc) (i32.const 1)))
    (local.get $v)
  )

  (func $fetch_u16 (result i32)
    (local $lo i32)
    (local $hi i32)
    (local.set $lo (i32.load8_u (global.get $pc)))
    (local.set $hi (i32.load8_u (i32.add (global.get $pc) (i32.const 1))))
    (global.set $pc (i32.add (global.get $pc) (i32.const 2)))
    (i32.or (local.get $lo) (i32.shl (local.get $hi) (i32.const 8)))
  )

  (func $fetch_i32 (result i32)
    (local $v i32)
    (local.set $v (i32.load (global.get $pc)))
    (global.set $pc (i32.add (global.get $pc) (i32.const 4)))
    (local.get $v)
  )

  ;; ---- Heap string helpers ----
  ;; Heap string format: [len:i32][byte0 byte1 ...]

  (func $alloc_string (param $src i32) (param $slen i32) (result i32)
    (local $ptr i32)
    (local.set $ptr (call $alloc (i32.add (local.get $slen) (i32.const 4))))
    (i32.store (local.get $ptr) (local.get $slen))
    (call $memcpy
      (i32.add (local.get $ptr) (i32.const 4))
      (local.get $src)
      (local.get $slen))
    (local.get $ptr)
  )

  (func $string_len (param $ptr i32) (result i32)
    (i32.load (local.get $ptr))
  )

  (func $string_data (param $ptr i32) (result i32)
    (i32.add (local.get $ptr) (i32.const 4))
  )

  ;; ---- Memory copy ----
  (func $memcpy (param $dst i32) (param $src i32) (param $n i32)
    (local $i i32)
    (local.set $i (i32.const 0))
    (block $done
      (loop $copy
        (br_if $done (i32.ge_u (local.get $i) (local.get $n)))
        (i32.store8
          (i32.add (local.get $dst) (local.get $i))
          (i32.load8_u (i32.add (local.get $src) (local.get $i))))
        (local.set $i (i32.add (local.get $i) (i32.const 1)))
        (br $copy)
      )
    )
  )

  ;; ---- String comparison ----
  (func $str_eq (param $a i32) (param $b i32) (result i32)
    (local $alen i32) (local $blen i32) (local $i i32)
    (local.set $alen (call $string_len (local.get $a)))
    (local.set $blen (call $string_len (local.get $b)))
    (if (i32.ne (local.get $alen) (local.get $blen))
      (then (return (i32.const 0))))
    (local.set $i (i32.const 0))
    (block $done
      (loop $cmp
        (br_if $done (i32.ge_u (local.get $i) (local.get $alen)))
        (if (i32.ne
              (i32.load8_u (i32.add (call $string_data (local.get $a)) (local.get $i)))
              (i32.load8_u (i32.add (call $string_data (local.get $b)) (local.get $i))))
          (then (return (i32.const 0))))
        (local.set $i (i32.add (local.get $i) (i32.const 1)))
        (br $cmp)
      )
    )
    (i32.const 1)
  )

  ;; ---- String concatenation ----
  (func $str_concat (param $a i32) (param $b i32) (result i32)
    (local $alen i32) (local $blen i32) (local $ptr i32) (local $total i32)
    (local.set $alen (call $string_len (local.get $a)))
    (local.set $blen (call $string_len (local.get $b)))
    (local.set $total (i32.add (local.get $alen) (local.get $blen)))
    (local.set $ptr (call $alloc (i32.add (local.get $total) (i32.const 4))))
    (i32.store (local.get $ptr) (local.get $total))
    (call $memcpy
      (i32.add (local.get $ptr) (i32.const 4))
      (call $string_data (local.get $a))
      (local.get $alen))
    (call $memcpy
      (i32.add (i32.add (local.get $ptr) (i32.const 4)) (local.get $alen))
      (call $string_data (local.get $b))
      (local.get $blen))
    (local.get $ptr)
  )

  ;; ---- Constant pool access ----
  ;; Pool format: [count:u32] [entry...]
  ;; Each entry: [type:u8] [len:u32] [data:bytes]

  (func $constpool_entry (param $idx i32) (result i32)
    ;; Returns a heap-allocated string pointer for the constant at $idx.
    ;; Walks the constant pool to find the entry.
    (local $pos i32) (local $count i32) (local $i i32)
    (local $etype i32) (local $elen i32) (local $ptr i32)
    (local.set $pos (' << ic(constpoolBase) << '))
    (local.set $count (i32.load (local.get $pos)))
    (local.set $pos (i32.add (local.get $pos) (i32.const 4)))
    (local.set $i (i32.const 0))
    (block $found
      (loop $scan
        (br_if $found (i32.ge_u (local.get $i) (local.get $count)))
        (local.set $etype (i32.load8_u (local.get $pos)))
        (local.set $pos (i32.add (local.get $pos) (i32.const 1)))
        (local.set $elen (i32.load (local.get $pos)))
        (local.set $pos (i32.add (local.get $pos) (i32.const 4)))
        (if (i32.eq (local.get $i) (local.get $idx))
          (then
            ;; Allocate a heap string and copy data into it
            (local.set $ptr (call $alloc_string (local.get $pos) (local.get $elen)))
            (return (local.get $ptr))
          )
        )
        (local.set $pos (i32.add (local.get $pos) (local.get $elen)))
        (local.set $i (i32.add (local.get $i) (i32.const 1)))
        (br $scan)
      )
    )
    ;; Not found — return null (0)
    (i32.const 0)
  )

  ;; ---- Function table access ----
  ;; Table format: [count:u32] [entry...], each entry 9 bytes:
  ;;   [offset:u32][arity:u16][localCount:u16][hasRestArg:u8]

  (func $fntable_offset (param $idx i32) (result i32)
    (i32.load (i32.add
      (' << ic(fntableBase + 4) << ')
      (i32.mul (local.get $idx) (i32.const 9))))
  )

  (func $fntable_arity (param $idx i32) (result i32)
    (i32.load16_u (i32.add
      (' << ic(fntableBase + 8) << ')
      (i32.mul (local.get $idx) (i32.const 9))))
  )

  (func $fntable_locals (param $idx i32) (result i32)
    (i32.load16_u (i32.add
      (' << ic(fntableBase + 10) << ')
      (i32.mul (local.get $idx) (i32.const 9))))
  )

  ;; ---- Call frame management ----
  ;; Frame layout on call stack:
  ;;   [return_pc:i32][saved_sp:i32][locals_ptr:i32][local_count:i32]
  ;; Total frame header = 16 bytes. Locals are heap-allocated.

  (func $push_frame (param $ret_pc i32) (param $saved_sp i32)
    (param $locals_ptr i32) (param $local_count i32)
    (i32.store (global.get $csp) (local.get $ret_pc))
    (i32.store (i32.add (global.get $csp) (i32.const 4)) (local.get $saved_sp))
    (i32.store (i32.add (global.get $csp) (i32.const 8)) (local.get $locals_ptr))
    (i32.store (i32.add (global.get $csp) (i32.const 12)) (local.get $local_count))
    (global.set $csp (i32.add (global.get $csp) (i32.const 16)))
  )

  (func $pop_frame
    (global.set $csp (i32.sub (global.get $csp) (i32.const 16)))
  )

  (func $frame_ret_pc (result i32)
    (i32.load (i32.sub (global.get $csp) (i32.const 16)))
  )

  (func $frame_saved_sp (result i32)
    (i32.load (i32.sub (global.get $csp) (i32.const 12)))
  )

  (func $frame_locals_ptr (result i32)
    (i32.load (i32.sub (global.get $csp) (i32.const 8)))
  )

  (func $frame_local_count (result i32)
    (i32.load (i32.sub (global.get $csp) (i32.const 4)))
  )

  ;; ---- Local variable access (within current frame) ----
  ;; Locals are 8-byte tagged values on the heap
  ;; locals_ptr[idx] = [type:i32][val:i32]

  (func $get_local_type (param $idx i32) (result i32)
    (i32.load (i32.add
      (call $frame_locals_ptr)
      (i32.mul (local.get $idx) (i32.const 8))))
  )

  (func $get_local_val (param $idx i32) (result i32)
    (i32.load (i32.add
      (i32.add (call $frame_locals_ptr) (i32.const 4))
      (i32.mul (local.get $idx) (i32.const 8))))
  )

  (func $set_local (param $idx i32) (param $type i32) (param $val i32)
    (local $base i32)
    (local.set $base (i32.add
      (call $frame_locals_ptr)
      (i32.mul (local.get $idx) (i32.const 8))))
    (i32.store (local.get $base) (local.get $type))
    (i32.store (i32.add (local.get $base) (i32.const 4)) (local.get $val))
  )

  ;; ---- Allocate locals block ----
  (func $alloc_locals (param $count i32) (result i32)
    (local $ptr i32) (local $size i32)
    (local.set $size (i32.mul (local.get $count) (i32.const 8)))
    (local.set $ptr (call $alloc (local.get $size)))
    ;; Zero-initialize (all nulls: type=0, val=0)
    (call $memzero (local.get $ptr) (local.get $size))
    (local.get $ptr)
  )

  (func $memzero (param $dst i32) (param $n i32)
    (local $i i32)
    (local.set $i (i32.const 0))
    (block $done
      (loop $zero
        (br_if $done (i32.ge_u (local.get $i) (local.get $n)))
        (i32.store8 (i32.add (local.get $dst) (local.get $i)) (i32.const 0))
        (local.set $i (i32.add (local.get $i) (i32.const 1)))
        (br $zero)
      )
    )
  )

  ;; ---- Heap list helpers ----
  ;; List format: [len:i32][cap:i32][items_ptr:i32]
  ;; Items: array of 8-byte tagged values

  (func $alloc_list (param $count i32) (result i32)
    (local $ptr i32) (local $items i32)
    (local.set $items (call $alloc (i32.mul (local.get $count) (i32.const 8))))
    (local.set $ptr (call $alloc (i32.const 12)))
    (i32.store (local.get $ptr) (local.get $count))
    (i32.store (i32.add (local.get $ptr) (i32.const 4)) (local.get $count))
    (i32.store (i32.add (local.get $ptr) (i32.const 8)) (local.get $items))
    (local.get $ptr)
  )

  (func $list_len (param $ptr i32) (result i32)
    (i32.load (local.get $ptr))
  )

  (func $list_get_type (param $ptr i32) (param $idx i32) (result i32)
    (local $items i32)
    (local.set $items (i32.load (i32.add (local.get $ptr) (i32.const 8))))
    (i32.load (i32.add (local.get $items) (i32.mul (local.get $idx) (i32.const 8))))
  )

  (func $list_get_val (param $ptr i32) (param $idx i32) (result i32)
    (local $items i32)
    (local.set $items (i32.load (i32.add (local.get $ptr) (i32.const 8))))
    (i32.load (i32.add
      (i32.add (local.get $items) (i32.const 4))
      (i32.mul (local.get $idx) (i32.const 8))))
  )

  (func $list_set (param $ptr i32) (param $idx i32)
    (param $type i32) (param $val i32)
    (local $items i32) (local $base i32)
    (local.set $items (i32.load (i32.add (local.get $ptr) (i32.const 8))))
    (local.set $base (i32.add (local.get $items) (i32.mul (local.get $idx) (i32.const 8))))
    (i32.store (local.get $base) (local.get $type))
    (i32.store (i32.add (local.get $base) (i32.const 4)) (local.get $val))
  )

  ;; ---- Heap object helpers ----
  ;; Object format: [count:i32][capacity:i32][entries_ptr:i32]
  ;; Each entry: [key_str_ptr:i32][val_type:i32][val_payload:i32] = 12 bytes

  (func $alloc_object (param $cap i32) (result i32)
    (local $ptr i32) (local $entries i32)
    (local.set $entries (call $alloc (i32.mul (local.get $cap) (i32.const 12))))
    (call $memzero (local.get $entries) (i32.mul (local.get $cap) (i32.const 12)))
    (local.set $ptr (call $alloc (i32.const 12)))
    (i32.store (local.get $ptr) (i32.const 0))
    (i32.store (i32.add (local.get $ptr) (i32.const 4)) (local.get $cap))
    (i32.store (i32.add (local.get $ptr) (i32.const 8)) (local.get $entries))
    (local.get $ptr)
  )

  (func $object_count (param $ptr i32) (result i32)
    (i32.load (local.get $ptr))
  )

  (func $object_set (param $obj i32) (param $key i32)
    (param $vtype i32) (param $vval i32)
    (local $count i32) (local $cap i32) (local $entries i32)
    (local $i i32) (local $base i32) (local $ekey i32)
    (local.set $count (i32.load (local.get $obj)))
    (local.set $cap (i32.load (i32.add (local.get $obj) (i32.const 4))))
    (local.set $entries (i32.load (i32.add (local.get $obj) (i32.const 8))))
    ;; Search for existing key
    (local.set $i (i32.const 0))
    (block $found
      (loop $search
        (br_if $found (i32.ge_u (local.get $i) (local.get $count)))
        (local.set $base (i32.add (local.get $entries)
          (i32.mul (local.get $i) (i32.const 12))))
        (local.set $ekey (i32.load (local.get $base)))
        (if (call $str_eq (local.get $ekey) (local.get $key))
          (then
            ;; Update existing entry
            (i32.store (i32.add (local.get $base) (i32.const 4)) (local.get $vtype))
            (i32.store (i32.add (local.get $base) (i32.const 8)) (local.get $vval))
            (return)
          )
        )
        (local.set $i (i32.add (local.get $i) (i32.const 1)))
        (br $search)
      )
    )
    ;; Append new entry (simple, no resize for now)
    (local.set $base (i32.add (local.get $entries)
      (i32.mul (local.get $count) (i32.const 12))))
    (i32.store (local.get $base) (local.get $key))
    (i32.store (i32.add (local.get $base) (i32.const 4)) (local.get $vtype))
    (i32.store (i32.add (local.get $base) (i32.const 8)) (local.get $vval))
    (i32.store (local.get $obj) (i32.add (local.get $count) (i32.const 1)))
  )

  (func $object_get (param $obj i32) (param $key i32) (result i32)
    ;; Returns: type via result, val via $tmp_val global
    ;; Returns TAG_NULL (0) if key not found
    (local $count i32) (local $entries i32)
    (local $i i32) (local $base i32) (local $ekey i32)
    (local.set $count (i32.load (local.get $obj)))
    (local.set $entries (i32.load (i32.add (local.get $obj) (i32.const 8))))
    (local.set $i (i32.const 0))
    (block $done
      (loop $search
        (br_if $done (i32.ge_u (local.get $i) (local.get $count)))
        (local.set $base (i32.add (local.get $entries)
          (i32.mul (local.get $i) (i32.const 12))))
        (local.set $ekey (i32.load (local.get $base)))
        (if (call $str_eq (local.get $ekey) (local.get $key))
          (then
            (global.set $tmp_val
              (i32.load (i32.add (local.get $base) (i32.const 8))))
            (return (i32.load (i32.add (local.get $base) (i32.const 4))))
          )
        )
        (local.set $i (i32.add (local.get $i) (i32.const 1)))
        (br $search)
      )
    )
    ;; Not found
    (global.set $tmp_val (i32.const 0))
    (i32.const 0)
  )

  ;; ---- Closure helpers ----
  ;; Closure heap format: [fn_idx:i32][scope_csp:i32]

  (func $alloc_closure (param $fn_idx i32) (param $scope_csp i32) (result i32)
    (local $ptr i32)
    (local.set $ptr (call $alloc (i32.const 8)))
    (i32.store (local.get $ptr) (local.get $fn_idx))
    (i32.store (i32.add (local.get $ptr) (i32.const 4)) (local.get $scope_csp))
    (local.get $ptr)
  )

  (func $closure_fn_idx (param $ptr i32) (result i32)
    (i32.load (local.get $ptr))
  )

  ;; ---- Integer to string conversion ----
  (func $int_to_string (param $val i32) (result i32)
    (local $ptr i32) (local $pos i32) (local $n i32)
    (local $neg i32) (local $digit i32) (local $start i32) (local $end i32)
    (local $tmp i32)
    ;; Max 12 chars for i32 (-2147483648)
    (local.set $ptr (call $alloc (i32.const 16)))
    (local.set $start (i32.add (local.get $ptr) (i32.const 4)))
    (local.set $pos (local.get $start))
    (local.set $n (local.get $val))
    (local.set $neg (i32.const 0))
    (if (i32.lt_s (local.get $n) (i32.const 0))
      (then
        (local.set $neg (i32.const 1))
        (local.set $n (i32.sub (i32.const 0) (local.get $n)))
      )
    )
    (if (i32.eqz (local.get $n))
      (then
        (i32.store8 (local.get $pos) (i32.const 48))
        (local.set $pos (i32.add (local.get $pos) (i32.const 1)))
      )
      (else
        (block $digits_done
          (loop $digits
            (br_if $digits_done (i32.eqz (local.get $n)))
            (local.set $digit (i32.rem_u (local.get $n) (i32.const 10)))
            (i32.store8 (local.get $pos) (i32.add (local.get $digit) (i32.const 48)))
            (local.set $pos (i32.add (local.get $pos) (i32.const 1)))
            (local.set $n (i32.div_u (local.get $n) (i32.const 10)))
            (br $digits)
          )
        )
        (if (local.get $neg)
          (then
            (i32.store8 (local.get $pos) (i32.const 45))
            (local.set $pos (i32.add (local.get $pos) (i32.const 1)))
          )
        )
        ;; Reverse the digits in place
        (local.set $end (i32.sub (local.get $pos) (i32.const 1)))
        (block $rev_done
          (loop $rev
            (br_if $rev_done (i32.ge_u (local.get $start) (local.get $end)))
            (local.set $tmp (i32.load8_u (local.get $start)))
            (i32.store8 (local.get $start) (i32.load8_u (local.get $end)))
            (i32.store8 (local.get $end) (local.get $tmp))
            (local.set $start (i32.add (local.get $start) (i32.const 1)))
            (local.set $end (i32.sub (local.get $end) (i32.const 1)))
            (br $rev)
          )
        )
      )
    )
    ;; Store length
    (i32.store (local.get $ptr)
      (i32.sub (local.get $pos) (i32.add (local.get $ptr) (i32.const 4))))
    (local.get $ptr)
  )

  ;; ---- Value equality ----
  (func $val_eq (param $t1 i32) (param $v1 i32)
    (param $t2 i32) (param $v2 i32) (result i32)
    ;; Oak empty (_) equals everything
    (if (i32.or (i32.eq (local.get $t1) (i32.const 1))
                (i32.eq (local.get $t2) (i32.const 1)))
      (then (return (i32.const 1))))
    ;; Types must match for all other comparisons
    (if (i32.ne (local.get $t1) (local.get $t2))
      (then (return (i32.const 0))))
    ;; Same type — compare by type
    (if (i32.or (i32.eq (local.get $t1) (i32.const 0))   ;; null = null
                (i32.eq (local.get $t1) (i32.const 1)))   ;; empty = empty
      (then (return (i32.const 1))))
    (if (i32.le_u (local.get $t1) (i32.const 4))          ;; int, float, bool: compare payload
      (then (return (i32.eq (local.get $v1) (local.get $v2)))))
    (if (i32.or (i32.eq (local.get $t1) (i32.const 5))    ;; string
                (i32.eq (local.get $t1) (i32.const 6)))    ;; atom
      (then (return (call $str_eq (local.get $v1) (local.get $v2)))))
    ;; Lists & objects: reference equality for now
    (i32.eq (local.get $v1) (local.get $v2))
  )

  ;; ===================================================================
  ;; ---- VM DISPATCH LOOP ----
  ;; ===================================================================

  (func $vm_run (export "run")
    (local $op i32)
    (local $t1 i32) (local $v1 i32)
    (local $t2 i32) (local $v2 i32)
    (local $idx i32) (local $tmp i32) (local $tmp2 i32)
    (local $fn_idx i32) (local $arity i32) (local $expected i32)
    (local $locals_ptr i32) (local $i i32)
    (local $key_ptr i32) (local $obj_ptr i32) (local $list_ptr i32)
    (local $ret_type i32) (local $ret_val i32)

    ;; Push an initial frame for the top-level program
    (call $push_frame
      (i32.const 0)                     ;; no return address
      (global.get $sp)                  ;; saved sp
      (call $alloc_locals (i32.const 256)) ;; generous top-level locals
      (i32.const 256))

    (block $halt
      (loop $dispatch
        ;; ---- Fetch opcode ----
        (local.set $op (call $fetch_u8))

        ;; ---- Dispatch via nested blocks + br_table ----
' << generateDispatchTable() << '
        (br $dispatch)
      ) ;; end loop
    ) ;; end halt block
  ) ;; end $vm_run

  ;; ---- Built-in function dispatcher ----
  (func $call_builtin (param $bi i32) (param $arity i32)
    (local $t1 i32) (local $v1 i32)
    ;; Dispatch by builtin index
    (if (i32.eqz (local.get $bi))
      (then
        ;; BUILTIN_PRINT (0): print(value)
        (local.set $t1 (call $pop_tagged))
        (local.set $v1 (global.get $tmp_val))
        (if (i32.eq (local.get $t1) (i32.const 5))   ;; TAG_STRING
          (then
            (call $host_print
              (call $string_data (local.get $v1))
              (call $string_len (local.get $v1)))
          )
          (else
            ;; Convert to string first
            (if (i32.eq (local.get $t1) (i32.const 2))  ;; TAG_INT
              (then
                (local.set $v1 (call $int_to_string (local.get $v1)))
                (call $host_print
                  (call $string_data (local.get $v1))
                  (call $string_len (local.get $v1)))
              )
              (else
                (if (i32.eq (local.get $t1) (i32.const 0))  ;; TAG_NULL
                  (then (nop))
                )
              )
            )
          )
        )
        (call $push_val (i32.const 0) (i32.const 0))  ;; return null
      )
    )
    (if (i32.eq (local.get $bi) (i32.const 1))
      (then
        ;; BUILTIN_LEN (1): len(value) -> int
        (local.set $t1 (call $pop_tagged))
        (local.set $v1 (global.get $tmp_val))
        (if (i32.eq (local.get $t1) (i32.const 5))           ;; string
          (then (call $push_val (i32.const 2) (call $string_len (local.get $v1))))
          (else (if (i32.eq (local.get $t1) (i32.const 7))   ;; list
            (then (call $push_val (i32.const 2) (call $list_len (local.get $v1))))
            (else (if (i32.eq (local.get $t1) (i32.const 8)) ;; object
              (then (call $push_val (i32.const 2) (call $object_count (local.get $v1))))
              (else (call $push_val (i32.const 2) (i32.const 0)))
            ))
          ))
        )
      )
    )
    (if (i32.eq (local.get $bi) (i32.const 2))
      (then
        ;; BUILTIN_TYPE (2): type(value) -> atom
        (local.set $t1 (call $pop_tagged))
        (drop (global.get $tmp_val))
        ;; Return atom for the type name (reuse constant pool)
        (call $push_val (i32.const 6)
          (call $constpool_entry (local.get $t1)))
      )
    )
    (if (i32.eq (local.get $bi) (i32.const 3))
      (then
        ;; BUILTIN_STRING (3): string(value) -> string
        (local.set $t1 (call $pop_tagged))
        (local.set $v1 (global.get $tmp_val))
        (if (i32.eq (local.get $t1) (i32.const 5))  ;; already string
          (then (call $push_val (i32.const 5) (local.get $v1)))
          (else (if (i32.eq (local.get $t1) (i32.const 2)) ;; int
            (then (call $push_val (i32.const 5) (call $int_to_string (local.get $v1))))
            (else (call $push_val (i32.const 5)
              (call $int_to_string (local.get $v1)))) ;; fallback
          ))
        )
      )
    )
    (if (i32.eq (local.get $bi) (i32.const 13))
      (then
        ;; BUILTIN_EXIT (13)
        (local.set $t1 (call $pop_tagged))
        (local.set $v1 (global.get $tmp_val))
        (call $host_exit (local.get $v1))
      )
    )
  )

  ;; ---- Entry point ----
  (func (export "main") (result i32)
    (call $vm_run)
    (i32.const 0)
  )

  (func (export "bytecode_base") (result i32)
    (global.get $bytecode_base)
  )

  (func (export "constpool_base") (result i32)
    (global.get $constpool_base)
  )
)
'
}

// ---------------------------------------------------------------------------
// Generate the br_table dispatch block for all opcodes
// ---------------------------------------------------------------------------
fn generateDispatchTable() {
	// Each opcode handler is a block of WAT instructions.
	// The br_table jumps to the right block, then each block
	// falls through to the handler code.

	handlers := [
		// 0: HALT
		'(br $halt)'

		// 1: NOP
		'(nop)'

		// 2: CONST_NULL
		'(call $push_val (i32.const 0) (i32.const 0))'

		// 3: CONST_EMPTY
		'(call $push_val (i32.const 1) (i32.const 0))'

		// 4: CONST_TRUE
		'(call $push_val (i32.const 4) (i32.const 1))'

		// 5: CONST_FALSE
		'(call $push_val (i32.const 4) (i32.const 0))'

		// 6: CONST_INT — fetch i32 operand, push as int
		'(call $push_val (i32.const 2) (call $fetch_i32))'

		// 7: CONST_FLOAT — fetch u16 pool index, resolve
		'(local.set $idx (call $fetch_u16))
        (call $push_val (i32.const 3) (call $constpool_entry (local.get $idx)))'

		// 8: CONST_STRING — fetch u16 pool index, resolve
		'(local.set $idx (call $fetch_u16))
        (call $push_val (i32.const 5) (call $constpool_entry (local.get $idx)))'

		// 9: CONST_ATOM — fetch u16 pool index, resolve
		'(local.set $idx (call $fetch_u16))
        (call $push_val (i32.const 6) (call $constpool_entry (local.get $idx)))'

		// 10: POP
		'(drop (call $pop_tagged))
        (drop (global.get $tmp_val))'

		// 11: DUP
		'(call $push_val (call $peek_type) (call $peek_val))'

		// 12: LOAD_LOCAL
		'(local.set $idx (call $fetch_u16))
        (call $push_val
          (call $get_local_type (local.get $idx))
          (call $get_local_val (local.get $idx)))'

		// 13: STORE_LOCAL
		'(local.set $idx (call $fetch_u16))
        (local.set $t1 (call $pop_tagged))
        (local.set $v1 (global.get $tmp_val))
        (call $set_local (local.get $idx) (local.get $t1) (local.get $v1))'

		// 14: LOAD_UPVAL — simplified: not yet implemented; push null
		'(drop (call $fetch_u16))
        (drop (call $fetch_u16))
        (call $push_val (i32.const 0) (i32.const 0))'

		// 15: STORE_UPVAL — simplified: not yet implemented; pop and discard
		'(drop (call $fetch_u16))
        (drop (call $fetch_u16))
        (drop (call $pop_tagged))
        (drop (global.get $tmp_val))'

		// 16: ADD
		'(local.set $t2 (call $pop_tagged))
        (local.set $v2 (global.get $tmp_val))
        (local.set $t1 (call $pop_tagged))
        (local.set $v1 (global.get $tmp_val))
        (if (i32.and (i32.eq (local.get $t1) (i32.const 2))
                     (i32.eq (local.get $t2) (i32.const 2)))
          (then (call $push_val (i32.const 2)
            (i32.add (local.get $v1) (local.get $v2))))
          (else (if (i32.and (i32.eq (local.get $t1) (i32.const 5))
                             (i32.eq (local.get $t2) (i32.const 5)))
            (then (call $push_val (i32.const 5)
              (call $str_concat (local.get $v1) (local.get $v2))))
            (else (call $push_val (i32.const 2)
              (i32.add (local.get $v1) (local.get $v2))))
          ))
        )'

		// 17: SUB
		'(local.set $t2 (call $pop_tagged))
        (local.set $v2 (global.get $tmp_val))
        (local.set $t1 (call $pop_tagged))
        (local.set $v1 (global.get $tmp_val))
        (call $push_val (i32.const 2)
          (i32.sub (local.get $v1) (local.get $v2)))'

		// 18: MUL
		'(local.set $t2 (call $pop_tagged))
        (local.set $v2 (global.get $tmp_val))
        (local.set $t1 (call $pop_tagged))
        (local.set $v1 (global.get $tmp_val))
        (call $push_val (i32.const 2)
          (i32.mul (local.get $v1) (local.get $v2)))'

		// 19: DIV
		'(local.set $t2 (call $pop_tagged))
        (local.set $v2 (global.get $tmp_val))
        (local.set $t1 (call $pop_tagged))
        (local.set $v1 (global.get $tmp_val))
        (if (i32.eqz (local.get $v2))
          (then (call $push_val (i32.const 0) (i32.const 0)))
          (else (call $push_val (i32.const 2)
            (i32.div_s (local.get $v1) (local.get $v2))))
        )'

		// 20: MOD
		'(local.set $t2 (call $pop_tagged))
        (local.set $v2 (global.get $tmp_val))
        (local.set $t1 (call $pop_tagged))
        (local.set $v1 (global.get $tmp_val))
        (if (i32.eqz (local.get $v2))
          (then (call $push_val (i32.const 0) (i32.const 0)))
          (else (call $push_val (i32.const 2)
            (i32.rem_s (local.get $v1) (local.get $v2))))
        )'

		// 21: POW (simplified: use multiplication loop for small exponents)
		'(local.set $t2 (call $pop_tagged))
        (local.set $v2 (global.get $tmp_val))
        (local.set $t1 (call $pop_tagged))
        (local.set $v1 (global.get $tmp_val))
        (local.set $tmp (i32.const 1))
        (local.set $i (i32.const 0))
        (block $pow_done
          (loop $pow_loop
            (br_if $pow_done (i32.ge_s (local.get $i) (local.get $v2)))
            (local.set $tmp (i32.mul (local.get $tmp) (local.get $v1)))
            (local.set $i (i32.add (local.get $i) (i32.const 1)))
            (br $pow_loop)
          )
        )
        (call $push_val (i32.const 2) (local.get $tmp))'

		// 22: NEG
		'(local.set $t1 (call $pop_tagged))
        (local.set $v1 (global.get $tmp_val))
        (call $push_val (local.get $t1)
          (i32.sub (i32.const 0) (local.get $v1)))'

		// 23: BAND
		'(local.set $t2 (call $pop_tagged))
        (local.set $v2 (global.get $tmp_val))
        (local.set $t1 (call $pop_tagged))
        (local.set $v1 (global.get $tmp_val))
        (call $push_val (i32.const 2)
          (i32.and (local.get $v1) (local.get $v2)))'

		// 24: BOR
		'(local.set $t2 (call $pop_tagged))
        (local.set $v2 (global.get $tmp_val))
        (local.set $t1 (call $pop_tagged))
        (local.set $v1 (global.get $tmp_val))
        (call $push_val (i32.const 2)
          (i32.or (local.get $v1) (local.get $v2)))'

		// 25: BXOR
		'(local.set $t2 (call $pop_tagged))
        (local.set $v2 (global.get $tmp_val))
        (local.set $t1 (call $pop_tagged))
        (local.set $v1 (global.get $tmp_val))
        (call $push_val (i32.const 2)
          (i32.xor (local.get $v1) (local.get $v2)))'

		// 26: BRSHIFT
		'(local.set $t2 (call $pop_tagged))
        (local.set $v2 (global.get $tmp_val))
        (local.set $t1 (call $pop_tagged))
        (local.set $v1 (global.get $tmp_val))
        (call $push_val (i32.const 2)
          (i32.shr_u (local.get $v1) (local.get $v2)))'

		// 27: EQ
		'(local.set $t2 (call $pop_tagged))
        (local.set $v2 (global.get $tmp_val))
        (local.set $t1 (call $pop_tagged))
        (local.set $v1 (global.get $tmp_val))
        (call $push_val (i32.const 4)
          (call $val_eq
            (local.get $t1) (local.get $v1)
            (local.get $t2) (local.get $v2)))'

		// 28: NEQ
		'(local.set $t2 (call $pop_tagged))
        (local.set $v2 (global.get $tmp_val))
        (local.set $t1 (call $pop_tagged))
        (local.set $v1 (global.get $tmp_val))
        (call $push_val (i32.const 4)
          (i32.eqz (call $val_eq
            (local.get $t1) (local.get $v1)
            (local.get $t2) (local.get $v2))))'

		// 29: GT
		'(local.set $t2 (call $pop_tagged))
        (local.set $v2 (global.get $tmp_val))
        (local.set $t1 (call $pop_tagged))
        (local.set $v1 (global.get $tmp_val))
        (call $push_val (i32.const 4)
          (i32.gt_s (local.get $v1) (local.get $v2)))'

		// 30: LT
		'(local.set $t2 (call $pop_tagged))
        (local.set $v2 (global.get $tmp_val))
        (local.set $t1 (call $pop_tagged))
        (local.set $v1 (global.get $tmp_val))
        (call $push_val (i32.const 4)
          (i32.lt_s (local.get $v1) (local.get $v2)))'

		// 31: GEQ
		'(local.set $t2 (call $pop_tagged))
        (local.set $v2 (global.get $tmp_val))
        (local.set $t1 (call $pop_tagged))
        (local.set $v1 (global.get $tmp_val))
        (call $push_val (i32.const 4)
          (i32.ge_s (local.get $v1) (local.get $v2)))'

		// 32: LEQ
		'(local.set $t2 (call $pop_tagged))
        (local.set $v2 (global.get $tmp_val))
        (local.set $t1 (call $pop_tagged))
        (local.set $v1 (global.get $tmp_val))
        (call $push_val (i32.const 4)
          (i32.le_s (local.get $v1) (local.get $v2)))'

		// 33: NOT
		'(local.set $t1 (call $pop_tagged))
        (local.set $v1 (global.get $tmp_val))
        (call $push_val (i32.const 4)
          (i32.eqz (local.get $v1)))'

		// 34: CONCAT (<<)
		'(local.set $t2 (call $pop_tagged))
        (local.set $v2 (global.get $tmp_val))
        (local.set $t1 (call $pop_tagged))
        (local.set $v1 (global.get $tmp_val))
        (if (i32.and (i32.eq (local.get $t1) (i32.const 5))
                     (i32.eq (local.get $t2) (i32.const 5)))
          (then (call $push_val (i32.const 5)
            (call $str_concat (local.get $v1) (local.get $v2))))
          (else (call $push_val (i32.const 5)
            (call $str_concat (local.get $v1) (local.get $v2))))
        )'

		// 35: MAKE_LIST
		'(local.set $idx (call $fetch_u16))
        (local.set $list_ptr (call $alloc_list (local.get $idx)))
        ;; Pop elements in reverse order and store
        (local.set $i (i32.sub (local.get $idx) (i32.const 1)))
        (block $list_done
          (loop $list_fill
            (br_if $list_done (i32.lt_s (local.get $i) (i32.const 0)))
            (local.set $t1 (call $pop_tagged))
            (local.set $v1 (global.get $tmp_val))
            (call $list_set (local.get $list_ptr) (local.get $i)
              (local.get $t1) (local.get $v1))
            (local.set $i (i32.sub (local.get $i) (i32.const 1)))
            (br $list_fill)
          )
        )
        (call $push_val (i32.const 7) (local.get $list_ptr))'

		// 36: MAKE_OBJECT
		'(local.set $idx (call $fetch_u16))
        (local.set $obj_ptr (call $alloc_object
          (if (result i32) (i32.eqz (local.get $idx))
            (then (i32.const 4))
            (else (local.get $idx)))))
        ;; Pop pairs in reverse order (key, val)
        (local.set $i (i32.sub (local.get $idx) (i32.const 1)))
        (block $obj_done
          (loop $obj_fill
            (br_if $obj_done (i32.lt_s (local.get $i) (i32.const 0)))
            ;; Pop value first (it was pushed last)
            (local.set $t2 (call $pop_tagged))
            (local.set $v2 (global.get $tmp_val))
            ;; Pop key
            (local.set $t1 (call $pop_tagged))
            (local.set $v1 (global.get $tmp_val))
            (call $object_set (local.get $obj_ptr)
              (local.get $v1)    ;; key (string ptr)
              (local.get $t2) (local.get $v2))
            (local.set $i (i32.sub (local.get $i) (i32.const 1)))
            (br $obj_fill)
          )
        )
        (call $push_val (i32.const 8) (local.get $obj_ptr))'

		// 37: GET_PROP
		'(local.set $t2 (call $pop_tagged))   ;; key
        (local.set $v2 (global.get $tmp_val))
        (local.set $t1 (call $pop_tagged))   ;; obj/list
        (local.set $v1 (global.get $tmp_val))
        (if (i32.eq (local.get $t1) (i32.const 8))   ;; object
          (then
            (local.set $tmp (call $object_get (local.get $v1) (local.get $v2)))
            (call $push_val (local.get $tmp) (global.get $tmp_val))
          )
          (else (if (i32.eq (local.get $t1) (i32.const 7))   ;; list
            (then
              (if (i32.eq (local.get $t2) (i32.const 2))  ;; int index
                (then
                  (if (i32.lt_u (local.get $v2) (call $list_len (local.get $v1)))
                    (then
                      (call $push_val
                        (call $list_get_type (local.get $v1) (local.get $v2))
                        (call $list_get_val (local.get $v1) (local.get $v2)))
                    )
                    (else (call $push_val (i32.const 0) (i32.const 0)))
                  )
                )
                (else (call $push_val (i32.const 0) (i32.const 0)))
              )
            )
            (else (if (i32.eq (local.get $t1) (i32.const 5))  ;; string
              (then
                ;; String indexing: s.(i) returns single char
                (if (i32.and
                      (i32.eq (local.get $t2) (i32.const 2))
                      (i32.lt_u (local.get $v2) (call $string_len (local.get $v1))))
                  (then
                    (local.set $tmp (call $alloc_string
                      (i32.add (call $string_data (local.get $v1)) (local.get $v2))
                      (i32.const 1)))
                    (call $push_val (i32.const 5) (local.get $tmp))
                  )
                  (else (call $push_val (i32.const 0) (i32.const 0)))
                )
              )
              (else (call $push_val (i32.const 0) (i32.const 0)))
            ))
          ))
        )'

		// 38: SET_PROP
		'(local.set $t2 (call $pop_tagged))    ;; value
        (local.set $v2 (global.get $tmp_val))
        (local.set $t1 (call $pop_tagged))    ;; key
        (local.set $v1 (global.get $tmp_val))
        (local.set $tmp (call $pop_tagged))   ;; object type
        (local.set $tmp2 (global.get $tmp_val)) ;; object ptr
        (if (i32.eq (local.get $tmp) (i32.const 8))
          (then
            (call $object_set (local.get $tmp2) (local.get $v1)
              (local.get $t2) (local.get $v2))
          )
          (else (if (i32.eq (local.get $tmp) (i32.const 7))
            (then
              ;; list[idx] = val
              (if (i32.eq (local.get $t1) (i32.const 2))
                (then
                  (call $list_set (local.get $tmp2) (local.get $v1)
                    (local.get $t2) (local.get $v2))
                )
              )
            )
          ))
        )
        (call $push_val (local.get $tmp) (local.get $tmp2))'

		// 39: JUMP
		'(global.set $pc (i32.add
          (global.get $bytecode_base)
          (call $fetch_i32)))'

		// 40: JUMP_FALSE
		'(local.set $idx (call $fetch_i32))
        (local.set $t1 (call $pop_tagged))
        (local.set $v1 (global.get $tmp_val))
        (if (i32.or
              (i32.and (i32.eq (local.get $t1) (i32.const 4))
                       (i32.eqz (local.get $v1)))      ;; bool false
              (i32.eq (local.get $t1) (i32.const 0)))   ;; null
          (then
            (global.set $pc (i32.add
              (global.get $bytecode_base)
              (local.get $idx)))
          )
        )'

		// 41: CLOSURE
		'(local.set $idx (call $fetch_u16))
        (call $push_val (i32.const 9)
          (call $alloc_closure (local.get $idx) (global.get $csp)))'

		// 42: CALL
		'(local.set $arity (call $fetch_u8))
        ;; Peek at the function value below the arguments
        ;; Stack: ... fn arg0 arg1 ... argN
        (local.set $tmp (i32.sub (global.get $sp)
          (i32.mul (i32.add (local.get $arity) (i32.const 1)) (i32.const 8))))
        (local.set $t1 (i32.load (local.get $tmp)))
        (local.set $v1 (i32.load (i32.add (local.get $tmp) (i32.const 4))))
        (if (i32.eq (local.get $t1) (i32.const 9))   ;; TAG_FUNCTION
          (then
            (local.set $fn_idx (call $closure_fn_idx (local.get $v1)))
            (local.set $expected (call $fntable_arity (local.get $fn_idx)))
            ;; Allocate new locals
            (local.set $locals_ptr
              (call $alloc_locals (call $fntable_locals (local.get $fn_idx))))
            ;; Copy arguments into locals
            (local.set $i (i32.const 0))
            (block $copy_done
              (loop $copy_args
                (br_if $copy_done (i32.ge_u (local.get $i) (local.get $arity)))
                ;; Read arg from stack (after function slot)
                (local.set $tmp2 (i32.add (local.get $tmp)
                  (i32.mul (i32.add (local.get $i) (i32.const 1)) (i32.const 8))))
                (call $set_local_at (local.get $locals_ptr) (local.get $i)
                  (i32.load (local.get $tmp2))
                  (i32.load (i32.add (local.get $tmp2) (i32.const 4))))
                (local.set $i (i32.add (local.get $i) (i32.const 1)))
                (br $copy_args)
              )
            )
            ;; Restore SP to before function + args
            (global.set $sp (local.get $tmp))
            ;; Push call frame
            (call $push_frame
              (global.get $pc)
              (global.get $sp)
              (local.get $locals_ptr)
              (call $fntable_locals (local.get $fn_idx)))
            ;; Jump to function body
            (global.set $pc (i32.add
              (global.get $bytecode_base)
              (call $fntable_offset (local.get $fn_idx))))
          )
          (else
            ;; Not a function — push null
            ;; Pop the args + fn off the stack
            (global.set $sp (local.get $tmp))
            (call $push_val (i32.const 0) (i32.const 0))
          )
        )'

		// 43: RETURN
		'(local.set $ret_type (call $peek_type))
        (local.set $ret_val (call $peek_val))
        ;; Restore caller state
        (global.set $pc (call $frame_ret_pc))
        (global.set $sp (call $frame_saved_sp))
        (call $pop_frame)
        ;; Push return value
        (call $push_val (local.get $ret_type) (local.get $ret_val))
        ;; If pc = 0, this was the top-level program — halt
        (if (i32.eqz (global.get $pc))
          (then (br $halt))
        )'

		// 44: TAIL_CALL — same as CALL for now
		'(local.set $arity (call $fetch_u8))
        (local.set $tmp (i32.sub (global.get $sp)
          (i32.mul (i32.add (local.get $arity) (i32.const 1)) (i32.const 8))))
        (local.set $t1 (i32.load (local.get $tmp)))
        (local.set $v1 (i32.load (i32.add (local.get $tmp) (i32.const 4))))
        (if (i32.eq (local.get $t1) (i32.const 9))
          (then
            (local.set $fn_idx (call $closure_fn_idx (local.get $v1)))
            (local.set $locals_ptr
              (call $alloc_locals (call $fntable_locals (local.get $fn_idx))))
            (local.set $i (i32.const 0))
            (block $tc_done
              (loop $tc_args
                (br_if $tc_done (i32.ge_u (local.get $i) (local.get $arity)))
                (local.set $tmp2 (i32.add (local.get $tmp)
                  (i32.mul (i32.add (local.get $i) (i32.const 1)) (i32.const 8))))
                (call $set_local_at (local.get $locals_ptr) (local.get $i)
                  (i32.load (local.get $tmp2))
                  (i32.load (i32.add (local.get $tmp2) (i32.const 4))))
                (local.set $i (i32.add (local.get $i) (i32.const 1)))
                (br $tc_args)
              )
            )
            ;; Reuse current frame (tail call optimization)
            (global.set $sp (local.get $tmp))
            (i32.store (i32.sub (global.get $csp) (i32.const 8)) (local.get $locals_ptr))
            (i32.store (i32.sub (global.get $csp) (i32.const 4))
              (call $fntable_locals (local.get $fn_idx)))
            (global.set $pc (i32.add
              (global.get $bytecode_base)
              (call $fntable_offset (local.get $fn_idx))))
          )
          (else
            (global.set $sp (local.get $tmp))
            (call $push_val (i32.const 0) (i32.const 0))
          )
        )'

		// 45: BUILTIN
		'(local.set $idx (call $fetch_u16))
        (local.set $arity (call $fetch_u8))
        (call $call_builtin (local.get $idx) (local.get $arity))'

		// 46: IMPORT — push null for now (modules are pre-bundled)
		'(drop (call $pop_tagged))
        (drop (global.get $tmp_val))
        (call $push_val (i32.const 0) (i32.const 0))'

		// 47: DEEP_EQ — same as EQ for now
		'(local.set $t2 (call $pop_tagged))
        (local.set $v2 (global.get $tmp_val))
        (local.set $t1 (call $pop_tagged))
        (local.set $v1 (global.get $tmp_val))
        (call $push_val (i32.const 4)
          (call $val_eq (local.get $t1) (local.get $v1)
                        (local.get $t2) (local.get $v2)))'

		// 48: SWAP
		'(local.set $t2 (call $pop_tagged))
        (local.set $v2 (global.get $tmp_val))
        (local.set $t1 (call $pop_tagged))
        (local.set $v1 (global.get $tmp_val))
        (call $push_val (local.get $t2) (local.get $v2))
        (call $push_val (local.get $t1) (local.get $v1))'

		// 49: MATCH_JUMP
		'(local.set $t2 (call $pop_tagged))
        (local.set $v2 (global.get $tmp_val))
        (local.set $idx (call $fetch_i32))
        ;; Compare with TOS (condition on top of stack, without popping)
        (if (i32.eqz (call $val_eq
              (call $peek_type) (call $peek_val)
              (local.get $t2) (local.get $v2)))
          (then
            (global.set $pc (i32.add
              (global.get $bytecode_base)
              (local.get $idx)))
          )
        )'

		// 50: SCOPE_PUSH
		'(nop)'

		// 51: SCOPE_POP
		'(nop)'
	]

	numOps := len(handlers)

	// Build the WAT block structure for br_table dispatch
	// Pattern: nested blocks, one per opcode, with br_table at the innermost level
	result := ''

	// Open all blocks (outermost = $op_default, innermost = $op_0)
	result <- result << '        (block $op_default\n'
	fn openBlocks(i) if i < numOps {
		true -> {
			result <- result << '        (block $op_' << string(i) << '\n'
			openBlocks(i + 1)
		}
	}
	openBlocks(0)

	// br_table instruction
	result <- result << '          (br_table'
	fn addLabels(i) if i < numOps {
		true -> {
			result <- result << ' $op_' << string(i)
			addLabels(i + 1)
		}
	}
	addLabels(0)
	result <- result << ' $op_default (local.get $op))\n'

	// Close blocks and add handlers
	fn closeBlocks(i) if i < numOps {
		true -> {
			result <- result << '        ) ;; $op_' << string(i) << '\n'
			result <- result << '        ;; -- ' << if i < len(OpcodeName) { true -> OpcodeName.(i), _ -> '???' } << ' --\n'
			result <- result << '        ' << handlers.(i) << '\n'
			result <- result << '        (br $dispatch)\n'
			closeBlocks(i + 1)
		}
	}
	closeBlocks(0)

	// Close $op_default block
	result <- result << '        ) ;; $op_default — unknown opcode\n'
	result <- result << '        (br $halt)\n'

	result
}

// Helper function referenced from the CALL handler
// Needs to be emitted in the WAT module
fn generateSetLocalAtHelper() {
	'
  ;; Helper: set local in an explicit locals block (not current frame)
  (func $set_local_at (param $locals_ptr i32) (param $idx i32)
    (param $type i32) (param $val i32)
    (local $base i32)
    (local.set $base (i32.add
      (local.get $locals_ptr)
      (i32.mul (local.get $idx) (i32.const 8))))
    (i32.store (local.get $base) (local.get $type))
    (i32.store (i32.add (local.get $base) (i32.const 4)) (local.get $val))
  )
'
}
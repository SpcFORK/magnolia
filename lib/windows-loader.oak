fn _familyDll(prefix, suffix) if suffix {
	? -> prefix + '.dll'
	_ -> if len(suffix) >= 4 {
		true -> if suffix.(len(suffix) - 4) = '.dll' {
			true -> suffix
			_ -> prefix + suffix + '.dll'
		}
		_ -> prefix + suffix + '.dll'
	}
}

fn msvcpDll(suffix) _familyDll(MsvcpPrefix, suffix)

fn msvcpFamily(suffix, symbol, args...) if isWindows?() {
	true -> callIn(msvcpDll(suffix), symbol, args...)
	_ -> _platformError('msvcpFamily')
}


	VcompPrefix: VcompPrefix
} := import('windows-constants')

{
	moduleHandle: moduleHandle
	loadLibrary: loadLibrary
	procAddress: procAddress
} := import('windows-kernel')

_loadedLibraries := {}

fn _platformError(apiName) {
	{
		type: :error
		error: apiName + ' is only available on Windows'
	}
}

fn isWindows? ___runtime_sys_info().os = 'windows'

fn _normalizeHandleResult(result, apiName, library) if sys.ok?(result) & result.r1 > 0 {
	true -> {
		{
			type: :ok
			handle: result.r1
			library: library
		}
	}
	_ -> {
		{
			type: :error
			error: apiName + ' failed'
			library: library
			detail: result
		}
	}
}

fn loadDll(library) if isWindows?() {
	true -> if cached := _loadedLibraries.(library) {
		? -> {
			alreadyLoaded := moduleHandle(library)
			if sys.ok?(alreadyLoaded) & alreadyLoaded.r1 > 0 {
				true -> {
					_loadedLibraries.(library) := alreadyLoaded.r1
					{
						type: :ok
						handle: alreadyLoaded.r1
						library: library
					}
				}
				_ -> {
					loaded := loadLibrary(library)
					result := _normalizeHandleResult(loaded, 'LoadLibraryW', library)
					if result.type {
						:ok -> {
							_loadedLibraries.(library) := result.handle
							result
						}
						_ -> {
							systemPath := 'C:\\Windows\\System32\\' + library
							loadedSystem := loadLibrary(systemPath)
							systemResult := _normalizeHandleResult(loadedSystem, 'LoadLibraryW', systemPath)
							if systemResult.type {
								:ok -> {
									_loadedLibraries.(library) := systemResult.handle
									{
										type: :ok
										handle: systemResult.handle
										library: library
										path: systemPath
									}
								}
								_ -> {
									{
										type: :error
										error: 'LoadLibraryW failed'
										library: library
										detail: result.detail
										fallback: systemResult.detail
									}
								}
							}
						}
					}
				}
			}
		}
		_ -> {
			{
				type: :ok
				handle: cached
				library: library
			}
		}
	}
	_ -> _platformError('loadDll')
}

fn resolveInLoaded(library, symbol) if isWindows?() {
	true -> {
		loaded := loadDll(library)
		if loaded.type {
			:ok -> {
				proc := procAddress(loaded.handle, symbol)
				if sys.ok?(proc) & proc.r1 > 0 {
					true -> {
						{
							type: :ok
							proc: proc.r1
							handle: loaded.handle
							library: library
							symbol: symbol
						}
					}
					_ -> {
						{
							type: :error
							error: 'Could not resolve procedure'
							library: library
							symbol: symbol
							detail: proc
						}
					}
				}
			}
			_ -> loaded
		}
	}
	_ -> _platformError('resolveInLoaded')
}

fn callIn(library, symbol, args...) if isWindows?() {
	true -> {
		resolved := resolveInLoaded(library, symbol)
		if resolved.type {
			:ok -> sys.call(resolved.proc, args...)
			_ -> resolved
		}
	}
	_ -> _platformError('callIn')
}

fn user32(symbol, args...) if isWindows?() {
	true -> callIn(User32, symbol, args...)
	_ -> _platformError('user32')
}


// gui-shader.oak — CPU shader engine (facade)
//
// This module re-exports all sub-modules and provides the core shader
// runtime: Shader constructor, registry, renderers, and pixel buffer.
//
// This module is imported by GUI.oak and re-exported with `sh` prefixed names.
// It can also be imported directly: import('gui-shader')
//
// Sub-modules:
//   gui-shader-math     — constants, math, easing, 2D/3D vectors
//   gui-shader-color    — packed RGB, HSL/HSV, blending
//   gui-shader-noise    — hashing, noise2D, fbm
//   gui-shader-sdf      — SDF primitives, patterns
//   gui-shader-codegen  — GLSL/HLSL codegen, WebGL, offline compilation

{
	default: default
	each: each
	filter: filter
} := import('std')

_draw := import('gui-draw')

// Import sub-modules
m := import('gui-shader-math')
col := import('gui-shader-color')
noise := import('gui-shader-noise')
sdf := import('gui-shader-sdf')
codegen := import('gui-shader-codegen')


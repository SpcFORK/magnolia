// =========================================================================
// @ Shader Registry
// =========================================================================

_registry := []

fn _registerShader(shader) {
	_registry <- _registry << shader
	?
}

fn unregisterShader(shader) {
	_registry <- _registry |> with filter() fn(s) s != shader
}

fn clearAll() with each(_registry) fn(s) {
	if s != ? -> {
		reset(s)
		s._frameCount <- 0
	}
}

fn destroyAll() {
	with each(_registry) fn(s) {
		if s != ? -> {
			reset(s)
			s._frameCount <- 0
		}
	}
	_registry <- []
}

fn registeredCount() len(_registry)

// =========================================================================
// @ Shader Core
// =========================================================================

cs Shader(fragment?, opts?) {
	fragment := fragment?
	draw := opts?.draw
	resolution := opts?.resolution |> default(4)
	uniforms := opts?.uniforms |> default({})
	_startNano := nanotime()
	_pausedAt := ?
	_pauseAccum := 0
	_frameStart := 0
	_dt := 0
	_frameCount := 0
	_registered := _registerShader(Self)
}

fn elapsed(shader) {
	now := nanotime()
	active := if shader._pausedAt != ? {
		true -> shader._pausedAt - shader._startNano - shader._pauseAccum
		_ -> now - shader._startNano - shader._pauseAccum
	}
	float(active) / 1000000000.0
}

fn pause(shader) if shader._pausedAt = ? -> {
	shader._pausedAt <- nanotime()
}

fn resume(shader) if shader._pausedAt != ? -> {
	shader._pauseAccum <- shader._pauseAccum + (nanotime() - shader._pausedAt)
	shader._pausedAt <- ?
}

fn reset(shader) if shader != ? -> {
	shader._startNano <- nanotime()
	shader._pauseAccum <- 0
	shader._pausedAt <- ?
}

fn setUniform(shader, key, value) shader.uniforms.(key) <- value
fn getUniform(shader, key) shader.uniforms.(key)
fn setResolution(shader, res) shader.resolution <- res

fn beginFrame(shader) {
	shader._frameStart <- nanotime()
}

fn endFrame(shader) {
	now := nanotime()
	shader._dt <- float(now - shader._frameStart) / 1000000000.0
	shader._frameCount <- shader._frameCount + 1
	shader._dt
}

fn dt(shader) shader._dt
fn isRunning(shader) shader._pausedAt = ?
fn frameCount(shader) shader._frameCount

// =========================================================================
// @ Render Dispatch
// =========================================================================

fn render(window, shader, x, y, w, h) {
	t := elapsed(shader)
	if shader.draw != ? -> shader.draw(window, x, y, w, h, t, shader.uniforms)
	if shader.draw = ? -> renderShaderLines(window, shader, x, y, w, h)
}

// =========================================================================
// @ Multi-Pass Composition
// =========================================================================

cs ShaderPass(shader, x, y, w, h) {
	shader := shader
	x := x
	y := y
	w := w
	h := h
}

fn composePasses(window, passes) {
	with each(passes) fn(pass) {
		render(window, pass.shader, pass.x, pass.y, pass.w, pass.h)
	}
}

// =========================================================================
// @ Renderers
// =========================================================================

fn renderShader(window, shader, x, y, w, h) {
	t := elapsed(shader)
	res := shader.resolution
	u := shader.uniforms

	fn _row(ry) if ry >= h {
		true -> ?
		_ -> {
			fn _col(rx) if rx >= w {
				true -> ?
				_ -> {
					c := shader.fragment(rx, ry, w, h, t, u)
					if c != ? -> _draw.fillRect(window, x + rx, y + ry, res, res, c)
					_col(rx + res)
				}
			}
			_col(0)
			_row(ry + res)
		}
	}
	_row(0)
}

fn renderShaderLines(window, shader, x, y, w, h) {
	t := elapsed(shader)
	res := shader.resolution
	u := shader.uniforms

	fn _row(ry) if ry >= h {
		true -> ?
		_ -> {
			c := shader.fragment(int(w / 2), ry, w, h, t, u)
			if c != ? -> _draw.drawLine(window, x, y + ry, x + w, y + ry, c)
			_row(ry + res)
		}
	}
	_row(0)
}

fn renderGradientBands(window, gradientFn, x, y, w, h, time, bands?) {
	n := if bands? { ? -> 16, _ -> bands? }
	bandH := int(h / n)
	if bandH < 1 -> bandH <- 1
	fn _band(i) if i >= n {
		true -> ?
		_ -> {
			by := i * bandH
			bh := if i = n - 1 { true -> h - by, _ -> bandH }
			c := gradientFn(by + int(bh / 2), h, time)
			if c != ? -> _draw.fillRect(window, x, y + by, w, bh, c)
			_band(i + 1)
		}
	}
	_band(0)
}

fn renderGradient(window, gradientFn, x, y, w, h, time) renderGradientBands(window, gradientFn, x, y, w, h, time, 16)

fn renderHorizontalBands(window, gradientFn, x, y, w, h, time, bands?) {
	n := if bands? { ? -> 16, _ -> bands? }
	bandW := int(w / n)
	if bandW < 1 -> bandW <- 1
	fn _band(i) if i >= n {
		true -> ?
		_ -> {
			bx := i * bandW
			bw := if i = n - 1 { true -> w - bx, _ -> bandW }
			c := gradientFn(bx + int(bw / 2), w, time)
			if c != ? -> _draw.fillRect(window, x + bx, y, bw, h, c)
			_band(i + 1)
		}
	}
	_band(0)
}

fn renderColumns(window, columns, ox, oy, h) {
	with each(columns) fn(col_) {
		tailY := col_.headY - col_.length
		if tailY < 0 -> {
			_draw.drawLine(window, ox + col_.x, oy + 0, ox + col_.x, oy + col_.headY, col_.color)
			_draw.drawLine(window, ox + col_.x, oy + h + tailY, ox + col_.x, oy + h, col_.color)
		}
		if tailY >= 0 -> {
			_draw.drawLine(window, ox + col_.x, oy + tailY, ox + col_.x, oy + col_.headY, col_.color)
		}
	}
}

fn updateColumns(columns, h, t, rate?) {
	fh := float(h)
	r := if rate? { ? -> 40.0, _ -> rate? }
	with each(columns) fn(col_) {
		col_.headY <- int(fract(col_.phase + t * col_.speed / fh * r) * fh)
	}
}

// =========================================================================
// @ Pixel Buffer
// =========================================================================

fn createBuffer(w, h) { width: w, height: h, data: {} }

fn clearBuffer(buf, color?) {
	c := if color? { ? -> 0, _ -> color? }
	total := buf.width * buf.height
	fn _clear(i) if i < total -> {
		buf.data.(i) <- c
		_clear(i + 1)
	}
	_clear(0)
}

fn setPixel(buf, x, y, color) if {
	x < 0 -> ?
	y < 0 -> ?
	x >= buf.width -> ?
	y >= buf.height -> ?
	_ -> buf.data.(y * buf.width + x) <- color
}

fn getPixel(buf, x, y) if {
	x < 0 -> 0
	y < 0 -> 0
	x >= buf.width -> 0
	y >= buf.height -> 0
	_ -> {
		v := buf.data.(y * buf.width + x)
		if v { ? -> 0, _ -> v }
	}
}

fn renderBuffer(window, buf, ox, oy) {
	fn _row(ry) if ry < buf.height -> {
		fn _col(rx) if rx < buf.width -> {
			c := getPixel(buf, rx, ry)
			if c != 0 -> _draw.fillRect(window, ox + rx, oy + ry, 1, 1, c)
			_col(rx + 1)
		}
		_col(0)
		_row(ry + 1)
	}
	_row(0)
}

fn renderShaderToBuffer(buf, shader) {
	t := elapsed(shader)
	w := buf.width
	h := buf.height
	u := shader.uniforms
	res := shader.resolution
	fn _row(ry) if ry < h -> {
		fn _col(rx) if rx < w -> {
			c := shader.fragment(rx, ry, w, h, t, u)
			if c != ? -> setPixel(buf, rx, ry, c)
			_col(rx + res)
		}
		_col(0)
		_row(ry + res)
	}
	_row(0)
}

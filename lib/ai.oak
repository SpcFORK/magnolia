fn initXavier(n, fanIn, fanOut, seed) _initXavier(n, fanIn, fanOut, seed)
fn initHe(n, fanIn, seed) _initHe(n, fanIn, seed)
fn numericalGradient(f, x, h) _numericalGradient(f, x, h)
fn numericalGradientVec(f, x, h) _numericalGradientVec(f, x, h)


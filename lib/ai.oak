// ============================================================================
// Re-exports: Vector Operations & Distances (ai-vec)
// ============================================================================

fn dotProduct(v1, v2) _dotProduct(v1, v2)
fn magnitude(v) _magnitude(v)
fn normalize(v) _normalize(v)
fn cosineSimilarity(v1, v2) _cosineSimilarity(v1, v2)

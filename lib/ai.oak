fn lrConstant(baseLr, step) _lrConstant(baseLr, step)
fn lrStepDecay(baseLr, step, stepSize, decayFactor) _lrStepDecay(baseLr, step, stepSize, decayFactor)
fn lrExponentialDecay(baseLr, step, decayRate) _lrExponentialDecay(baseLr, step, decayRate)

// libai implements AI and machine learning utilities following 2026 standards.
//
// This library provides functions for working with embeddings, neural networks,
// language models, and other AI/ML operations. It includes vector operations,
// normalization, attention mechanisms, and data preprocessing utilities designed
// for modern AI applications including LLMs, vision models, and multimodal systems.
//
// This is the hub module that re-exports from sub-modules:
//   ai-vec     — Vector operations, distances, normalization, statistics
//   ai-linalg  — Matrix operations and linear algebra
//   ai-nn      — Activations, loss functions, attention, masks
//   ai-optim   — Optimizers, LR scheduling, regularization, gradients
//   ai-data    — Preprocessing, batching, encoding, metrics, training
//   ai-text    — Tokenization and text processing
//   ai-ml      — KNN, clustering, dimensionality reduction, ensembles, time series
//   ai-decode  — Sampling, decoding, retrieval, probability distributions

// ============================================================================
// Sub-module imports
// ============================================================================

{
	dotProduct: _dotProduct
	magnitude: _magnitude
	normalize: _normalize
	cosineSimilarity: _cosineSimilarity
	euclideanDistance: _euclideanDistance
	manhattanDistance: _manhattanDistance
	chebyshevDistance: _chebyshevDistance
	hammingDistance: _hammingDistance
	vecAdd: _vecAdd
	vecSub: _vecSub
	vecScale: _vecScale
	minMaxScale: _minMaxScale
	zScore: _zScore
	mean: _mean
	variance: _variance
	stddev: _stddev
	entropy: _entropy
	ema: _ema
	pbatchNormalize: _pbatchNormalize
	pbatchCosineSimilarity: _pbatchCosineSimilarity
	cosineSimilarityMatrix: _cosineSimilarityMatrix
	distanceMatrix: _distanceMatrix
} := import('ai-vec')

{
	matZeros: _matZeros
	matIdentity: _matIdentity
	matTranspose: _matTranspose
	matMul: _matMul
	matAdd: _matAdd
	matScale: _matScale
	matDiag: _matDiag
	matFromDiag: _matFromDiag
	matTrace: _matTrace
	outerProduct: _outerProduct
	matHadamard: _matHadamard
	matFlatten: _matFlatten
	matReshape: _matReshape
	pmatMul: _pmatMul
} := import('ai-linalg')

{
	relu: _relu
	leakyRelu: _leakyRelu
	sigmoid: _sigmoid
	tanh: _tanh
	gelu: _gelu
	swish: _swish
	mish: _mish
	elu: _elu
	selu: _selu
	softmax: _softmax
	pbatchSoftmax: _pbatchSoftmax
	crossEntropyLoss: _crossEntropyLoss
	meanSquaredError: _meanSquaredError
	meanAbsoluteError: _meanAbsoluteError
	huberLoss: _huberLoss
	pbatchMeanSquaredError: _pbatchMeanSquaredError
	scaledDotProductAttention: _scaledDotProductAttention
	multiHeadAttention: _multiHeadAttention
	positionalEncoding: _positionalEncoding
	ropeEmbedding: _ropeEmbedding
	layerNorm: _layerNorm
	causalMask: _causalMask
	paddingMask: _paddingMask
	applyMask: _applyMask
} := import('ai-nn')

{
	dropout: _dropout
	l2Regularization: _l2Regularization
	l1Regularization: _l1Regularization
	elasticNetRegularization: _elasticNetRegularization
	sgdStep: _sgdStep
	sgdMomentumStep: _sgdMomentumStep
	clipGradNorm: _clipGradNorm
	adamStep: _adamStep
	rmspropStep: _rmspropStep
	lrConstant: _lrConstant
	lrStepDecay: _lrStepDecay
	lrExponentialDecay: _lrExponentialDecay
	lrCosineAnnealing: _lrCosineAnnealing
	lrWarmupLinear: _lrWarmupLinear
	lrCosineWarmRestarts: _lrCosineWarmRestarts
	initUniform: _initUniform
	initXavier: _initXavier
	initHe: _initHe
	numericalGradient: _numericalGradient
	numericalGradientVec: _numericalGradientVec
} := import('ai-optim')

{
	ModelConfig: _ModelConfig
	oneHotEncode: _oneHotEncode
	oneHotDecode: _oneHotDecode
	shuffleIndices: _shuffleIndices
	trainTestSplit: _trainTestSplit
	kFoldIndices: _kFoldIndices
	batchify: _batchify
	padSequence: _padSequence
	labelEncode: _labelEncode
	polynomialFeatures: _polynomialFeatures
	accuracy: _accuracy
	precisionScore: _precisionScore
	recallScore: _recallScore
	f1Score: _f1Score
	confusionMatrix: _confusionMatrix
	rSquared: _rSquared
	addNoise: _addNoise
	mixup: _mixup
	quantize: _quantize
	dequantize: _dequantize
	trainLoop: _trainLoop
} := import('ai-data')

{
	tokenizeSimple: _tokenizeSimple
	tokenCount: _tokenCount
	nGrams: _nGrams
	bagOfWords: _bagOfWords
	tfidf: _tfidf
} := import('ai-text')

{
	knn: _knn
	kMeansStep: _kMeansStep
	kMeans: _kMeans

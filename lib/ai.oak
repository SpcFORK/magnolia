// ============================================================================
// Re-exports: Optimization (ai-optim)
// ============================================================================

fn dropout(v, rate, seed) _dropout(v, rate, seed)
fn l2Regularization(weights, lambda) _l2Regularization(weights, lambda)
fn l1Regularization(weights, lambda) _l1Regularization(weights, lambda)

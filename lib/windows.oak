fn apiSetDll(contract) {
	if contract {
		? -> ApiSetPrefix
		_ -> if len(contract) >= 4 {
			true -> if contract.(len(contract) - 4) = '.dll' {
				true -> contract
				_ -> ApiSetPrefix + contract + '.dll'
			}
			_ -> ApiSetPrefix + contract + '.dll'
		}
	}
}

fn apiSet(contract, symbol, args...) if isWindows?() {
	true -> callIn(apiSetDll(contract), symbol, args...)
	_ -> _platformError('apiSet')
}


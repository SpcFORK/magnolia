// Returns a best-effort user-readable message from a Win32 error code.
fn formatMessage(errorCode) if isWindows?() {
	true -> {
		wideChars := 1024
		buf := bits(_zeros(wideChars * 2, []))
		res := kernel32(
			'FormatMessageW'
			FORMAT_MESSAGE_FROM_SYSTEM | FORMAT_MESSAGE_IGNORE_INSERTS
			?
			errorCode
			0
			addr(buf)
			wideChars
			?
		)
		if sys.ok?(res) & res.r1 > 0 {
			true -> _utf16leToString(memread(addr(buf), res.r1 * 2))
			_ -> ?
		}
	}
	_ -> ?
}

fn lastErrorMessage() if isWindows?() {
	true -> formatMessage(getLastError())
	_ -> ?
}


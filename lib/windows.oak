fn _utf16leToString(buf) {
	bytes := bits(buf)
	fn sub(i, out) if i + 1 < len(bytes) {
		true -> {
			cp := bytes.(i) + bytes.(i + 1) * 256
			if cp = 0 {
				true -> out
				_ -> sub(i + 2, out + char(cp))
			}
		}
		_ -> out
	}
	sub(0, '')
}

// UTF-16 helper for Win32 *W APIs.
fn wstr(s) utf16(s)

// Null-terminated ANSI helper for APIs like GetProcAddress.
fn cstr(s) s + char(0)

fn makeWord(low, high) low + high * 256

fn isWindows? ___runtime_sys_info().os = 'windows'

fn _platformError(apiName) {
	{
		type: :error
		error: apiName + ' is only available on Windows'
	}
}

fn resolve(symbol) if isWindows?() {
	true -> sys.resolve(Kernel32, symbol)
	_ -> _platformError('resolve')
}

fn resolveIn(library, symbol) if isWindows?() {
	true -> sys.resolve(library, symbol)
	_ -> _platformError('resolveIn')
}

fn call(target, args...) if isWindows?() {
	true -> sys.call(target, args...)
	_ -> _platformError('call')
}

fn kernel32(symbol, args...) if isWindows?() {
	true -> sys.resolveAndCall(Kernel32, symbol, args...)
	_ -> _platformError('kernel32')
}

fn ntdll(symbol, args...) if isWindows?() {
	true -> sys.resolveAndCall(Ntdll, symbol, args...)
	_ -> _platformError('ntdll')
}

// Alias for low-level Native API dispatch through ntdll.dll exports.
fn ntNative(symbol, args...) if isWindows?() {
	true -> ntdll(symbol, args...)
	_ -> _platformError('ntNative')
}

fn psapi(symbol, args...) if isWindows?() {
	true -> sys.resolveAndCall(Psapi, symbol, args...)
	_ -> _platformError('psapi')
}

fn _normalizeHandleResult(result, apiName, library) if sys.ok?(result) & result.r1 > 0 {
	true -> {
		{
			type: :ok
			handle: result.r1
			library: library
		}
	}
	_ -> {
		{
			type: :error
			error: apiName + ' failed'
			library: library
			detail: result
		}
	}
}

// Loads a DLL and memoizes its module handle for later symbol resolution.
fn loadDll(library) if isWindows?() {
	true -> if cached := _loadedLibraries.(library) {
		? -> {
			alreadyLoaded := moduleHandle(library)
			if sys.ok?(alreadyLoaded) & alreadyLoaded.r1 > 0 {
				true -> {
					_loadedLibraries.(library) := alreadyLoaded.r1
					{
						type: :ok
						handle: alreadyLoaded.r1
						library: library
					}
				}
				_ -> {
					loaded := loadLibrary(library)
					result := _normalizeHandleResult(loaded, 'LoadLibraryW', library)
					if result.type {
						:ok -> {
							_loadedLibraries.(library) := result.handle
							result
						}
						_ -> {
							systemPath := 'C:\\Windows\\System32\\' + library
							loadedSystem := loadLibrary(systemPath)
							systemResult := _normalizeHandleResult(loadedSystem, 'LoadLibraryW', systemPath)
							if systemResult.type {
								:ok -> {
									_loadedLibraries.(library) := systemResult.handle
									{
										type: :ok
										handle: systemResult.handle
										library: library
										path: systemPath
									}
								}
								_ -> {
									{
										type: :error
										error: 'LoadLibraryW failed'
										library: library
										detail: result.detail
										fallback: systemResult.detail
									}
								}
							}
						}
					}
				}
			}
		}
		_ -> {
			{
				type: :ok
				handle: cached
				library: library
			}
		}
	}
	_ -> _platformError('loadDll')
}

// Resolves a symbol from a loaded DLL, loading the DLL on-demand.
fn resolveInLoaded(library, symbol) if isWindows?() {
	true -> {
		loaded := loadDll(library)
		if loaded.type {
			:ok -> {
				proc := procAddress(loaded.handle, symbol)
				if sys.ok?(proc) & proc.r1 > 0 {
					true -> {
						{
							type: :ok
							proc: proc.r1
							handle: loaded.handle
							library: library
							symbol: symbol
						}
					}
					_ -> {
						{
							type: :error
							error: 'Could not resolve procedure'
							library: library
							symbol: symbol
							detail: proc
						}
					}
				}
			}
			_ -> loaded
		}
	}
	_ -> _platformError('resolveInLoaded')
}

// Calls a symbol from a DLL, loading and resolving it on-demand.
fn callIn(library, symbol, args...) if isWindows?() {
	true -> {
		resolved := resolveInLoaded(library, symbol)
		if resolved.type {
			:ok -> sys.call(resolved.proc, args...)
			_ -> resolved
		}
	}
	_ -> _platformError('callIn')
}


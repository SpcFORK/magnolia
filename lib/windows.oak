fn _ptrRead(address) if ptrSize() {
	8 -> readU64(address)
	_ -> readU32(address)
}

fn _bytesToString(raw) {
	bytes := bits(raw)
	fn sub(i, out) if i < len(bytes) {
		true -> sub(i + 1, out + char(bytes.(i)))
		_ -> out
	}
	sub(0, '')
}

// Builds a sockaddr_in-compatible structure and returns {buffer, ptr, len}.
fn sockaddrIn(ipv4, port) if isWindows?() {
	true -> {
		portNet := callValueOrZero(htons(port))
		ipNet := callValueOrZero(inetAddr(ipv4))
		buf := bits([
			AF_INET % 256
			int(AF_INET / 256)
			portNet % 256
			int(portNet / 256)
			ipNet % 256
			int(ipNet / 256) % 256
			int(ipNet / 65536) % 256
			int(ipNet / 16777216) % 256
			0
			0
			0
			0
			0
			0
			0
			0
		])
		{type: :ok, buffer: buf, ptr: addr(buf), len: 16}
	}
	_ -> _platformError('sockaddrIn')
}

fn _internetReadAll(hInternetFile, chunkBuf, bytesReadBuf, chunkSize, out) {
	res := internetReadFile(hInternetFile, addr(chunkBuf), chunkSize, addr(bytesReadBuf))
	if callOk?(res) {
		true -> {
			readCount := readU32(addr(bytesReadBuf))
			if readCount {
				0 -> {type: :ok, body: out}
				_ -> _internetReadAll(
					hInternetFile
					chunkBuf
					bytesReadBuf
					chunkSize
					out + _bytesToString(memread(addr(chunkBuf), readCount))
				)
			}
		}
		_ -> {type: :error, error: 'InternetReadFile failed', detail: res}
	}
}

// Downloads URL content via WinINet and returns {type: :ok, body: <string>}.
fn internetSimpleGet(url, agent, chunkSize) if isWindows?() {
	true -> {
		chunkSize := if chunkSize {
			? -> 4096
			_ -> chunkSize
		}
		agent := if agent {
			? -> 'Magnolia/Windows'
			_ -> agent
		}

		hInternet := internetOpen(agent, INTERNET_OPEN_TYPE_PRECONFIG, ?, ?, 0)
		if callOk?(hInternet) {
			true -> {
				hFile := internetOpenUrl(hInternet.r1, url, ?, 0, 0, 0)
				if callOk?(hFile) {
					true -> {
						chunkBuf := bits(_zeros(chunkSize, []))
						bytesReadBuf := bits([0, 0, 0, 0])
						result := _internetReadAll(hFile.r1, chunkBuf, bytesReadBuf, chunkSize, '')
						internetCloseHandle(hFile.r1)
						internetCloseHandle(hInternet.r1)
						result
					}
					_ -> {
						internetCloseHandle(hInternet.r1)
						{type: :error, error: 'InternetOpenUrlW failed', detail: hFile}
					}
				}
			}
			_ -> {type: :error, error: 'InternetOpenW failed', detail: hInternet}
		}
	}
	_ -> _platformError('internetSimpleGet')
}

fn regReadDword(rootKey, subKey, valueName) if isWindows?() {
	true -> {
		keyBuf := bits(_zeros(ptrSize(), []))
		openResult := regOpenKeyEx(rootKey, subKey, 0, KEY_READ, addr(keyBuf))
		if statusOk?(openResult) {
			true -> {
				hKey := _ptrRead(addr(keyBuf))
				typeBuf := bits([0, 0, 0, 0])
				valueBuf := bits([0, 0, 0, 0])
				sizeBuf := bits([4, 0, 0, 0])
				queryResult := regQueryValueEx(hKey, valueName, 0, addr(typeBuf), addr(valueBuf), addr(sizeBuf))
				regCloseKey(hKey)
				if statusOk?(queryResult) {
					true -> {type: :ok, value: readU32(addr(valueBuf)), regType: readU32(addr(typeBuf))}
					_ -> {type: :error, error: 'RegQueryValueExW failed', detail: queryResult}
				}
			}
			_ -> {type: :error, error: 'RegOpenKeyExW failed', detail: openResult}
		}
	}
	_ -> _platformError('regReadDword')
}

fn regWriteDword(rootKey, subKey, valueName, value) if isWindows?() {
	true -> {
		keyBuf := bits(_zeros(ptrSize(), []))
		dispositionBuf := bits([0, 0, 0, 0])
		createResult := regCreateKeyEx(rootKey, subKey, 0, ?, 0, KEY_READ | KEY_WRITE, 0, addr(keyBuf), addr(dispositionBuf))
		if statusOk?(createResult) {
			true -> {
				hKey := _ptrRead(addr(keyBuf))
				valueBuf := bits([0, 0, 0, 0])
				writeU32(addr(valueBuf), value)
				setResult := regSetValueEx(hKey, valueName, 0, REG_DWORD, addr(valueBuf), 4)
				regCloseKey(hKey)
				if statusOk?(setResult) {
					true -> {type: :ok, value: value}
					_ -> {type: :error, error: 'RegSetValueExW failed', detail: setResult}
				}
			}
			_ -> {type: :error, error: 'RegCreateKeyExW failed', detail: createResult}
		}
	}
	_ -> _platformError('regWriteDword')
}

fn regReadString(rootKey, subKey, valueName) if isWindows?() {
	true -> {
		keyBuf := bits(_zeros(ptrSize(), []))
		openResult := regOpenKeyEx(rootKey, subKey, 0, KEY_READ, addr(keyBuf))
		if statusOk?(openResult) {
			true -> {
				hKey := _ptrRead(addr(keyBuf))
				typeBuf := bits([0, 0, 0, 0])
				sizeBuf := bits([0, 0, 0, 0])
				sizeResult := regQueryValueEx(hKey, valueName, 0, addr(typeBuf), ?, addr(sizeBuf))
				if statusOk?(sizeResult) {
					true -> {
						size := readU32(addr(sizeBuf))
						valueBuf := bits(_zeros(size, []))
						queryResult := regQueryValueEx(hKey, valueName, 0, addr(typeBuf), addr(valueBuf), addr(sizeBuf))
						regCloseKey(hKey)
						if statusOk?(queryResult) {
							true -> {
								{
									type: :ok
									value: _utf16leToString(memread(addr(valueBuf), readU32(addr(sizeBuf))))
									regType: readU32(addr(typeBuf))
								}
							}
							_ -> {type: :error, error: 'RegQueryValueExW failed', detail: queryResult}
						}
					}
					_ -> {
						regCloseKey(hKey)
						{type: :error, error: 'RegQueryValueExW size query failed', detail: sizeResult}
					}
				}
			}
			_ -> {type: :error, error: 'RegOpenKeyExW failed', detail: openResult}
		}
	}
	_ -> _platformError('regReadString')
}

fn regWriteString(rootKey, subKey, valueName, value) if isWindows?() {
	true -> {
		keyBuf := bits(_zeros(ptrSize(), []))
		dispositionBuf := bits([0, 0, 0, 0])
		createResult := regCreateKeyEx(rootKey, subKey, 0, ?, 0, KEY_READ | KEY_WRITE, 0, addr(keyBuf), addr(dispositionBuf))
		if statusOk?(createResult) {
			true -> {
				hKey := _ptrRead(addr(keyBuf))
				valueWide := wstr(value)
				setResult := regSetValueEx(hKey, valueName, 0, REG_SZ, addr(valueWide), len(valueWide))
				regCloseKey(hKey)
				if statusOk?(setResult) {
					true -> {type: :ok, value: value}
					_ -> {type: :error, error: 'RegSetValueExW failed', detail: setResult}
				}
			}
			_ -> {type: :error, error: 'RegCreateKeyExW failed', detail: createResult}
		}
	}
	_ -> _platformError('regWriteString')
}


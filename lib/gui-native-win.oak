						if !_default(opts.resizable, true) -> {
							style := windows.getWindowLongPtr(state.hwnd, windows.GWL_STYLE)
							if style.type = :ok {
								true -> {
									lockedStyle := style.r1 & ~(windows.WS_THICKFRAME | windows.WS_MAXIMIZEBOX)
									windows.setWindowLongPtr(state.hwnd, windows.GWL_STYLE, lockedStyle)
									windows.user32(
										'SetWindowPos'
										state.hwnd
										0
										0
										0
										0
										0
										SWP_NOMOVE | SWP_NOSIZE | SWP_NOZORDER | SWP_NOACTIVATE | SWP_FRAMECHANGED
									)
									state.locked <- true
								}
							}
						}
						// GPU layer init is deferred to the first beginFrame call so that
						// Vulkan/OpenGL ICD calls happen after the Win32 message pump has
						// started.  _ensureLayerInit guards this work so it only runs once.
						state._layerReady <- false
						state._layerInitInProgress <- false

								// now start D3D9 probe in background.
								true -> _startD3d9ProbeAsync(state)
								_ -> state._dllProbeDone <- true
							}
						}
						state._createTimings <- {
							parseOpts: _t1 - _t0
							probes: _t2 - _t1
							layerSelect: _t2b - _t2
							icons: _t4 - _t2b
							registerClass: _t5 - _t4
							createWindow: _t6 - _t5
							stateInit: _cwsTime() - _t6
						}
						state
					}
					_ -> {
						_releaseWindowThreadLock()
						_err('CreateWindowExW returned null handle', hwnd)
					}
				}
				_ -> {
					_releaseWindowThreadLock()
					_err('CreateWindowExW call failed', hwnd)
				}
			}
		}
	}
}

// Asynchronous window creation — runs createWindowState in a background goroutine.
// Returns a future object immediately: {type: :future, done: false, result: ?}
// The caller can poll future.done or pass the future to awaitWindow() which blocks
// until the result is ready.
fn createWindowAsync(title, width, height, options, className, frameMs, updateOnDispatch) {
	future := {
		type: :future
		done: false
		result: ?
		_t0: _cwsTime()
	}
	go(fn(f) {
		f.result <- createWindowState(title, width, height, options, className, frameMs, updateOnDispatch)
		f.done <- true
	}, future)
	future
}

// Blocks the current thread until an async window future completes.
// Returns the window state (same as createWindowState would return).
fn awaitWindow(future) {
	fn _spin(f) if f.done {
		true -> f.result
		_ -> {
			wait(0.001)
			_spin(f)
		}
	}
	result := _spin(future)
	if result.type = :ok -> {
		result._asyncWaitMs <- int((_cwsTime() - future._t0) * 1000.0)
	}
	result
}

_showTimings := ?
fn showWindow(window) {
	_st0 := nanotime()
	windows.showWindow(window.hwnd, windows.SW_SHOW)
	_st1 := nanotime()
	// Skip UpdateWindow when the frame loop will paint immediately.
	// This saves ~500ms at startup with no visual difference.
	if !_default(window.skipUpdateWindow, false) -> {
		windows.updateWindow(window.hwnd)
	}
	_st2 := nanotime()
	guiNativeWinIcons.applyWindowIcons(window.hwnd, window.icons)
	_st3 := nanotime()
	window.visible <- true
	_showTimings <- {
		showWindow: (_st1 - _st0) / 1000000000.0
		updateWindow: (_st2 - _st1) / 1000000000.0
		applyIcons: (_st3 - _st2) / 1000000000.0
		total: (_st3 - _st0) / 1000000000.0
	}
	window
}

fn getShowTimings() _showTimings

fn hideWindow(window) {
	windows.showWindow(window.hwnd, windows.SW_HIDE)
	window.visible <- false
	window
}

fn moveWindow(window, x, y) {
	windows.user32(
		'SetWindowPos'
		window.hwnd
		0
		x
		y
		0
		0
		SWP_NOSIZE | SWP_NOZORDER | SWP_NOACTIVATE
	)
	window.x <- x
	window.y <- y
	window
}

fn resizeWindow(window, width, height) {
	windows.user32(
		'SetWindowPos'
		window.hwnd
		0
		window.x
		window.y
		width
		height
		SWP_NOZORDER | SWP_NOACTIVATE
	)
	window.width <- width
	window.height <- height
	window
}

fn setFullscreen(window, enabled) {
	if enabled {
		true -> {
			if !window.fullscreen {
				true -> {
					window.restoreBounds <- {
						x: window.x
						y: window.y
						width: window.width
						height: window.height
					}
					style := windows.getWindowLongPtr(window.hwnd, windows.GWL_STYLE)
					if style.type = :ok {
						true -> window.preFullscreenStyle <- style.r1
					}
				}
			}
			currentStyle := _default(window.preFullscreenStyle, 0)
			borderlessStyle := (currentStyle & ~(windows.WS_OVERLAPPEDWINDOW)) | windows.WS_POPUP | windows.WS_VISIBLE
			windows.setWindowLongPtr(window.hwnd, windows.GWL_STYLE, borderlessStyle)
			screenW := windows.getSystemMetrics(windows.SM_CXSCREEN)
			screenH := windows.getSystemMetrics(windows.SM_CYSCREEN)
			sw := if screenW.type = :ok { true -> screenW.r1, _ -> window.width }
			sh := if screenH.type = :ok { true -> screenH.r1, _ -> window.height }
			windows.user32(
				'SetWindowPos'
				window.hwnd
				windows.HWND_TOP
				0
				0
				sw
				sh
				SWP_NOACTIVATE | SWP_NOOWNERZORDER | SWP_FRAMECHANGED
			)
			window.width <- sw
			window.height <- sh
			window.x <- 0
			window.y <- 0
			window.fullscreen <- true
			window.visible <- true
			window
		}
		_ -> {
			if window.preFullscreenStyle != ? {
				true -> windows.setWindowLongPtr(window.hwnd, windows.GWL_STYLE, window.preFullscreenStyle)
			}
			if window.restoreBounds != ? {
				true -> {
					resizeWindow(window, window.restoreBounds.width, window.restoreBounds.height)
					moveWindow(window, window.restoreBounds.x, window.restoreBounds.y)
				}
			}
			windows.user32(
				'SetWindowPos'
				window.hwnd
				0
				0
				0
				0
				0
				SWP_NOMOVE | SWP_NOSIZE | SWP_NOZORDER | SWP_NOACTIVATE | SWP_FRAMECHANGED
			)
			window.preFullscreenStyle <- ?
			window.fullscreen <- false
			window
		}
	}
}

fn lockResize(window, locked) {
	style := windows.getWindowLongPtr(window.hwnd, windows.GWL_STYLE)
	if style.type = :ok {
		true -> {
			currentStyle := style.r1
			newStyle := if locked {
				true -> currentStyle & ~(windows.WS_THICKFRAME | windows.WS_MAXIMIZEBOX)
				_ -> currentStyle | windows.WS_THICKFRAME | windows.WS_MAXIMIZEBOX
			}
			windows.setWindowLongPtr(window.hwnd, windows.GWL_STYLE, newStyle)
			windows.user32(
				'SetWindowPos'
				window.hwnd
				0
				0
				0
				0
				0
				SWP_NOMOVE | SWP_NOSIZE | SWP_NOZORDER | SWP_NOACTIVATE | SWP_FRAMECHANGED
			)
			window.locked <- if locked { true -> true, _ -> false }
			window
		}
		_ -> _err('GetWindowLongPtrW failed', style)
	}
}

fn setTitle(window, title) {
	windows.setWindowText(window.hwnd, title)
	window.title <- title
	window
}

fn _ensureLayerInitForFrame(window) if !_default(window._layerReady, false) {
	true -> _ensureLayerInit(window)
	_ -> { type: :ok, alreadyReady: true }
}

fn beginFrame(window) {
	// Initialize GPU layers on first frame, after the Win32 message pump has
	// started.  This prevents Vulkan/OpenGL ICD calls from blocking or
	// deadlocking during window creation.
	_ensureLayerInitForFrame(window)
	target := windows.getDC(window.hwnd)
	if windows.callOk?(target) & target.r1 > 0 {
		true -> guiNativeWinFrame.prepareBeginFrameTarget(window, target.r1)
		_ -> _err('GetDC failed', target)
	}
}

fn endFrame(window) if window.frameHdc > 0 & window.frameTargetHdc > 0 {
	true -> {
		presentedViaOpenGL := guiNativeWinPresent.presentFrameViaOpenGL(window)
		presentedViaDdraw := guiNativeWinDdraw.presentFrameViaDdraw(window)
		presentedViaVulkan := false
		// Vulkan present: swapchain-based present is not yet wired.
		// window.vulkanInstance is kept alive for future draw calls and swapchain setup.
		if !presentedViaOpenGL.presented & !presentedViaDdraw.presented & !presentedViaVulkan {
			true -> guiNativeWinPresent.presentFrameViaGdi(window)
		}
		windows.gdi32('GdiFlush')
		windows.releaseDC(window.hwnd, window.frameTargetHdc)
		window.frameTargetHdc <- 0
		0
	}
	_ -> 0
}

fn poll(window) {
	// Ensure deferred GPU/layer bootstrap finishes before dispatching messages.
	init := _ensureLayerInitForFrame(window)
	if init.type = :busy {
		true -> { type: :idle, detail: init }
		_ -> if windows.windowAlive?(window.hwnd) {
			true -> guiNativeWinPoll.pollWindowMessages(window)
			_ -> {
				window.closed <- true
				{ type: :closed }
			}
		}
	}
}

fn close(window) {
	if _default(window._nativeClosed, false) {
		true -> 0
		_ -> {
			endFrame(window)
			guiNativeWinClose.cleanupFrameBuffers(window)
			guiNativeWinDdraw.releasePrimarySurface(window)
			guiNativeWinClose.cleanupOpenGL(window)
			guiNativeWinClose.cleanupVulkan(window)
			if windows.windowAlive?(window.hwnd) {
				true -> windows.destroyWindow(window.hwnd)
			}
			window.closed <- true
			window._nativeClosed <- true
			if _default(window._threadLockHeld, false) {
				true -> {
					window._threadLockHeld <- false
					_releaseWindowThreadLock()
				}
			}
			0
		}
	}
}

// libimage is a facade that re-exports all image format libraries.
//
// Usage:
//   img := import('image')
//   img.bmp.bmp(w, h, pixels)
//   img.ico.ico(w, h, pixels)
//   img.ppm.ppm(w, h, pixels)
//   img.tga.tga(w, h, pixels)
//   img.qoi.qoi(w, h, pixels, channels)
//
// Or import individual formats directly:
//   { bmp: bmp } := import('image-bmp')

bmp := import('image-bmp')
ico := import('image-ico')
ppm := import('image-ppm')
tga := import('image-tga')
qoi := import('image-qoi')

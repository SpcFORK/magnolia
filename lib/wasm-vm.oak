	BUILTIN_VALUES: BUILTIN_VALUES
	BUILTIN_SLICE: BUILTIN_SLICE
	BUILTIN_APPEND: BUILTIN_APPEND
	BUILTIN_WAIT: BUILTIN_WAIT
	BUILTIN_EXIT: BUILTIN_EXIT

	// Type tags
	TAG_NULL: TAG_NULL
	TAG_EMPTY: TAG_EMPTY
	TAG_INT: TAG_INT
	TAG_FLOAT: TAG_FLOAT
	TAG_BOOL: TAG_BOOL
	TAG_STRING: TAG_STRING
	TAG_ATOM: TAG_ATOM
	TAG_LIST: TAG_LIST
	TAG_OBJECT: TAG_OBJECT
	TAG_FUNCTION: TAG_FUNCTION

	// Compiler API
	createCompiler: createCompiler
	compileProgram: compileProgram
	compileNode: compileNode

	// Serialization
	serializeBytecodeToString: serializeBytecodeToString
	serializeConstantPool: serializeConstantPool
	serializeFunctionTable: serializeFunctionTable
	disassemble: disassemble
}

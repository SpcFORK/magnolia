	OP_SCOPE_POP: OP_SCOPE_POP
	OP_CALL_SPREAD: OP_CALL_SPREAD
	NUM_OPCODES: NUM_OPCODES

	// Built-in indices
	BUILTIN_PRINT: BUILTIN_PRINT
	BUILTIN_LEN: BUILTIN_LEN
	BUILTIN_TYPE: BUILTIN_TYPE
	BUILTIN_STRING: BUILTIN_STRING
	BUILTIN_INT: BUILTIN_INT
	BUILTIN_FLOAT: BUILTIN_FLOAT
	BUILTIN_CODEPOINT: BUILTIN_CODEPOINT
	BUILTIN_CHAR: BUILTIN_CHAR

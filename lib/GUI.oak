// --- Anti-aliased drawing primitives ---
// These use software sub-pixel blending for smooth edges on all backends.
// bgColor is the background color used for blending (default: black).
fn drawLineAA(window, x1, y1, x2, y2, color, bgColor) guiAA.drawLineAA(_depsLine, window, x1, y1, x2, y2, color, bgColor)
fn drawCircleFilledAA(window, cx, cy, radius, color, bgColor) guiAA.drawCircleFilledAA(_depsLine, window, cx, cy, radius, color, bgColor)
fn drawCircleOutlineAA(window, cx, cy, radius, color, bgColor) guiAA.drawCircleOutlineAA(_depsLine, window, cx, cy, radius, color, bgColor)
fn drawEllipseFilledAA(window, cx, cy, rx, ry, color, bgColor) guiAA.drawEllipseFilledAA(_depsLine, window, cx, cy, rx, ry, color, bgColor)
fn drawRoundedRectFilledAA(window, x, y, w, h, radius, color, bgColor) guiAA.drawRoundedRectFilledAA(_depsLine, window, x, y, w, h, radius, color, bgColor)
fn drawTriangleFilledAA(window, p0, p1, p2, color, bgColor) guiAA.drawTriangleFilledAA(_depsLine, window, p0, p1, p2, color, bgColor)

// --- Unified draw() API ---
// Single entry point for all drawing — pass an options object describing
// shape, geometry, color, fill, AA, lighting, line style, etc.
// See docs/gui-draw-ops.md for the full reference.
//
// The _drawOpsDeps object is populated lazily after all facade functions are
// defined (see _initDrawOpsDeps below).  Forward-declared here so the closure
// captures the mutable binding.
_drawOpsDeps := ?

fn _initDrawOpsDeps() {
	_drawOpsDeps <- {
		// Core platform
		drawLine: drawLine
		drawLinesBatch: drawLinesBatch
		fillRect: fillRect
		drawText: drawText
		rgb: rgb
		// 2D shapes
		drawRect2D: drawRect2D
		drawCircle2D: drawCircle2D
		drawPolyline2D: drawPolyline2D
		drawPolygon2D: drawPolygon2D
		drawEllipse2D: drawEllipse2D
		drawArc2D: drawArc2D
		drawTriangle2D: drawTriangle2D
		drawRoundedRect2D: drawRoundedRect2D
		drawStar2D: drawStar2D
		drawBezier2D: drawBezier2D
		drawRing2D: drawRing2D
		drawCross2D: drawCross2D
		drawDiamond2D: drawDiamond2D
		drawArrow2D: drawArrow2D
		drawCapsule2D: drawCapsule2D
		drawSector2D: drawSector2D
		drawRegularPolygon2D: drawRegularPolygon2D
		drawSpiral2D: drawSpiral2D
		drawGrid2D: drawGrid2D
		drawThickLine2D: drawThickLine2D
		drawDashedLine2D: drawDashedLine2D
		// AA
		drawLineAA: drawLineAA
		drawCircleFilledAA: drawCircleFilledAA
		drawCircleOutlineAA: drawCircleOutlineAA
		drawEllipseFilledAA: drawEllipseFilledAA
		drawRoundedRectFilledAA: drawRoundedRectFilledAA
		drawTriangleFilledAA: drawTriangleFilledAA
		// 3D (populated after mesh functions are defined; backfilled below)
		drawMeshSolid: drawMeshSolid
		drawMeshLit: drawMeshLit
		drawMeshWireframe: drawMeshWireframe
	}
}

fn draw(window, op) {
	if _drawOpsDeps = ? -> _initDrawOpsDeps()
	guiDrawOps.draw(_drawOpsDeps, window, op)
}

fn drawBatch(window, ops) {
	if _drawOpsDeps = ? -> _initDrawOpsDeps()
	guiDrawOps.drawBatch(_drawOpsDeps, window, ops)
}

fn CubeMesh(size) {
	hs := _default(size, 2) / 2
	{
		vertices: [
			Vec3(-hs, -hs, -hs)
			Vec3(hs, -hs, -hs)
			Vec3(hs, hs, -hs)
			Vec3(-hs, hs, -hs)
			Vec3(-hs, -hs, hs)
			Vec3(hs, -hs, hs)
			Vec3(hs, hs, hs)
			Vec3(-hs, hs, hs)
		]
		edges: [
			[0, 1]
			[1, 2]
			[2, 3]
			[3, 0]
			[4, 5]
			[5, 6]
			[6, 7]
			[7, 4]
			[0, 4]
			[1, 5]
			[2, 6]
			[3, 7]
		]
		faces: [
			[0, 3, 2, 1]
			[4, 5, 6, 7]
			[0, 1, 5, 4]
			[2, 3, 7, 6]
			[1, 2, 6, 5]
			[0, 4, 7, 3]
		]
		faceColors: [
			rgb(250, 94, 94)
			rgb(250, 186, 86)
			rgb(124, 238, 120)
			rgb(94, 188, 252)
			rgb(188, 126, 255)
			rgb(255, 128, 214)
		]
	}
}

fn drawTriangleFilled(window, p0, p1, p2, color) {
	guiRaster.drawTriangleFilled(_depsLine, window, p0, p1, p2, color)
}

// Shared deps for 3D mesh drawing — avoids per-call object allocation.
_depsMesh := {
	drawLine: drawLine
	transformVertices: _transformVertices
	projectPoint: _projectPoint
	rgb: rgb
	Vec3: Vec3
}

_depsMeshWire := {
	drawLine: drawLine
	transformVertices: _transformVertices
	projectPoint: _projectPoint
}

_depsRgb := { rgb: rgb }

fn drawMeshSolid(window, mesh, transform, camera, color, light, borderColor) {
	guiRaster.drawMeshSolid(_depsMesh, window, mesh, transform, camera, color, light, borderColor)
}

fn drawMeshLit(window, mesh, transform, camera, color, scene, material, borderColor) {
	guiRaster.drawMeshLit(_depsMesh, window, mesh, transform, camera, color, scene, material, borderColor)
}


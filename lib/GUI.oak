fn poll(window) if window.type {
	:ok -> if window.backend {
		:windows -> guiNativeWin.poll(window)
		:linux -> guiNativeLinux.poll(window)
		:web -> if window.closed {
			true -> { type: :closed }
			_ -> { type: :idle }
		}
		_ -> _err('Unknown window backend', window)
	}
	_ -> window
}

fn _frameIntervalNt(window) guiLoop.frameIntervalNt(window)

fn _frameMaxDtNt(window) guiLoop.frameMaxDtNt(window)

fn _markUrgentFrameIfResizeDispatch(window, step) guiLoop.markUrgentFrameIfResizeDispatch(window, step)

fn _maybeRunFrame(window, onFrame, force) guiLoop.maybeRunFrame(window, onFrame, force, _publish)

fn _sleepUntilNextFrame(window) guiLoop.sleepUntilNextFrame(window)

fn run(window, onEvent, onFrame) if window.type {
	:ok -> {
		if !_default(window._runStarted, false) -> {
			window._runStarted <- true
			_publish(window, :runStart, {
				type: :runStart
			})
			if _default(window.visible, false) {
				true -> _maybeRunFrame(window, onFrame, true)
			}
		}
		step := poll(window)
		if step.type {
			:dispatch -> {
				guiEvents._cacheDispatchContext(window)
				_markUrgentFrameIfResizeDispatch(window, step)
				_publish(window, :dispatch, step)
				if onEvent {
					? -> ?
					_ -> onEvent(window, step)
				}
				guiEvents._clearDispatchContext(window)
				// Render when frame is due. updateOnDispatch forces a frame on
				// every dispatch; otherwise only the timer-scheduled frame runs.
				_maybeRunFrame(window, onFrame, _default(window.updateOnDispatch, false))
				run(window, onEvent, onFrame)
			}
			:idle -> {
				if guiEvents.listenerCount(window, :idle) > 0 -> _publish(window, :idle, step)
				_sleepUntilNextFrame(window)
				_maybeRunFrame(window, onFrame, false)
				if window.backend = :web {
					true -> 0
					_ -> run(window, onEvent, onFrame)
				}
			}
			:closed -> {
				if window.backend = :windows {
					true -> close(window)
					_ -> {
						_publish(window, :closed, step)
						0
					}
				}
			}
			_ -> step
		}
	}
	_ -> window
}

fn close(window) if window.type {
	:ok -> if _default(window._nativeClosed, false) {
		true -> 0
		_ -> {
			_publish(window, :closing, {
				type: :closing
			})
			guiDraw.releaseResources(window)
			result := if window.backend {
				:windows -> guiNativeWin.close(window)
				:linux -> guiNativeLinux.close(window)
				:web -> {
					window.closed <- true
					window._nativeClosed <- true
					0
				}
				_ -> _err('Unknown window backend', window)
			}
			window._nativeClosed <- true
			_publish(window, :closed, {
				type: :closed
			})
			result
		}
	}
	_ -> 0
}


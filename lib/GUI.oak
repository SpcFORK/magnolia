fn setCanvasTransparentColor(canvas, color) guiCanvas.setTransparentColor(canvas, color)
fn destroyCanvas(canvas) guiCanvas.destroy(canvas)
fn destroyAllCanvases(window) guiCanvas.destroyAll(window)
fn isCanvas?(obj) guiCanvas.isCanvas?(obj)
fn canvases(window) guiCanvas.canvases(window)
fn canvasCount(window) guiCanvas.canvasCount(window)
fn canvasAt(window, px, py) guiCanvas.canvasAt(window, px, py)
fn canvasHitTest?(canvas, px, py) guiCanvas.hitTest?(canvas, px, py)
fn canvasToLocal(canvas, px, py) guiCanvas.toLocal(canvas, px, py)

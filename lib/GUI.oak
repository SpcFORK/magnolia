// ─── Virtual / design resolution ────────────────────────────────────────────
// Set a fixed logical resolution.  All drawing happens in design coords;
// the back-buffer is allocated at the logical size and scaled to the
// physical window at present time.
//   options.scaleMode   – 'fit' | 'fill' | 'stretch'  (default 'fit')
//   options.pixelPerfect – true rounds 'fit' scale to integer multiples
fn setDesignResolution(window, logicalWidth, logicalHeight, options) guiResolution.setDesignResolution(window, logicalWidth, logicalHeight, options)
fn clearDesignResolution(window) guiResolution.clearDesignResolution(window)

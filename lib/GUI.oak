guiGraph := import('gui-graph')
guiForm := import('gui-form')
guiLoop := import('gui-loop')
guiShader := import('gui-shader')
guiFonts := import('gui-fonts')
guiVideo := import('gui-video')
guiResolution := import('gui-resolution')
guiCanvas := import('gui-canvas')
guiClipboard := import('gui-clipboard')
guiFiledrop := import('gui-filedrop')
guiDialogs := import('gui-dialogs')
guiMenus := import('gui-menus')
guiTheme := import('gui-theme')
guiSystray := import('gui-systray')
_guiImportT4 := nanotime()

// Module-import timing exposed for diagnostics.
// All values in seconds (float).
_importTimings := {
	platform: (_guiImportT1 - _guiImportT0) / 1000000000.0
	render: (_guiImportT2 - _guiImportT1) / 1000000000.0
	backend: (_guiImportT3 - _guiImportT2) / 1000000000.0
	ui: (_guiImportT4 - _guiImportT3) / 1000000000.0
	total: (_guiImportT4 - _guiImportT0) / 1000000000.0
}

fn getImportTimings() _importTimings

fn backend() if ___runtime_sys_info().os {
	'windows' -> :windows
	'linux' -> :linux
	'js' -> :web
	'web' -> :web
	'browser' -> :web
	'wasm' -> :web
	_ -> :unknown
}

fn isWindows?() backend() = :windows
fn isLinux?() backend() = :linux
fn isWeb?() backend() = :web

{ _default: _default, _err: _err } := import('gui-common')


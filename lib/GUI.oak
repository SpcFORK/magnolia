// Shared deps objects for 2D drawing — avoids per-call object allocation.
_depsLine := { drawLine: drawLine }
_depsLineBatch := { drawLine: drawLine, drawLinesBatch: drawLinesBatch }
_depsLineRect := { drawLine: drawLine, fillRect: fillRect }
_depsLineEllipse := { drawLine: drawLine, fillEllipse: guiDraw.fillEllipse }
_depsLinePoly := { drawLine: drawLine, fillPolygon: guiDraw.fillPolygon }
_depsLineBatchPoly := { drawLine: drawLine, drawLinesBatch: drawLinesBatch, fillPolygon: guiDraw.fillPolygon }
_depsLineRectRounded := { drawLine: drawLine, fillRect: fillRect, fillRoundedRect: guiDraw.fillRoundedRect }
_depsLineRectEllipse := { drawLine: drawLine, fillRect: fillRect, fillEllipse: guiDraw.fillEllipse }

fn drawRect2D(window, x, y, width, height, color, filled, borderColor) gui2d.drawRect2D(_depsLineRect, window, x, y, width, height, color, filled, borderColor)
fn drawCircle2D(window, cx, cy, radius, color, filled, borderColor) gui2d.drawCircle2D(_depsLineEllipse, window, cx, cy, radius, color, filled, borderColor)
fn drawPolyline2D(window, points, color, closed) gui2d.drawPolyline2D(_depsLine, window, points, color, closed)
fn drawPolygon2D(window, points, color, filled, borderColor) gui2d.drawPolygon2D(_depsLinePoly, window, points, color, filled, borderColor)
fn drawGrid2D(window, spacing, color, originX, originY) gui2d.drawGrid2D(_depsLineBatch, window, spacing, color, originX, originY)
fn drawEllipse2D(window, cx, cy, rx, ry, color, filled, borderColor) gui2d.drawEllipse2D(_depsLineEllipse, window, cx, cy, rx, ry, color, filled, borderColor)
fn drawArc2D(window, cx, cy, radius, startAngle, endAngle, color) gui2d.drawArc2D(_depsLineBatch, window, cx, cy, radius, startAngle, endAngle, color)
fn drawTriangle2D(window, x1, y1, x2, y2, x3, y3, color, filled, borderColor) gui2d.drawTriangle2D(_depsLinePoly, window, x1, y1, x2, y2, x3, y3, color, filled, borderColor)
fn drawRoundedRect2D(window, x, y, width, height, radius, color, filled, borderColor) gui2d.drawRoundedRect2D(_depsLineRectRounded, window, x, y, width, height, radius, color, filled, borderColor)
fn drawStar2D(window, cx, cy, outerR, innerR, points, color, filled, borderColor) gui2d.drawStar2D(_depsLinePoly, window, cx, cy, outerR, innerR, points, color, filled, borderColor)
fn drawBezier2D(window, points, color, steps) gui2d.drawBezier2D(_depsLineBatch, window, points, color, steps)
fn drawRing2D(window, cx, cy, outerR, innerR, color) gui2d.drawRing2D(_depsLineBatch, window, cx, cy, outerR, innerR, color)
fn drawCross2D(window, cx, cy, size, thickness, color, filled) gui2d.drawCross2D(_depsLineRect, window, cx, cy, size, thickness, color, filled)

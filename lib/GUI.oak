// ─── Virtual / design resolution ────────────────────────────────────────────
// Set a fixed logical resolution.  All drawing happens in design coords;
// the back-buffer is allocated at the logical size and scaled to the
// physical window at present time.
//   options.scaleMode   – 'fit' | 'fill' | 'stretch'  (default 'fit')
//   options.pixelPerfect – true rounds 'fit' scale to integer multiples
fn setDesignResolution(window, logicalWidth, logicalHeight, options) guiResolution.setDesignResolution(window, logicalWidth, logicalHeight, options)
fn clearDesignResolution(window) guiResolution.clearDesignResolution(window)
fn hasDesignResolution?(window) guiResolution.hasDesignResolution?(window)
fn designWidth(window) guiResolution.designWidth(window)
fn designHeight(window) guiResolution.designHeight(window)
fn physicalWidth(window) guiResolution.physicalWidth(window)
fn physicalHeight(window) guiResolution.physicalHeight(window)
fn resolutionScaleX(window) guiResolution.scaleX(window)
fn resolutionScaleY(window) guiResolution.scaleY(window)
fn resolutionOffsetX(window) guiResolution.offsetX(window)
fn resolutionOffsetY(window) guiResolution.offsetY(window)
fn physicalToLogical(window, px, py) guiResolution.physicalToLogical(window, px, py)
fn logicalToPhysical(window, lx, ly) guiResolution.logicalToPhysical(window, lx, ly)

fn createCanvas(window, id, options) guiWeb.createCanvas(window, id, options)

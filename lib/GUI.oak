// libGUI provides a simple cross-platform window middleware for Magnolia.
//
// Backends:
// - Windows: Win32 via lib/windows
// - Linux: X11 via lib/linux
// - Web/JS runtimes: logical no-op window state for portability

_guiImportT0 := nanotime()
std := import('std')
windows := import('windows')
linux := import('linux')
_guiImportT1 := nanotime()
guiMesh := import('gui-mesh')
guiRender := import('gui-render')
gui3dmath := import('gui-3dmath')
gui2d := import('gui-2d')
guiRaster := import('gui-raster')
guiLighting := import('gui-lighting')
_guiImportT2 := nanotime()
guiWeb := import('gui-web')
guiNativeWin := import('gui-native-win')
guiNativeLinux := import('gui-native-linux')
_guiImportT3 := nanotime()
guiDraw := import('gui-draw')
guiColor := import('gui-color')
guiEvents := import('gui-events')
guiGraph := import('gui-graph')
guiForm := import('gui-form')
guiLoop := import('gui-loop')
guiShader := import('gui-shader')
guiFonts := import('gui-fonts')
guiVideo := import('gui-video')
_guiImportT4 := nanotime()

// Module-import timing exposed for diagnostics.
// All values in seconds (float).
_importTimings := {
	platform: (_guiImportT1 - _guiImportT0) / 1000000000.0
	render: (_guiImportT2 - _guiImportT1) / 1000000000.0
	backend: (_guiImportT3 - _guiImportT2) / 1000000000.0
	ui: (_guiImportT4 - _guiImportT3) / 1000000000.0
	total: (_guiImportT4 - _guiImportT0) / 1000000000.0
}

fn getImportTimings() _importTimings

fn backend() if ___runtime_sys_info().os {
	'windows' -> :windows
	'linux' -> :linux
	'js' -> :web
	'web' -> :web
	'browser' -> :web
	'wasm' -> :web
	_ -> :unknown
}

fn isWindows?() backend() = :windows
fn isLinux?() backend() = :linux
fn isWeb?() backend() = :web

{ _default: _default, _err: _err } := import('gui-common')


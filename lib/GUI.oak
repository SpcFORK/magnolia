fn shaderIsRunning(shader) guiShader.isRunning(shader)
fn shaderFrameCount(shader) guiShader.frameCount(shader)
fn shaderRegisteredCount() guiShader.registeredCount()
fn shaderUnregisterShader(shader) guiShader.unregisterShader(shader)
fn shaderClearAll() guiShader.clearAll()
fn shaderDestroyAll() guiShader.destroyAll()

// --- Render
fn shaderRender(window, shader, x, y, w, h) guiShader.render(window, shader, x, y, w, h)
fn shaderRenderShader(window, shader, x, y, w, h) guiShader.renderShader(window, shader, x, y, w, h)
fn shaderRenderShaderLines(window, shader, x, y, w, h) guiShader.renderShaderLines(window, shader, x, y, w, h)
fn shaderRenderGradientBands(window, gradientFn, x, y, w, h, time, bands?) guiShader.renderGradientBands(window, gradientFn, x, y, w, h, time, bands?)
fn shaderRenderGradient(window, gradientFn, x, y, w, h, time) guiShader.renderGradient(window, gradientFn, x, y, w, h, time)
fn shaderRenderHorizontalBands(window, gradientFn, x, y, w, h, time, bands?) guiShader.renderHorizontalBands(window, gradientFn, x, y, w, h, time, bands?)
fn shaderRenderColumns(window, columns, ox, oy, h) guiShader.renderColumns(window, columns, ox, oy, h)
fn shaderUpdateColumns(columns, h, t, rate?) guiShader.updateColumns(columns, h, t, rate?)

// --- Multi-pass
fn ShaderPass(shader, x, y, w, h) guiShader.ShaderPass(shader, x, y, w, h)
fn shaderComposePasses(window, passes) guiShader.composePasses(window, passes)

// --- Pixel buffer
fn shaderCreateBuffer(w, h) guiShader.createBuffer(w, h)
fn shaderClearBuffer(buf, color?) guiShader.clearBuffer(buf, color?)
fn shaderSetPixel(buf, x, y, color) guiShader.setPixel(buf, x, y, color)
fn shaderGetPixel(buf, x, y) guiShader.getPixel(buf, x, y)
fn shaderRenderBuffer(window, buf, ox, oy) guiShader.renderBuffer(window, buf, ox, oy)
fn shaderRenderShaderToBuffer(buf, shader) guiShader.renderShaderToBuffer(buf, shader)

// =========================================================================
// Re-export: gui-fonts (cross-platform font management)
// =========================================================================

// Font weight constants
fontFW_THIN       := guiFonts.FW_THIN
fontFW_EXTRALIGHT := guiFonts.FW_EXTRALIGHT
fontFW_LIGHT      := guiFonts.FW_LIGHT
fontFW_NORMAL     := guiFonts.FW_NORMAL
fontFW_MEDIUM     := guiFonts.FW_MEDIUM
fontFW_SEMIBOLD   := guiFonts.FW_SEMIBOLD
fontFW_BOLD       := guiFonts.FW_BOLD
fontFW_EXTRABOLD  := guiFonts.FW_EXTRABOLD
fontFW_HEAVY      := guiFonts.FW_HEAVY

fn defaultFontSpec() guiFonts.defaultFontSpec()
fn createFontFromSpec(spec) guiFonts.createFont(spec)
fn deleteFontFromSpec(fontResult) guiFonts.deleteFont(fontResult)
fn fontKey(spec) guiFonts.fontKey(spec)
fn cachedFont(windowOrDisplay, spec) guiFonts.cachedFont(windowOrDisplay, spec)
fn releaseCachedFonts(windowOrDisplay) guiFonts.releaseCachedFonts(windowOrDisplay)
fn measureTextEx(windowOrDisplay, spec, text) guiFonts.measureText(windowOrDisplay, spec, text)
fn selectFontEx(args) guiFonts.selectFont(args)
fn fontGetTextMetrics(hdc) guiFonts.getTextMetrics(hdc)
fn fontLineHeight(hdcOrFontStruct) guiFonts.fontLineHeight(hdcOrFontStruct)
fn buildXLFD(spec) guiFonts.buildXLFD(spec)

// =========================================================================
// Re-export: gui-video (video frame <-> GUI bridge)
// =========================================================================

// Format conversion
fn videoFrameToBuffer(frame) guiVideo.frameToBuffer(frame)
fn videoBufferToFrame(buf) guiVideo.bufferToFrame(buf)

// Rendering video frames
fn videoRenderFrame(window, frame, ox, oy) guiVideo.renderFrame({ fillRect: fillRect }, window, frame, ox, oy)
fn videoRenderFrameScaled(window, frame, ox, oy, scale) guiVideo.renderFrameScaled({ fillRect: fillRect }, window, frame, ox, oy, scale)

// Video effects on shader buffers
fn videoBufferGrayscale(buf) guiVideo.bufferGrayscale(buf)
fn videoBufferInvert(buf) guiVideo.bufferInvert(buf)
fn videoBufferThreshold(buf, t) guiVideo.bufferThreshold(buf, t)
fn videoBufferBlend(bufA, bufB, alpha) guiVideo.bufferBlend(bufA, bufB, alpha)
fn videoBufferDiff(bufA, bufB) guiVideo.bufferDiff(bufA, bufB)

// Capture and export
fn videoCaptureBuffer(buf) guiVideo.captureBuffer(buf)
fn videoFrameToBmpPixels(frame) guiVideo.frameToBmpPixels(frame)

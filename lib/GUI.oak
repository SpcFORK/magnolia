fn poll(window) if window.type {
	:ok -> if window.backend {
		:windows -> guiNativeWin.poll(window)
		:linux -> guiNativeLinux.poll(window)
		:web -> if window.closed {
			true -> {type: :closed}
			_ -> {type: :idle}
		}
		_ -> _err('Unknown window backend', window)
	}
	_ -> window
}

fn _frameIntervalNt(window) _default(window.frameMs, 16) * 1000000

fn _frameMaxDtNt(window) _default(window.maxFrameDtMs, 250) * 1000000

fn _markUrgentFrameIfResizeDispatch(window, step) {
	if window.backend = :windows & step.type = :dispatch {
		true -> {
			msgType := windows.readU32(addr(window.msgBuf) + MSG_OFF_TYPE)
			isResizeRelated :=
				(msgType = GUI_WM_SIZE) |
				(msgType = GUI_WM_PAINT) |
				(msgType = GUI_WM_ERASEBKGND) |
				(msgType = GUI_WM_SIZING) |
				(msgType = GUI_WM_WINDOWPOSCHANGED) |
				(msgType = GUI_WM_ENTERSIZEMOVE) |
				(msgType = GUI_WM_EXITSIZEMOVE)
			if isResizeRelated {
				true -> window._forceNextFrame <- true
			}
		}
	}
}

fn _maybeRunFrame(window, onFrame, force) {
	if onFrame {
		? -> ?
		_ -> {
			now := nanotime()
			next := _default(window._nextFrameNt, now)
			if window._nextFrameNt {
				? -> window._nextFrameNt <- next
			}
			forceNow := force | _default(window._forceNextFrame, false)
			if forceNow {
				true -> window._forceNextFrame <- false
			}
			due := forceNow | now >= next
			if due {
				true -> {
					last := _default(window._lastFrameNt, now)
					rawDt := now - last
					dtNs := if rawDt < 0 {
						true -> 0
						_ -> if rawDt > _frameMaxDtNt(window) {
							true -> _frameMaxDtNt(window)
							_ -> rawDt
						}
					}
					dt := float(dtNs) / 1000000000.0
					window._lastFrameNt <- now
					onFrame(window, dt)
					_publish(window, :frame, {
						type: :frame
						dt: dt
						timeNs: now
					})
					interval := _frameIntervalNt(window)
					now2 := nanotime()
					scheduledBase := if forceNow {
						true -> now2
						_ -> next
					}
					scheduled := scheduledBase + interval
					if scheduled < now2 - interval {
						true -> window._nextFrameNt <- now2 + interval
						_ -> window._nextFrameNt <- scheduled
					}
				}
			}
		}
	}
}

fn _sleepUntilNextFrame(window) {
	if _default(window._forceNextFrame, false) {
		true -> 0
		_ -> {
	now := nanotime()
	next := _default(window._nextFrameNt, now + _frameIntervalNt(window))
	remaining := next - now
	if remaining > 0 {
		true -> {
			sleepMs := int((remaining + 999999) / 1000000)
			if sleepMs < 1 -> sleepMs <- 1
			if window.backend {
				:windows -> windows.kernel32('Sleep', sleepMs)
				:linux -> guiNativeLinux.sleepFrame(sleepMs)
			}
		}
	}
		}
}
}

fn run(window, onEvent, onFrame) if window.type {
	:ok -> {
		if !_default(window._runStarted, false) -> {
			window._runStarted <- true
			_publish(window, :runStart, {
				type: :runStart
			})
		}
		step := poll(window)
		if step.type {
			:dispatch -> {
				_markUrgentFrameIfResizeDispatch(window, step)
				_publish(window, :dispatch, step)
				if onEvent {
					? -> ?
					_ -> onEvent(window, step)
				}
				if _default(window.updateOnDispatch, false) {
					true -> _maybeRunFrame(window, onFrame, false)
				}
				// Even without updateOnDispatch, render when due to prevent redraw starvation.
				_maybeRunFrame(window, onFrame, false)
				run(window, onEvent, onFrame)
			}
			:idle -> {
				_publish(window, :idle, step)
				_sleepUntilNextFrame(window)
				_maybeRunFrame(window, onFrame, false)
				if window.backend = :web {
					true -> 0
					_ -> run(window, onEvent, onFrame)
				}
			}
			:closed -> {
				_publish(window, :closed, step)
				0
			}
			_ -> step
		}
	}
	_ -> window
}

fn close(window) if window.type {
	:ok -> if window.closed {
		true -> 0
		_ -> {
			_publish(window, :closing, {
				type: :closing
			})
			result := if window.backend {
				:windows -> guiNativeWin.close(window)
				:linux -> guiNativeLinux.close(window)
				:web -> {
					window.closed <- true
					0
				}
				_ -> _err('Unknown window backend', window)
			}
			_publish(window, :closed, {
				type: :closed
			})
			result
		}
	}
	_ -> 0
}

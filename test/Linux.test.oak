linux := import('Linux')

fn run(t) {
	{
		'linux constants and helpers expose expected types' |> t.eq(
			{
				(type(linux.LibC) = :list) &
				(type(linux.LibDL) = :list) &
				(type(linux.LibX11) = :list) &
				(type(linux.PROT_READ) = :int) &
				(type(linux.MAP_PRIVATE) = :int) &
				(type(linux.O_RDONLY) = :int) &
				(type(linux.RTLD_NOW) = :int) &
				(type(linux.ExposureMask) = :int) &
				(type(linux.ClientMessage) = :int) &
				(type(linux.cstr('oak')) = :string) &
				(type(linux.loadDll) = :function) &
				(type(linux.resolveInLoaded) = :function) &
				(type(linux.callIn) = :function) &
				(type(linux.x11) = :function) &
				(type(linux.errno) = :function) &
				(type(linux.strerror) = :function) &
				(type(linux.allocPages) = :function) &
				(type(linux.openDefaultWindow) = :function) &
				(type(linux.runWindowLoop) = :function) &
				(type(linux.readU64) = :function) &
				(len(linux.cstr('oak')) = 4)
			}
			true
		)

		'linux typed memory helpers read and write little-endian integers safely' |> t.eq(
			{
				buf := bits([0, 0, 0, 0, 0, 0, 0, 0])
				p := addr(buf)
				linux.writeU32(p, 305419896) // 0x12345678
				linux.writeU64(p, 72623859790382856) // 0x0102030405060708
				[
					linux.readU32(p)
					linux.readU64(p)
				]
			}
			[84281096, 72623859790382856]
		)

		'linux wrapper basic behavior is OS-aware and safe' |> t.eq(
			{
				os := ___runtime_sys_info().os
				pidCall := linux.libc('getpid')
				errNo := linux.errno()
				errText := linux.strerror(2)
				if os {
					'linux' -> {
						linux.isLinux?() &
						((pidCall.type = :ok) | (pidCall.type = :success)) &
						(linux.currentProcessId() > 0) &
						(linux.parentProcessId() > 0) &
						(linux.pageSize() > 0) &
						(errNo >= 0) &
						(type(errText) = :string)
					}
					_ -> {
						(!linux.isLinux?()) &
						(pidCall.type = :error) &
						(linux.currentProcessId() = -1) &
						(linux.parentProcessId() = -1) &
						(linux.pageSize() = -1) &
						(errNo = -1) &
						(type(errText) = :null)
					}
				}
			}
			true
		)
	}
}

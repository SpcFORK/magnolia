syntax := import('syntax')
Virtual := import('Virtual')

fn run(t) {
	{
		'macro? identifies Macro wrappers' |> t.assert(
			syntax.macro?(syntax.Macro(fn(args) args.(0)))
		)

		'parseWithMacros expands nested macro calls' |> t.assert(
			{
				expanded := syntax.parseWithMacros('wrap(inc(2))', {
					inc: syntax.Macro(fn(args) {
						type: :binary
						op: :plus
						left: args.(0)
						right: {
							type: :int
							tok: args.(0).tok
							val: 1
						}
					})
					wrap: syntax.Macro(fn(args) {
						type: :list
						tok: args.(0).tok
						elems: args
					})
				})

				expanded.(0).type = :list &
					len(expanded.(0).elems) = 1 &
					expanded.(0).elems.(0).type = :binary &
					expanded.(0).elems.(0).left.val = 2 &
					expanded.(0).elems.(0).right.val = 1
			}
		)
	}

	{
		if ___runtime_go_version() = 'js' {
			true -> 'virtual context macros rewrite expression before eval (skipped in js runtime)' |> t.eq(true, true)
			_ -> {
				ctx := Virtual.createVirtualContext()

				ctx.defineMacro('twice', fn(call, expand) {
					value := expand(call.args.(0))
					{
						type: :binary
						op: :plus
						left: value
						right: value
					}
				})

				'virtual context macros rewrite expression before eval' |> t.eq(
					ctx.evalExpr('twice(4 + 1)')
					10
				)
			}
		}
	}
}

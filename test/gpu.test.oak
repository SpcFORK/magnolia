gpu := import('gpu')

fn run(t) {
	{
		'gpu backends() returns list' |> t.eq(
			type(gpu.backends())
			:list
		)

		'gpu cuda/opencl library lists are lists' |> t.eq(
			[type(gpu.cudaLibraries()), type(gpu.openclLibraries())]
			[:list, :list]
		)

		'gpu scan result has expected shape' |> t.eq(
			{
				result := gpu.scan()
				[type(result), result.0.name, result.1.name]
			}
			[:list, 'cuda', 'opencl']
		)

		'gpu resolve surfaces missing procedure as error object' |> t.eq(
			gpu.resolve('definitely-missing-oak-syscall.dll', 'DefinitelyMissingProc').type
			:error
		)

		'gpu call delegates to syscall result object' |> t.eq(
			gpu.call(-1).type
			:error
		)

		'gpu backend helpers return structured results' |> t.eq(
			[type(gpu.cuda('DefinitelyMissingProc').type), type(gpu.opencl('DefinitelyMissingProc').type)]
			[:atom, :atom]
		)
	}
}

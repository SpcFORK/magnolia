transpile := import('transpile')
contains? := import('std').contains?

fn Token(type, val) {
	type: type
	tok: { pos: [0, 1, 1], type: type, val: val }
	val: val
}

fn Int(val) Token(:int, val)

fn run(t) {
	transpile.clearTranspilers()
	transpile.configure({
		enabled?: true
		verbose?: false
	})

	{
		'createTranspiler + registerTranspiler applies visitor' |> t.eq(
			{
				transpile.clearTranspilers()
				transpile.registerTranspiler(
					transpile.createTranspiler(fn(node) if node.type {
						:int -> {
							node.val := node.val + 10
							node
						}
						_ -> node
					})
				)
				transpile.transpileNode(Int(2)).val
			}
			12
		)

		'non-function transpiler is ignored' |> t.eq(
			{
				transpile.clearTranspilers()
				transpile.registerTranspiler('not a function')
				transpile.transpileNode(Int(9)).val
			}
			9
		)

		'disabled transpilation leaves node unchanged' |> t.eq(
			{
				transpile.clearTranspilers()
				transpile.configure({ enabled?: false })
				transpile.registerTranspiler(fn(node) if node.type {
					:int -> {
						node.val := 100
						node
					}
					_ -> node
				})
				result := transpile.transpileNode(Int(5)).val
				transpile.configure({ enabled?: true })
				result
			}
			5
		)

		'multiple transpilers run in sequence' |> t.eq(
			{
				transpile.clearTranspilers()
				transpile.registerTranspiler(fn(node) if node.type {
					:int -> {
						node.val := node.val + 1
						node
					}
					_ -> node
				})
				transpile.registerTranspiler(fn(node) if node.type {
					:int -> {
						node.val := node.val * 3
						node
					}
					_ -> node
				})
				transpile.transpileNode(Int(4)).val
			}
			15
		)

		'verbose mode invokes configured logger' |> t.eq(
			{
				transpile.clearTranspilers()
				logMessages := []
				transpile.configure({
					verbose?: true
					log: fn(msg) logMessages << msg
				})
				transpile.registerTranspiler(fn(node) node)
				transpile.transpileNode(Int(1))
				transpile.configure({
					verbose?: false
					log: print
				})
				len(logMessages)
			}
			2
		)
	}

	{
		'optimizeConstants folds integer addition' |> t.eq(
			transpile.optimizeConstants({
				type: :binary
				op: :plus
				tok: Token(:plus, ?).tok
				left: Int(2)
				right: Int(3)
			})
			Int(5)
		)

		'optimizeConstants folds integer subtraction' |> t.eq(
			transpile.optimizeConstants({
				type: :binary
				op: :minus
				tok: Token(:minus, ?).tok
				left: Int(9)
				right: Int(4)
			})
			Int(5)
		)

		'optimizeConstants folds integer multiplication' |> t.eq(
			transpile.optimizeConstants({
				type: :binary
				op: :times
				tok: Token(:times, ?).tok
				left: Int(6)
				right: Int(7)
			})
			Int(42)
		)

		'optimizeConstants leaves unsupported operations untouched' |> t.eq(
			{
				node := {
					type: :binary
					op: :branchArrow
					tok: Token(:branchArrow, ?).tok
					left: Int(8)
					right: Int(2)
				}
				transpile.optimizeConstants(node)
			}
			{
				type: :binary
				op: :branchArrow
				tok: Token(:branchArrow, ?).tok
				left: Int(8)
				right: Int(2)
			}
		)

		'optimizeConstants folds integer division when exact' |> t.eq(
			transpile.optimizeConstants({
				type: :binary
				op: :divide
				tok: Token(:divide, ?).tok
				left: Int(8)
				right: Int(2)
			})
			Int(4)
		)

		'optimizeConstants keeps divide-by-zero unchanged' |> t.eq(
			{
				node := {
					type: :binary
					op: :divide
					tok: Token(:divide, ?).tok
					left: Int(8)
					right: Int(0)
				}
				transpile.optimizeConstants(node)
			}
			{
				type: :binary
				op: :divide
				tok: Token(:divide, ?).tok
				left: Int(8)
				right: Int(0)
			}
		)

		'optimizeConstants folds integer power' |> t.eq(
			transpile.optimizeConstants({
				type: :binary
				op: :power
				tok: Token(:times, ?).tok
				left: Int(2)
				right: Int(5)
			})
			Int(32)
		)

		'optimizeConstants folds integer bitwise and' |> t.eq(
			transpile.optimizeConstants({
				type: :binary
				op: :and
				tok: Token(:and, ?).tok
				left: Int(14)
				right: Int(11)
			})
			Int(10)
		)

		'optimizeConstants folds numeric comparisons' |> t.eq(
			transpile.optimizeConstants({
				type: :binary
				op: :geq
				tok: Token(:geq, ?).tok
				left: Int(6)
				right: Int(3)
			})
			Token(:bool, true)
		)
	}

	// --- New constant folding tests: unary, string, bool, equality, block ---

	{
		'optimizeConstants folds unary negate int' |> t.eq(
			transpile.optimizeConstants({
				type: :unary
				op: :minus
				tok: Token(:minus, ?).tok
				right: Int(42)
			}).val
			-42
		)

		'optimizeConstants folds unary negate float' |> t.eq(
			transpile.optimizeConstants({
				type: :unary
				op: :minus
				tok: Token(:minus, ?).tok
				right: Token(:float, 3.14)
			}).val
			-3.14
		)

		'optimizeConstants folds unary boolean not' |> t.eq(
			transpile.optimizeConstants({
				type: :unary
				op: :exclam
				tok: Token(:exclam, ?).tok
				right: Token(:bool, true)
			}).val
			false
		)

		'optimizeConstants folds string concatenation' |> t.eq(
			transpile.optimizeConstants({
				type: :binary
				op: :plus
				tok: Token(:plus, ?).tok
				left: Token(:string, 'hello ')
				right: Token(:string, 'world')
			}).val
			'hello world'
		)

		'optimizeConstants folds boolean or' |> t.eq(
			transpile.optimizeConstants({
				type: :binary
				op: :or
				tok: Token(:or, ?).tok
				left: Token(:bool, false)
				right: Token(:bool, true)
			}).val
			true
		)

		'optimizeConstants folds boolean and' |> t.eq(
			transpile.optimizeConstants({
				type: :binary
				op: :and
				tok: Token(:and, ?).tok
				left: Token(:bool, true)
				right: Token(:bool, false)
			}).val
			false
		)

		'optimizeConstants folds boolean xor' |> t.eq(
			transpile.optimizeConstants({
				type: :binary
				op: :xor
				tok: Token(:xor, ?).tok
				left: Token(:bool, true)
				right: Token(:bool, true)
			}).val
			false
		)

		'optimizeConstants folds equality on ints' |> t.eq(
			transpile.optimizeConstants({
				type: :binary
				op: :eq
				tok: Token(:eq, ?).tok
				left: Int(5)
				right: Int(5)
			}).val
			true
		)

		'optimizeConstants folds inequality on strings' |> t.eq(
			transpile.optimizeConstants({
				type: :binary
				op: :neq
				tok: Token(:neq, ?).tok
				left: Token(:string, 'a')
				right: Token(:string, 'b')
			}).val
			true
		)

		'optimizeConstants folds left shift' |> t.eq(
			transpile.optimizeConstants({
				type: :binary
				op: :pushArrow
				tok: Token(:pushArrow, ?).tok
				left: Int(4)
				right: Int(2)
			}).val
			16
		)

		'optimizeConstants folds right shift' |> t.eq(
			transpile.optimizeConstants({
				type: :binary
				op: :rshift
				tok: Token(:rshift, ?).tok
				left: Int(16)
				right: Int(2)
			}).val
			4
		)

		'optimizeConstants unwraps single-constant block' |> t.eq(
			transpile.optimizeConstants({
				type: :block
				exprs: [Int(42)]
				tok: Token(:leftBrace, ?).tok
			})
			Int(42)
		)

		'optimizeConstants preserves multi-expression block' |> t.eq(
			transpile.optimizeConstants({
				type: :block
				exprs: [Int(1), Int(2)]
				tok: Token(:leftBrace, ?).tok
			}).type
			:block
		)
	}

	{
		'removeDebugCalls drops direct debug calls' |> t.eq(
			len(
				transpile.removeDebugCalls({
					type: :block
					exprs: [
						{
							type: :fnCall
							function: { type: :identifier, val: 'debug', tok: Token(:identifier, 'debug').tok }
							args: []
							restArg: ?
							tok: Token(:leftParen, ?).tok
						}
						{
							type: :fnCall
							function: { type: :identifier, val: 'print', tok: Token(:identifier, 'print').tok }
							args: []
							restArg: ?
							tok: Token(:leftParen, ?).tok
						}
					]
					tok: Token(:leftBrace, ?).tok
				}).exprs
			)
			1
		)

		'removeDebugCalls keeps non-identifier call targets' |> t.eq(
			len(
				transpile.removeDebugCalls({
					type: :block
					exprs: [
						{
							type: :fnCall
							function: { type: :propertyAccess, left: Int(1), right: Int(2), tok: Token(:dot, ?).tok }
							args: []
							restArg: ?
							tok: Token(:leftParen, ?).tok
						}
					]
					tok: Token(:leftBrace, ?).tok
				}).exprs
			)
			1
		)
	}

	{
		'walkNode recursively visits nested nodes' |> t.eq(
			{
				visited := []
				node := {
					type: :function
					body: {
						type: :ifExpr
						cond: {
							type: :unary
							right: Int(1)
							tok: Token(:bang, ?).tok
						}
						branches: [
							{
								type: :ifBranch
								target: {
									type: :list
									elems: [Int(2)]
									tok: Token(:leftBracket, ?).tok
								}
								body: {
									type: :object
									entries: [{ key: Int(3), val: Int(4) }]
									tok: Token(:leftBrace, ?).tok
								}
								tok: Token(:arrow, ?).tok
							}
						]
						tok: Token(:ifKeyword, ?).tok
					}
					tok: Token(:fnKeyword, ?).tok
				}
				transpile.walkNode(node, fn(n) {
					visited << n.type
					n
				})
				[
					visited |> contains?(:function)
					visited |> contains?(:ifExpr)
					visited |> contains?(:ifBranch)
					visited |> contains?(:unary)
					visited |> contains?(:list)
					visited |> contains?(:object)
				]
			}
			[true, true, true, true, true, true]
		)

		'walkNode handles fnCall restArg and assignment/propertyAccess' |> t.eq(
			{
				seenTypes := []
				node := {
					type: :block
					exprs: [
						{
							type: :fnCall
							function: { type: :identifier, val: 'f', tok: Token(:identifier, 'f').tok }
							args: [
								{
									type: :assignment
									left: Int(1)
									right: {
										type: :propertyAccess
										left: Int(2)
										right: Int(3)
										tok: Token(:dot, ?).tok
									}
									tok: Token(:assign, ?).tok
								}
							]
							restArg: Int(4)
							tok: Token(:leftParen, ?).tok
						}
					]
					tok: Token(:leftBrace, ?).tok
				}
				transpile.walkNode(node, fn(n) {
					seenTypes << n.type
					n
				})
				[
					seenTypes |> contains?(:fnCall)
					seenTypes |> contains?(:assignment)
					seenTypes |> contains?(:propertyAccess)
				]
			}
			[true, true, true]
		)
	}

	transpile.clearTranspilers()
	transpile.configure({
		enabled?: true
		verbose?: false
		log: print
	})
}

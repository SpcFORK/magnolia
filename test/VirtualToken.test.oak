VirtualToken := import('VirtualToken')
Virtual := import('Virtual')

fn run(t) {
	{
		'at builds token positions' |> t.eq(
			VirtualToken.at(10, 2, 7)
			[10, 2, 7]
		)

		'Comma uses default position and null payload' |> t.eq(
			VirtualToken.Comma()
			{
				type: :comma
				val: ?
				pos: [0, 1, 1]
			}
		)

		'Identifier stores payload and custom position' |> t.eq(
			VirtualToken.Identifier('name', VirtualToken.at(4, 3, 9))
			{
				type: :identifier
				val: 'name'
				pos: [4, 3, 9]
			}
		)

		'NumberLiteral stores number payload text' |> t.eq(
			VirtualToken.NumberLiteral('2.5')
			{
				type: :numberLiteral
				val: '2.5'
				pos: [0, 1, 1]
			}
		)

		'Comment stores payload and preserves explicit position' |> t.eq(
			VirtualToken.Comment(' note', [8, 1, 3])
			{
				type: :comment
				val: ' note'
				pos: [8, 1, 3]
			}
		)

		'DeepEq token class maps to deepEq type' |> t.eq(
			VirtualToken.DeepEq([1, 1, 1]).type
			:deepEq
		)

		'BinaryNode creates complete AST node with tok metadata' |> t.eq(
			VirtualToken.BinaryNode(
				:plus
				VirtualToken.IntNode(2)
				VirtualToken.IntNode(3)
				VirtualToken.Plus(VirtualToken.at(12, 4, 8))
			)
			{
				type: :binary
				tok: {
					type: :plus
					val: ?
					pos: [12, 4, 8]
				}
				op: :plus
				left: { type: :int, tok: ?, val: 2 }
				right: { type: :int, tok: ?, val: 3 }
			}
		)

		'BlockNode and AssignmentNode can build a complete evaluable program' |> t.eq(
			{
				ctx := Virtual.createVirtualContext()
				program := VirtualToken.BlockNode([
					VirtualToken.AssignmentNode(
						VirtualToken.IdentifierNode('x', VirtualToken.Identifier('x'))
						VirtualToken.IntNode(9, VirtualToken.NumberLiteral('9'))
						VirtualToken.Assign()
					)
					VirtualToken.BinaryNode(
						:plus
						VirtualToken.IdentifierNode('x')
						VirtualToken.IntNode(1)
						VirtualToken.Plus()
					)
				])
				ctx.evalAst(program)
			}
			10
		)

		'BinaryAdd builds and evaluates without manual op wiring' |> t.eq(
			{
				ctx := Virtual.createVirtualContext()
				node := VirtualToken.BinaryAdd(
					VirtualToken.IntNode(7)
					VirtualToken.IntNode(8)
				)
				ctx.evalAst(node)
			}
			15
		)

		'UnaryNot and BinaryEq convenience nodes compose correctly' |> t.eq(
			{
				ctx := Virtual.createVirtualContext()
				node := VirtualToken.UnaryNot(
					VirtualToken.BinaryEq(
						VirtualToken.IntNode(2)
						VirtualToken.IntNode(3)
					)
				)
				ctx.evalAst(node)
			}
			true
		)
	}
}

pack := import('pack')

fn run(t) {
	'build args without include' |> t.eq(
		pack.buildArgs('main.oak', 'bundle.oak', ?)
		['build', '--entry', 'main.oak', '--output', 'bundle.oak']
	)
	'build args with include' |> t.eq(
		pack.buildArgs('main.oak', 'bundle.oak', 'dyn:./dyn')
		['build', '--entry', 'main.oak', '--output', 'bundle.oak', '--include', 'dyn:./dyn']
	)
	'pack exports run function' |> t.eq(type(pack.run), :function)
}

bitwise := import('bitwise')

fn run(t) {
	// integer bitwise operators
	{
		{
			and: and
			or: or
			xor: xor
			not: not
			shl: shl
			shr: shr
		} := bitwise

		'and()' |> t.eq(and(13, 11), 9)
		'or()' |> t.eq(or(13, 11), 15)
		'xor()' |> t.eq(xor(13, 11), 6)
		'not()' |> t.eq(not(10), -11)
		'shl()' |> t.eq(shl(3, 4), 48)
		'shr()' |> t.eq(shr(48, 4), 3)
	}

	// mask helpers
	{
		{
			hasAll?: hasAll?
			hasAny?: hasAny?
			set: set
			clear: clear
			toggle: toggle
			update: update
		} := bitwise

		value := 10
		mask := 6

		'hasAll? false' |> t.eq(hasAll?(value, mask), false)
		'hasAny? true' |> t.eq(hasAny?(value, mask), true)
		'set()' |> t.eq(set(value, mask), 14)
		'clear()' |> t.eq(clear(value, mask), 8)
		'toggle()' |> t.eq(toggle(value, mask), 12)
		'update(true)' |> t.eq(update(value, mask, true), 14)
		'update(false)' |> t.eq(update(value, mask, false), 8)
	}

	// pointer and memory helpers
	{
		{
			ptr: ptr
			null: null
			null?: null?
			addrOf: addrOf
			add: add
			sub: sub
			diff: diff
			read: read
			write: write
		} := bitwise

		'ptr() type' |> t.eq(type(ptr(0)), :pointer)
		'null() is null pointer' |> t.eq(null(), pointer(0))
		'null? true' |> t.eq(null?(null()), true)
		'null? false' |> t.eq(null?(ptr(5)), false)

		buf := bits([65, 66, 67, 68])
		base := addrOf(buf)

		'add/sub and diff' |> t.eq(diff(sub(add(base, 3), 1), base), 2)

		write(add(base, 1), [90, 89])
		'read/write memory' |> t.approx(bits(read(base, 4)), [65, 90, 89, 68])
	}
}
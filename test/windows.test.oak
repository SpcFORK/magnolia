windows := import('windows')

fn run(t) {
	{
		'windows constants and helpers expose expected types' |> t.eq(
			[
				type(windows.Kernel32)
				type(windows.Ntdll)
				type(windows.Psapi)
				type(windows.User32)
				type(windows.Gdi32)
				type(windows.Advapi32)
				type(windows.Shell32)
				type(windows.Ole32)
				type(windows.PROCESS_VM_READ)
				type(windows.MEM_COMMIT)
				type(windows.PAGE_READWRITE)
				type(windows.FORMAT_MESSAGE_FROM_SYSTEM)
				type(windows.WS_OVERLAPPEDWINDOW)
				type(windows.CW_USEDEFAULT)
				type(windows.WM_PAINT)
				type(windows.SW_SHOW)
				type(windows.MB_OK)
				type(windows.IDC_ARROW)
				type(windows.wstr('oak'))
				type(windows.cstr('oak'))
				type(windows.formatMessage)
				type(windows.loadDll)
				type(windows.resolveInLoaded)
				type(windows.callIn)
				type(windows.user32)
				type(windows.gdi32)
				type(windows.advapi32)
				type(windows.shell32)
				type(windows.ole32)
				type(windows.registerClassEx)
				type(windows.createWindowEx)
				type(windows.defWindowProc)
				type(windows.showWindow)
				type(windows.updateWindow)
				type(windows.destroyWindow)
				type(windows.postQuitMessage)
				type(windows.getMessage)
				type(windows.peekMessage)
				type(windows.translateMessage)
				type(windows.dispatchMessage)
				type(windows.isWindow)
				type(windows.waitMessage)
				type(windows.callOk?)
				type(windows.noMessage?)
				type(windows.windowAlive?)
				type(windows.msgStructSize)
				type(windows.createMsgBuffer)
				type(windows.pumpWindowMessage)
				type(windows.runWindowLoopPeek)
				type(windows.messageBox)
				type(windows.setWindowText)
				type(windows.loadCursor)
				type(windows.loadIcon)
				type(windows.beginPaint)
				type(windows.endPaint)
				type(windows.getDC)
				type(windows.releaseDC)
				type(windows.getStockObject)
				type(windows.selectObject)
				type(windows.textOut)
				type(windows.rectangle)
				type(windows.ellipse)
				type(windows.createSolidBrush)
				type(windows.deleteObject)
				type(windows.virtualAllocEx)
				type(windows.virtualQueryEx)
				type(windows.readU32)
				type(windows.writeU64)
				len(windows.cstr('oak')) = 4
			]
			[:string, :string, :string, :string, :string, :string, :string, :string, :int, :int, :int, :int, :int, :int, :int, :int, :int, :int, :string, :string, :function, :function, :function, :function, :function, :function, :function, :function, :function, :function, :function, :function, :function, :function, :function, :function, :function, :function, :function, :function, :function, :function, :function, :function, :function, :function, :function, :function, :function, :function, :function, :function, :function, :function, :function, :function, :function, :function, :function, :function, :function, :function, true]
		)

		'typed memory helpers read and write little-endian integers safely' |> t.eq(
			{
				buf := bits([0, 0, 0, 0, 0, 0, 0, 0])
				p := addr(buf)
				windows.writeU32(p, 305419896) // 0x12345678
				windows.writeU64(p, 72623859790382856) // 0x0102030405060708
				[
					windows.readU32(p)
					windows.readU64(p)
				]
			}
			[84281096, 72623859790382856]
		)

		'windows wrapper basic behavior is OS-aware and safe' |> t.eq(
			{
				os := ___runtime_sys_info().os
				pidCall := windows.kernel32('GetCurrentProcessId')
				msg := windows.formatMessage(2)
				if os {
					'windows' -> {
						windows.isWindows?() &
						((pidCall.type = :ok) | (pidCall.type = :success)) &
						(windows.currentProcessId() > 0) &
						(windows.imageBase() > 0) &
						((type(msg) = :string) | (type(msg) = :null))
					}
					_ -> {
						(!windows.isWindows?()) &
						(pidCall.type = :error) &
						(windows.currentProcessId() = -1) &
						(windows.imageBase() = 0) &
						(type(msg) = :null)
					}
				}
			}
			true
		)

		'extended windows DLL wrappers and constants are exported' |> t.eq(
			[
				type(windows.Ws2_32)
				type(windows.Comctl32)
				type(windows.Wininet)
				type(windows.D3d9)
				type(windows.Msvcp)
				type(windows.Msvcrt)
				type(windows.Ucrtbase)
				type(windows.Vcruntime140)
				type(windows.ActionCenter)
				type(windows.Aclui)
				type(windows.Acledit)
				type(windows.Acppage)
				type(windows.Acprgwiz)
				type(windows.Acproxy)
				type(windows.Adprovider)
				type(windows.Aeinv)
				type(windows.Aepdu)
				type(windows.Aepic)
				type(windows.AepRoam)
				type(windows.Alrsvc)
				type(windows.Amstream)
				type(windows.SixTo4svc)
				type(windows.Adsldp)
				type(windows.Adsnt)
				type(windows.ApiSetPrefix)
				type(windows.ntNative)
				type(windows.ws2_32)
				type(windows.comctl32)
				type(windows.wininet)
				type(windows.d3d9)
				type(windows.msvcp)
				type(windows.msvcrt)
				type(windows.ucrtbase)
				type(windows.vcruntime140)
				type(windows.actionCenter)
				type(windows.aclui)
				type(windows.acledit)
				type(windows.acppage)
				type(windows.acprgwiz)
				type(windows.acproxy)
				type(windows.adprovider)
				type(windows.aeinv)
				type(windows.aepdu)
				type(windows.aepic)
				type(windows.aepRoam)
				type(windows.alrsvc)
				type(windows.amstream)
				type(windows.sixTo4svc)
				type(windows.adsldp)
				type(windows.adsnt)
			]
			[
				:string, :string, :string, :string, :string, :string, :string, :string, :string, :string,
				:string, :string, :string, :string, :string, :string, :string, :string, :string, :string,
				:string, :string, :string, :string, :string, :function, :function, :function, :function, :function,
				:function, :function, :function, :function, :function, :function, :function, :function, :function, :function,
				:function, :function, :function, :function, :function, :function, :function, :function, :function, :function
			]
		)

		'winsock wininet and registry wrappers expose expected types' |> t.eq(
			[
				type(windows.ERROR_SUCCESS)
				type(windows.AF_INET)
				type(windows.SOCK_STREAM)
				type(windows.IPPROTO_TCP)
				type(windows.SOCKET_ERROR)
				type(windows.SD_BOTH)
				type(windows.INTERNET_OPEN_TYPE_DIRECT)
				type(windows.INTERNET_DEFAULT_HTTPS_PORT)
				type(windows.HKEY_CURRENT_USER)
				type(windows.KEY_READ)
				type(windows.REG_DWORD)
				type(windows.makeWord)
				windows.makeWord(2, 2)
				type(windows.statusOk?)
				type(windows.wsLastError)
				type(windows.wsaStartup)
				type(windows.wsaCleanup)
				type(windows.socket)
				type(windows.bindSocket)
				type(windows.connectSocket)
				type(windows.listenSocket)
				type(windows.acceptSocket)
				type(windows.sendSocket)
				type(windows.recvSocket)
				type(windows.shutdownSocket)
				type(windows.closeSocket)
				type(windows.htons)
				type(windows.htonl)
				type(windows.inetAddr)
				type(windows.internetOpen)
				type(windows.internetConnect)
				type(windows.internetOpenUrl)
				type(windows.internetReadFile)
				type(windows.internetCloseHandle)
				type(windows.regCloseKey)
				type(windows.regOpenKeyEx)
				type(windows.regCreateKeyEx)
				type(windows.regQueryValueEx)
				type(windows.regSetValueEx)
				type(windows.regDeleteValue)
				type(windows.INTERNET_SERVICE_HTTP)
				type(windows.KEY_WRITE)
				type(windows.sockaddrIn)
				type(windows.internetSimpleGet)
				type(windows.regReadDword)
				type(windows.regWriteDword)
				type(windows.regReadString)
				type(windows.regWriteString)
			]
			[
				:int, :int, :int, :int, :int, :int, :int, :int, :int, :int,
				:int, :function, 514, :function, :function, :function, :function, :function, :function, :function,
				:function, :function, :function, :function, :function, :function, :function, :function, :function, :function,
				:function, :function, :function, :function, :function, :function, :function, :function, :function, :function,
				:int, :int, :function, :function, :function, :function, :function, :function
			]
		)
	}
}

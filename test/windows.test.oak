windows := import('windows')

fn run(t) {
	{
		'windows constants and helpers expose expected types' |> t.eq(
			{
				(type(windows.Kernel32) = :string) &
				(type(windows.Ntdll) = :string) &
				(type(windows.User32) = :string) &
				(type(windows.Gdi32) = :string) &
				(type(windows.Advapi32) = :string) &
				(type(windows.Ws2_32) = :string) &
				(type(windows.Wininet) = :string) &
				(type(windows.D3d9) = :string) &
				(type(windows.PROCESS_VM_READ) = :int) &
				(type(windows.MEM_COMMIT) = :int) &
				(type(windows.PAGE_READWRITE) = :int) &
				(type(windows.FORMAT_MESSAGE_FROM_SYSTEM) = :int) &
				(type(windows.wstr('oak')) = :string) &
				(type(windows.cstr('oak')) = :string) &
				(type(windows.loadDll) = :function) &
				(type(windows.callIn) = :function) &
				(type(windows.user32) = :function) &
				(type(windows.kernel32) = :function) &
				(type(windows.ntdll) = :function) &
				(type(windows.formatMessage) = :function) &
				(type(windows.virtualAllocEx) = :function) &
				(type(windows.virtualQueryEx) = :function) &
				(type(windows.readU32) = :function) &
				(type(windows.writeU64) = :function) &
				(len(windows.cstr('oak')) = 4)
			}
			true
		)

		'typed memory helpers read and write little-endian integers safely' |> t.eq(
			{
				buf := bits([0, 0, 0, 0, 0, 0, 0, 0])
				p := addr(buf)
				windows.writeU32(p, 305419896) // 0x12345678
				windows.writeU64(p, 72623859790382856) // 0x0102030405060708
				[
					windows.readU32(p)
					windows.readU64(p)
				]
			}
			[84281096, 72623859790382856]
		)

		'windows wrapper basic behavior is OS-aware and safe' |> t.eq(
			{
				os := ___runtime_sys_info().os
				pidCall := windows.kernel32('GetCurrentProcessId')
				msg := windows.formatMessage(2)
				if os {
					'windows' -> {
						windows.isWindows?() &
						((pidCall.type = :ok) | (pidCall.type = :success)) &
						(windows.currentProcessId() > 0) &
						(windows.imageBase() > 0) &
						((type(msg) = :string) | (type(msg) = :null))
					}
					_ -> {
						(!windows.isWindows?()) &
						(pidCall.type = :error) &
						(windows.currentProcessId() = -1) &
						(windows.imageBase() = 0) &
						(type(msg) = :null)
					}
				}
			}
			true
		)

		'extended windows DLL wrappers and constants are exported' |> t.eq(
			[
				type(windows.Ws2_32)
				type(windows.Comctl32)
				type(windows.Wininet)
				type(windows.D3d9)
				type(windows.Msvcp)
				type(windows.Msvcrt)
				type(windows.Ucrtbase)
				type(windows.Vcruntime140)
				type(windows.ActionCenter)
				type(windows.Aclui)
				type(windows.Acledit)
				type(windows.Acppage)
				type(windows.Acprgwiz)
				type(windows.Acproxy)
				type(windows.Adprovider)
				type(windows.Aeinv)
				type(windows.Aepdu)
				type(windows.Aepic)
				type(windows.AepRoam)
				type(windows.Alrsvc)
				type(windows.Amstream)
				type(windows.SixTo4svc)
				type(windows.Adsldp)
				type(windows.Adsnt)
				type(windows.ApiSetPrefix)
				type(windows.ntNative)
				type(windows.ws2_32)
				type(windows.comctl32)
				type(windows.wininet)
				type(windows.d3d9)
				type(windows.msvcp)
				type(windows.msvcrt)
				type(windows.ucrtbase)
				type(windows.vcruntime140)
				type(windows.actionCenter)
				type(windows.aclui)
				type(windows.acledit)
				type(windows.acppage)
				type(windows.acprgwiz)
				type(windows.acproxy)
				type(windows.adprovider)
				type(windows.aeinv)
				type(windows.aepdu)
				type(windows.aepic)
				type(windows.aepRoam)
				type(windows.alrsvc)
				type(windows.amstream)
				type(windows.sixTo4svc)
				type(windows.adsldp)
				type(windows.adsnt)
			]
			[
				:string, :string, :string, :string, :string, :string, :string, :string, :string, :string,
				:string, :string, :string, :string, :string, :string, :string, :string, :string, :string,
				:string, :string, :string, :string, :string, :function, :function, :function, :function, :function,
				:function, :function, :function, :function, :function, :function, :function, :function, :function, :function,
				:function, :function, :function, :function, :function, :function, :function, :function, :function, :function
			]
		)

		'winsock wininet and registry wrappers expose expected types' |> t.eq(
			[
				type(windows.ERROR_SUCCESS)
				type(windows.AF_INET)
				type(windows.SOCK_STREAM)
				type(windows.IPPROTO_TCP)
				type(windows.SOCKET_ERROR)
				type(windows.SD_BOTH)
				type(windows.INTERNET_OPEN_TYPE_DIRECT)
				type(windows.INTERNET_DEFAULT_HTTPS_PORT)
				type(windows.HKEY_CURRENT_USER)
				type(windows.KEY_READ)
				type(windows.REG_DWORD)
				type(windows.makeWord)
				windows.makeWord(2, 2)
				type(windows.statusOk?)
				type(windows.wsLastError)
				type(windows.wsaStartup)
				type(windows.wsaCleanup)
				type(windows.socket)
				type(windows.bindSocket)
				type(windows.connectSocket)
				type(windows.listenSocket)
				type(windows.acceptSocket)
				type(windows.sendSocket)
				type(windows.recvSocket)
				type(windows.shutdownSocket)
				type(windows.closeSocket)
				type(windows.htons)
				type(windows.htonl)
				type(windows.inetAddr)
				type(windows.internetOpen)
				type(windows.internetConnect)
				type(windows.internetOpenUrl)
				type(windows.internetReadFile)
				type(windows.internetCloseHandle)
				type(windows.regCloseKey)
				type(windows.regOpenKeyEx)
				type(windows.regCreateKeyEx)
				type(windows.regQueryValueEx)
				type(windows.regSetValueEx)
				type(windows.regDeleteValue)
				type(windows.INTERNET_SERVICE_HTTP)
				type(windows.KEY_WRITE)
				type(windows.sockaddrIn)
				type(windows.internetSimpleGet)
				type(windows.regReadDword)
				type(windows.regWriteDword)
				type(windows.regReadString)
				type(windows.regWriteString)
			]
			[
				:int, :int, :int, :int, :int, :int, :int, :int, :int, :int,
				:int, :function, 514, :function, :function, :function, :function, :function, :function, :function,
				:function, :function, :function, :function, :function, :function, :function, :function, :function, :function,
				:function, :function, :function, :function, :function, :function, :function, :function, :function, :function,
				:int, :int, :function, :function, :function, :function, :function, :function
			]
		)

		'additional compatibility and AD related DLL bindings are exported' |> t.eq(
			[
				type(windows.Adtschema)
				type(windows.Adsldpc)
				type(windows.Adsmsext)
				type(windows.Adsnds)
				type(windows.Adsnw)
				type(windows.Adadmigrate)
				type(windows.AdfsMig)
				type(windows.Adhsvc)
				type(windows.Admexs)
				type(windows.Admparse)
				type(windows.AdmTmpl)
				type(windows.Admxprox)
				type(windows.Adptif)
				type(windows.Adrclient)
				type(windows.Advapi32res)
				type(windows.Advpack)
				type(windows.Adwsmigrate)
				type(windows.Aecache)
				type(windows.Aeevts)
				type(windows.Aelupsvc)
				type(windows.Agcore)
				type(windows.Agentctl)
				type(windows.ALRes409)
				type(windows.AltTab)
				type(windows.Apcups)
				type(windows.Apds)
				type(windows.Amxread)
				type(windows.adtschema)
				type(windows.adsldpc)
				type(windows.adsmsext)
				type(windows.adsnds)
				type(windows.adsnw)
				type(windows.adadmigrate)
				type(windows.adfsMig)
				type(windows.adhsvc)
				type(windows.admexs)
				type(windows.admparse)
				type(windows.admTmpl)
				type(windows.admxprox)
				type(windows.adptif)
				type(windows.adrclient)
				type(windows.advapi32res)
				type(windows.advpack)
				type(windows.adwsmigrate)
				type(windows.aecache)
				type(windows.aeevts)
				type(windows.aelupsvc)
				type(windows.agcore)
				type(windows.agentctl)
				type(windows.alRes409)
				type(windows.altTab)
				type(windows.apcups)
				type(windows.apds)
				type(windows.amxread)
			]
			[
				:string, :string, :string, :string, :string, :string, :string, :string, :string, :string,
				:string, :string, :string, :string, :string, :string, :string, :string, :string, :string,
				:string, :string, :string, :string, :string, :string, :string, :function, :function, :function,
				:function, :function, :function, :function, :function, :function, :function, :function, :function, :function,
				:function, :function, :function, :function, :function, :function, :function, :function, :function, :function,
				:function, :function, :function, :function
			]
		)

		'dynamic D3DX9 and ApiSet helpers are exported' |> t.eq(
			[
				type(windows.D3dx9Prefix)
				type(windows.d3dx9Dll)
				windows.d3dx9Dll('43')
				type(windows.d3dx9)
				type(windows.apiSetDll)
				windows.apiSetDll('core-path-l1-1-0')
				type(windows.apiSet)
			]
			[
				:string
				:function
				'd3dx9_43.dll'
				:function
				:function
				'api-ms-win-core-path-l1-1-0.dll'
				:function
			]
		)

		'core app stack DLL bindings are exported' |> t.eq(
			[
				type(windows.Winhttp)
				type(windows.Urlmon)
				type(windows.Crypt32)
				type(windows.Bcrypt)
				type(windows.Secur32)
				type(windows.Comdlg32)
				type(windows.Oleaut32)
				type(windows.Shlwapi)
				type(windows.Shcore)
				type(windows.UxTheme)
				type(windows.Dwmapi)
				type(windows.Version)
				type(windows.Setupapi)
				type(windows.Netapi32)
				type(windows.winhttp)
				type(windows.urlmon)

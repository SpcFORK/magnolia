				type(windows.netapi32)
			]
			[
				:string, :string, :string, :string, :string, :string, :string, :string, :string, :string,
				:string, :string, :string, :string, :function, :function, :function, :function, :function, :function,
				:function, :function, :function, :function, :function, :function, :function, :function
			]
		)

		'multimedia scheduler and connectivity DLL bindings are exported' |> t.eq(
			[
				type(windows.Winmm)
				type(windows.Avrt)
				type(windows.Mmdevapi)
				type(windows.Dsound)
				type(windows.Mfplat)

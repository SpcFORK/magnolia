sceneManagerComp := import('./ext/mg/comps/scene-manager')

fn run(t) {
	sm := sceneManagerComp.SceneManager()

	'mg scene manager starts on intro scene' |> t.eq(
		[sm.currentScene, sm.nextScene, sm.isSceneChange()]
		[:intro, :intro, false]
	)

	sm.changeScene(:menu)
	'mg scene manager tracks scene change request' |> t.eq(
		[sm.currentScene, sm.nextScene, sm.isSceneChange()]
		[:intro, :menu, true]
	)

	sm.updateScene()
	'mg scene manager applies scene change update' |> t.eq(
		[sm.currentScene, sm.nextScene, sm.isSceneChange()]
		[:menu, :menu, false]
	)

	sm.changeScene(:intro)
	sm.updateScene()
	'mg scene manager supports return to intro scene' |> t.eq(
		[sm.currentScene, sm.nextScene]
		[:intro, :intro]
	)

	'mg scene manager clock default is zero' |> t.eq(
		sm.clockMs('introElapsedMs')
		0
	)

	sm.setClockMs('introElapsedMs', 1250)
	'mg scene manager setClockMs stores clock value' |> t.eq(
		sm.clockMs('introElapsedMs')
		1250
	)

	'mg scene manager tickClockSec increments and returns ms' |> t.eq(
		sm.tickClockSec('introElapsedMs', 0.5)
		1750
	)

	'mg scene manager tickClockSec initializes missing clock' |> t.eq(
		sm.tickClockSec('frameDtMs', 0.016)
		16
	)
}

{
	run: run
}
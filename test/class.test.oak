fn run(t) {
	{
		'class without params acts like constructor sugar' |> t.eq(
			{
				cs Empty {
					{}
				}
				type(Empty())
			}
			:object
		)

		'class sugar keeps bare braces as an empty block body' |> t.eq(
			{
				cs Empty {}
				Empty()
			}
			?
		)

		'class constructor params are captured in body' |> t.eq(
			{
				cs Pair(left, right) {
					{
						left: left
						right: right
					}
				}
				Pair(1, 2).right
			}
			2
		)

		'class methods can close over constructor state' |> t.eq(
			{
				cs Counter(start) {
					{
						value: start
						add: fn(delta) start + delta
					}
				}
				Counter(4).add(3)
			}
			7
		)

		'class assignment sugar methods mutate instance fields' |> t.eq(
			{
				cs Counter {
					a := 2
					set := fn {
						a <- 3
					}
				}

				counter := Counter()
				counter.set()
				counter.a
			}
			3
		)

		'class constructor supports variadic params' |> t.eq(
			{
				cs Bag(items...) {
					items
				}
				len(Bag(1, 2, 3))
			}
			3
		)

		'class constructor supports expression body sugar' |> t.eq(
			{
				cs Id(value) value
				Id(9)
			}
			9
		)

		'class supports parent merge and static members' |> t.eq(
			{
				cs Parent1 {
					a := 2
					b := 1
				}

				cs Parent2 {
					c := 3
					b := 2
				}

				cs Car(make) {
					kind := :vehicle
					fn describe() make + '-class'

					(Parent1, Parent2) -> {}
				}

				[
					Car('sedan').a
					Car('sedan').b
					Car('sedan').c
					Car.kind
					type(Car.describe)
				]
			}
			[2, 2, 3, :vehicle, :function]
		)

		'csof matches by class and class name atom' |> t.eq(
			{
				cs Alpha {}
				cs Beta {}

				[
					csof(Alpha, Alpha)
					csof(Alpha, Beta)
					csof(Alpha, :Alpha)
					csof(:Alpha, Alpha)
					csof(:Alpha, Beta)
				]
			}
			[true, false, true, true, false]
		)

		'csof on non-instance and single-arg forms' |> t.eq(
			{
				cs Alpha {}
				[
					csof(1, :Alpha)
					csof(Alpha)
					csof(1)
				]
			}
			[false, true, false]
		)

		'Self sugar references instance' |> t.eq(
			{
				cs Widget {
					x := 10
					y := 20
					getSelf := fn() Self
				}

				w := Widget()
				s := w.getSelf()
				[s.x, s.y]
			}
			[10, 20]
		)

		'Self sugar passed to external function' |> t.eq(
			{
				fn extract(obj) obj.value

				cs Box {
					value := 42
					extractSelf := fn() extract(Self)
				}

				Box().extractSelf()
			}
			42
		)

		'Self sugar enables mutation via external fn' |> t.eq(
			{
				fn bumpN(obj) obj.n <- obj.n + 1

				cs Counter {
					n := 0
					bump := fn() bumpN(Self)
				}

				c := Counter()
				c.bump()
				c.bump()
				c.n
			}
			2
		)

		'lowercase self references instance in assignment block' |> t.eq(
			{
				cs Widget {
					x := 10
					getSelf := fn() self
				}

				w := Widget()
				w.getSelf().x
			}
			10
		)

		'self in fn inside assignment block class' |> t.eq(
			{
				cs c { b := fn e() self }
				inst := c()
				type(inst.b())
			}
			:object
		)

	}
}

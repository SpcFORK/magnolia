{
	createVirtualFS: createVirtualFS
} := import('Virtual')

fn run(t) {
	'createVirtualFS exposes file existence and read operations' |> t.eq(
		{
			vfs := createVirtualFS({
				'test.txt': 'Hello, VFS!'
				'data/config.json': '{"version": "1.0"}'
			})
			[vfs.exists?('test.txt'), vfs.readFile('test.txt')]
		}
		[true, 'Hello, VFS!']
	)
}

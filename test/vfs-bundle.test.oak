// Test VFS bundling functionality

{
	println: println
} := import('std')
{
	createVirtualFS: createVirtualFS
} := import('Virtual')

// Test 1: Create VFS with files
fn testCreateVFS() {
	vfs := createVirtualFS({
		'test.txt': 'Hello, VFS!'
		'data/config.json': '{"version": "1.0"}'
	})
	
	if vfs.exists?('test.txt') {
		true -> println('✓ VFS file exists')
		_ -> println('✗ VFS file does not exist')
	}
	
	content := vfs.readFile('test.txt')
	if content {
		'Hello, VFS!' -> println('✓ VFS read correct content')
		_ -> println('✗ VFS read incorrect content: ' << content)
	}
}

// Test 2: Check if __Oak_VFS is available in bundle (set by build)
fn testBundledVFS() {
	if __Oak_VFS? {
		true -> {
			println('✓ __Oak_VFS global is available in bundle')
			files := __Oak_VFS.listFiles()
			println('  Bundled files: ' << string(len(files)))
		}
		_ -> println('  __Oak_VFS not bundled (expected if not built with --includeVFS)')
	}
}

println('[VFS Bundle Tests]')
testCreateVFS()
testBundledVFS()

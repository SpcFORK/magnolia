fn run(t) {
	{
		'make_chan returns channel object' |> t.eq(
			make_chan().type
			:channel
		)

		'buffered channel round trip works' |> t.eq(
			{
				ch := make_chan(1)
				chan_send(ch, 42)
				chan_recv(ch).data
			}
			42
		)

		'go goroutine can coordinate over channel' |> t.eq(
			{
				ch := make_chan()
				go(fn {
					chan_send(ch, :ready)
				})
				chan_recv(ch).data
			}
			:ready
		)

		'go runtime version is exposed as string' |> t.eq(
			type(___runtime_go_version())
			:string
		)

		'go runtime system info exposes cpu count' |> t.eq(
			type(___runtime_sys_info().cpus)
			:int
		)

		'bits converts byte lists to byte strings and back' |> t.eq(
			bits(bits([65, 66, 67]))
			[65, 66, 67]
		)

		'low-level memory read and write works for byte buffers' |> t.eq(
			{
				buf := bits([65, 66, 67])
				ptr := addr(buf)
				memwrite(ptr + 1, bits([90]))
				bits(memread(ptr, 3))
			}
			[65, 90, 67]
		)

		'memory read/write via pointer builtin' |> t.eq(
			{
				buf := bits([65, 66, 67])
				ptr := pointer(addr(buf))
				memwrite(ptr + 1, bits([90]))
				bits(memread(ptr, 3))
			}
			[65, 90, 67]
		)

		'pointer builtin type and arithmetic' |> t.eq(
			[
				type(pointer(0))
				pointer(0) == 0
				pointer(5) == pointer(5)
				pointer(100) + 5 == pointer(105)
				5 + pointer(100) == pointer(105)
				pointer(105) - 5 == pointer(100)
				pointer(20) > pointer(10)
				pointer(20) < pointer(10) == false
			]
			[:pointer, true, true, true, true, true, true, true]
		)

		'int from pointer builtin' |> t.eq(
			int(pointer(123))
			123
		)

		'name builtin and atom pointer refs' |> t.eq(
			{
				cs Alpha {}
				p := pointer(:Alpha)
				memwrite(:slot, :hello)
				q := pointer(:slot)
				[
					name(Alpha)
					name(:Beta)
					type(p)
					name(p)
					name(q)
				]
			}
			[:Alpha, :Beta, :pointer, :Alpha, :hello]
		)

		'utf16 builtin encodes to LE byte pairs with BOM' |> t.eq(
			{
				buf := utf16('Az')
				[
					len(buf)
					codepoint(buf.0)
					codepoint(buf.1)
					codepoint(buf.2)
					codepoint(buf.3)
					codepoint(buf.4)
					codepoint(buf.5)
				]
			}
			[6, 65, 0, 122, 0, 0, 0]
		)

		'atom and char builtins' |> t.eq(
			[
				atom('xyz')
				atom(10)
				char(65)
				char(-10)
				char(300)
			]
			[:xyz, :10, 'A', char(0), char(255)]
		)

		'runtime metadata builtins exist with expected types' |> t.eq(
			[
				type(___runtime_go_version())
				type(___runtime_sys_info().cpus)
				type(___runtime_gc())
				type(___runtime_mem().heap)
				type(___runtime_mem().allocs)
				type(___runtime_proc().pid)
				(type(___runtime_proc().exe) = :string) | (type(___runtime_proc().exe) = :null)
			]
			[:string, :int, :null, :int, :int, :int, true]
		)

		'runtime stdlib introspection builtins' |> t.eq(
			[
				type(___stdlibs())
				type(___stdlibs().std)
				___runtime_lib?('std')
				___runtime_lib?('sys')
				type(___runtime_lib('definitely_missing_lib'))
			]
			[:object, :string, true, true, :null]
		)

		'builtin presence for IO and process features' |> t.eq(
			[
				type(input)
				type(exit)
				type(exec)
				type(ls)
				type(rm)
				type(mkdir)
				type(stat)
				type(open)
				type(close)
				type(read)
				type(write)
				type(listen)
				type(req)
			]
			[
				:function, :function, :function, :function, :function
				:function, :function, :function, :function, :function
				:function, :function, :function
			]
		)

		'process time and random builtins' |> t.eq(
			[
				type(args())
				len(args()) > 0
				type(env())
				type(time())
				type(nanotime())
				type(rand())
				len(srand(8))
				rand() >= 0 & rand() < 1
			]
			[:list, true, :object, :float, :int, :float, 8, true]
		)
	}
}

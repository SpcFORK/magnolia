std := import('std')

fn run(t) {
	// Test syscall function exists and basic error handling
	{
		'invalid syscall number returns error' |> t.eq(
			syscall(-1).type
			:error
		)

		'syscall with no arguments returns error' |> t.eq(
			syscall().type
			:error
		)

		'syscall with valid number but invalid args' |> t.eq(
			syscall(0, 'invalid').type
			:error
		)

		'sysproc missing library returns error' |> t.eq(
			sysproc('definitely-missing-oak-syscall.dll', 'MissingProc').type
			:error
		)

		'utf16 encodes bytes with trailing null terminator' |> t.eq(
			{
				buf := utf16('Az')
				[len(buf), codepoint(buf.0), codepoint(buf.1), codepoint(buf.2), codepoint(buf.3), codepoint(buf.4), codepoint(buf.5)]
			}
			[6, 65, 0, 122, 0, 0, 0]
		)
	}
}

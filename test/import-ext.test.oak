fs := import('fs')
fmt := import('fmt')
{ each: each } := import('std')

fn writeFixture(dir, name, value) {
	fs.writeFile(fmt.format('{{0}}/{{1}}', dir, name), 'value := ' << string(value))
}

fn run(t) {
	fixtureDir := './test/.tmp-import-ext'
	rm(fixtureDir)
	mkdir(fixtureDir)

	[
		['module_oak.oak', 1]
		['module_ok.ok', 2]
		['module_mag.mag', 3]
		['module_mg.mg', 4]
		['explicit.ok', 5]
	] |> with each() fn(spec) {
		writeFixture(fixtureDir, spec.0, spec.1)
	}

	'extensionless import resolves .oak' |> t.eq(
		import('./test/.tmp-import-ext/module_oak').value
		1
	)

	'extensionless import resolves .ok' |> t.eq(
		import('./test/.tmp-import-ext/module_ok').value
		2
	)

	'extensionless import resolves .mag' |> t.eq(
		import('./test/.tmp-import-ext/module_mag').value
		3
	)

	'extensionless import resolves .mg' |> t.eq(
		import('./test/.tmp-import-ext/module_mg').value
		4
	)

	'explicit supported extension import works' |> t.eq(
		import('./test/.tmp-import-ext/explicit.ok').value
		5
	)

	rm(fixtureDir)
}

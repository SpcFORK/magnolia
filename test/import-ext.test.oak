fs := import('fs')
fmt := import('fmt')

fn writeFixture(dir, name, value) {
	fs.writeFile(fmt.format('{{0}}/{{1}}', dir, name), 'value := ' << string(value))
}

fn run(t) {
	if ___runtime_go_version() = 'js' {
		true -> 'import extension fixture imports skipped in js bundle runtime' |> t.eq(true, true)
		_ -> {
			fixtureDir := './test/.tmp-import-ext'
			rm(fixtureDir)
			mkdir(fixtureDir)

			writeFixture(fixtureDir, 'module_oak.oak', 1)
			writeFixture(fixtureDir, 'module_ok.ok', 2)
			writeFixture(fixtureDir, 'module_mag.mag', 3)
			writeFixture(fixtureDir, 'module_mg.mg', 4)
			writeFixture(fixtureDir, 'explicit.ok', 5)

			'extensionless import resolves .oak' |> t.eq(
				import('./.tmp-import-ext/module_oak').value
				1
			)

			'extensionless import resolves .ok' |> t.eq(
				import('./.tmp-import-ext/module_ok').value
				2
			)

			'extensionless import resolves .mag' |> t.eq(
				import('./.tmp-import-ext/module_mag').value
				3
			)

			'extensionless import resolves .mg' |> t.eq(
				import('./.tmp-import-ext/module_mg').value
				4
			)

			'explicit supported extension import works' |> t.eq(
				import('./.tmp-import-ext/explicit.ok').value
				5
			)

			rm(fixtureDir)
		}
	}
}

{
	run: run
}

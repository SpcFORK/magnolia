std := import('std')
sh := import('gui-shader')

fn _rgb(r, g, b) r | (g << 8) | (b << 16)

fn run(t) {
	// @ Math Helpers
	{
		{
			fract: fract
			mod: mod
			sign: sign
			abs2: abs2
			clamp: clamp
		} := sh
		'fract(3.75) = 0.75' |> t.approx(fract(3.75), 0.75)
		'clamp in range' |> t.eq(clamp(5, 0, 10), 5)
	}

	// @ Color Helpers
	{
		{
			colorR: colorR
		} := sh

		red := _rgb(255, 0, 0)
		std.println('colorR type:', type(colorR))
		std.println('red:', red)
		std.println('colorR(red):', colorR(red))
	}
}

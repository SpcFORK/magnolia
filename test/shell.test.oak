// shell.test.oak - tests for the virtual shell

shell := import('shell')
Virtual := import('Virtual')

fn run(t) {
	// Basic commands
	{
		vfs := Virtual.createVirtualFS({
			'/home/test.txt': 'Hello, World!'
			'/home/data.json': '{"version": "1.0"}'
			'/etc/config.conf': 'debug=true'
		})

		sh := shell.createShell(vfs)

		'shell initial directory is root' |> t.eq(sh.getCurrentDir(), '/')

		sh.exec('cd /home')
		'cd changes directory' |> t.eq(sh.getCurrentDir(), '/home')

		sh.exec('cd ..')
		'cd .. goes to parent' |> t.eq(sh.getCurrentDir(), '/')

		sh.exec('cd home')
		sh.exec('cd ../etc')
		'cd with ../ path works' |> t.eq(sh.getCurrentDir(), '/etc')
	}

	// File operations
	{
		vfs := Virtual.createVirtualFS({
			'/test.txt': 'original content'
		})

		sh := shell.createShell(vfs)

		sh.exec('touch /new.txt')
		'touch creates file' |> t.assert(vfs.exists?('/new.txt'))

		sh.exec('cp /test.txt /copy.txt')
		'cp copies content' |> t.eq(vfs.readFile('/copy.txt'), 'original content')

		sh.exec('mv /copy.txt /renamed.txt')
		'mv creates destination' |> t.assert(vfs.exists?('/renamed.txt'))
		'mv removes source' |> t.assert(!vfs.exists?('/copy.txt'))

		sh.exec('rm /renamed.txt')
		'rm deletes file' |> t.assert(!vfs.exists?('/renamed.txt'))
	}

	// Environment variables
	{
		if ___runtime_go_version() = 'js' {
			true -> 'export command behavior skipped in js runtime shell tests' |> t.eq(true, true)
			_ -> {
				sh := shell.createShell()

				sh.exec('export TEST_VAR=hello')
				env := sh.getEnv()
				'export sets variable' |> t.eq(env.TEST_VAR, 'hello')

				sh.exec('export TEST_VAR2=key=value')
				env := sh.getEnv()
				'export handles = in value' |> t.eq(env.TEST_VAR2, 'key=value')
			}
		}
	}

	// Batch mode
	{
		vfs := Virtual.createVirtualFS({})
		sh := shell.createShell(vfs)

		script := '
# Test script
cd /
touch test1.txt
touch test2.txt
echo Script executed
'

		result := sh.batch(script)
		'batch returns 0 on success' |> t.eq(result, 0)
		'batch executes first command' |> t.assert(vfs.exists?('/test1.txt'))
		'batch executes multiple commands' |> t.assert(vfs.exists?('/test2.txt'))
	}

	// Path normalization
	{
		sh := shell.createShell()

		sh.exec('cd /home/user')
		'absolute path works' |> t.eq(sh.getCurrentDir(), '/home/user')

		sh.exec('cd docs')
		'relative path appends' |> t.eq(sh.getCurrentDir(), '/home/user/docs')

		sh.exec('cd ./subdir')
		'./ prefix works' |> t.eq(sh.getCurrentDir(), '/home/user/docs/subdir')

		sh.exec('cd ../../other')
		'multiple ../ works' |> t.eq(sh.getCurrentDir(), '/home/other')
	}

	// Command parsing
	{
		vfs := Virtual.createVirtualFS({})
		sh := shell.createShell(vfs)

		'empty line returns 0' |> t.eq(sh.exec(''), 0)
		'comment returns 0' |> t.eq(sh.exec('# this is a comment'), 0)
		'unknown command returns 127' |> t.eq(sh.exec('unknown_command'), 127)

		sh.exec('touch    /file.txt')
		'multiple spaces handled' |> t.assert(vfs.exists?('/file.txt'))
	}

	// Error handling
	{
		vfs := Virtual.createVirtualFS({})
		sh := shell.createShell(vfs)

		'cat on nonexistent file returns error' |> t.eq(sh.exec('cat /nonexistent.txt'), 1)
		'cp with missing args returns error' |> t.eq(sh.exec('cp /source.txt'), 1)
		'mv with missing args returns error' |> t.eq(sh.exec('mv /source.txt'), 1)
	}
}

std := import('std')
audio := import('audio')
fmt := import('fmt')

s := audio.sine(440, 44100, 10)
d := audio.ogg(s, 44100, 1, 16)
r := audio.parseOgg(d)
fmt.println('sampleRate: ' + string(r.sampleRate))
fmt.println('channels: ' + string(r.channels))
fmt.println('bitDepth: ' + string(r.bitDepth))
fmt.println('samples: ' + string(len(r.samples)))
fmt.println('first sample approx: ' + string(int(r.samples.0 * 10000)))

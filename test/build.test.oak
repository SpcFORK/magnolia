std := import('std')
str := import('str')
build := import('build')
buildRender := import('build-render')
runtimeCodegen := import('runtime-codegen')

fn run(t) {
	parsed := build.parseIncludes('alpha:./one,beta:./two,third')
	'names from comma spec' |> t.eq(
		parsed |> std.map(:name)
		['alpha', 'beta', 'third']
	)

	fromList := build.parseIncludes([
		'foo:./x'
		{
			name: 'bar'
			path: '/tmp/bar.oak'
		}
	])
	'parse includes from list keeps object values' |> t.eq(
		[
			fromList.(0).name
			fromList.(1).path
		]
		['foo', '/tmp/bar.oak']
	)
	'parse includes resolves to .oak path' |> t.assert(
		str.endsWith?(fromList.(0).path, '.oak')
	)
	'build exports run function' |> t.eq(type(build.run), :function)
	'runtime-codegen exports wasm renderer' |> t.eq(type(runtimeCodegen.renderWasmBundle), :function)
	'build-render supports rshift in Oak output' |> t.assert(
		str.contains?(
			buildRender.renderOakBundle(
				{
					type: :binary
					tok: { type: :rshift }
					op: :rshift
					left: { type: :int, tok: { val: '8' }, val: 8 }
					right: { type: :int, tok: { val: '2' }, val: 2 }
				}
				{}
				fn(_) '{}'
				''
				fn(name) name
				fn(msg) msg
			)
			'8>>2'
		)
	)
	'build-render supports rshift in JS output' |> t.assert(
		str.contains?(
			buildRender.renderJSBundle(
				{
					type: :binary
					tok: { type: :rshift }
					op: :rshift
					left: { type: :int, tok: { val: '8' }, val: 8 }
					right: { type: :int, tok: { val: '2' }, val: 2 }
				}
				{}
				fn(_) '{}'
				''
				fn(name) name
				fn(x) x
			)
			'(8>>2)'
		)
	)

	wat := runtimeCodegen.renderWasmBundle({}, fn(_) {
		'line1\nline2\t"q"'
	})
	'wasm bundle imports oak.run' |> t.assert(str.contains?(wat, '(import "oak" "run"'))
	'wasm bundle exports run' |> t.assert(str.contains?(wat, '(export "run")'))
	'wasm bundle exports main' |> t.assert(str.contains?(wat, '(export "main")'))
	'wasm bundle exports bundle ptr/len helpers' |> t.assert(
		str.contains?(wat, '(export "bundle_ptr")') &
		str.contains?(wat, '(export "bundle_len")')
	)
	'wasm data segment escapes control characters' |> t.assert(
		str.contains?(wat, 'line1\\nline2\\t\\"q\\"')
	)

	byteEscapedWat := runtimeCodegen.renderWasmBundle({}, fn(_) {
		'A' << char(255) << char(0)
	})
	'wasm data segment escapes non-ascii and nul bytes' |> t.assert(
		str.contains?(byteEscapedWat, 'A\\ff\\00')
	)
	'wasm bundle_len counts utf-8 byte length' |> t.assert(
		str.contains?(byteEscapedWat, '(global $__oak_bundle_len (export "__oak_bundle_len") i32 (i32.const 3))')
	)

	// parseInclude keeps explicit extension
	{
		parsed := build.parseInclude('std.test:test/std.test.oak')
		'parseInclude keeps explicit .oak extension' |> t.eq(parsed.name, 'std.test')
		'parseInclude path ends with test/std.test.oak' |> t.assert(
			str.endsWith?(parsed.path, 'test/std.test.oak')
		)
	}

	// addImportsFromSource collects stdlib imports
	{
		buildImports := import('build-imports')
		collected := []

		buildImports.addImportsFromSource(
			'/entry.oak'
			''
			{}
			{}
			false
			fn(_) false
			fn(_) ?
			fn(name, _) '/deps/' + name
			fn(_) '/root'
			fn(path) collected << path
			fn(_, _) [{
				type: :assignment
				local?: true
				left: { type: :identifier, val: 'std' }
				right: {
					type: :fnCall
					function: { type: :identifier, val: 'import' }
					args: [{ type: :string, val: 'std' }]
					restArg: ?
				}
			}]
		)
		'addImportsFromSource collects static std import path' |> t.eq(
			collected
			['/deps/std']
		)
	}
}

std := import('std')
str := import('str')
build := import('build')
runtimeCodegen := import('runtime-codegen')

fn run(t) {
	parsed := build.parseIncludes('alpha:./one,beta:./two,third')
	'names from comma spec' |> t.eq(
		parsed |> std.map(:name)
		['alpha', 'beta', 'third']
	)

	fromList := build.parseIncludes([
		'foo:./x'
		{
			name: 'bar'
			path: '/tmp/bar.oak'
		}
	])
	'parse includes from list keeps object values' |> t.eq(
		[
			fromList.(0).name
			fromList.(1).path
		]
		['foo', '/tmp/bar.oak']
	)
	'parse includes resolves to .oak path' |> t.assert(
		str.endsWith?(fromList.(0).path, '.oak')
	)
	'build exports run function' |> t.eq(type(build.run), :function)
	'runtime-codegen exports wasm renderer' |> t.eq(type(runtimeCodegen.renderWasmBundle), :function)

	wat := runtimeCodegen.renderWasmBundle({}, fn(_) {
		'line1\nline2\t"q"'
	})
	'wasm bundle imports oak.run' |> t.assert(str.contains?(wat, '(import "oak" "run"'))
	'wasm bundle exports run' |> t.assert(str.contains?(wat, '(export "run")'))
	'wasm bundle exports main' |> t.assert(str.contains?(wat, '(export "main")'))
	'wasm bundle exports bundle ptr/len helpers' |> t.assert(
		str.contains?(wat, '(export "bundle_ptr")') &
		str.contains?(wat, '(export "bundle_len")')
	)
	'wasm data segment escapes control characters' |> t.assert(
		str.contains?(wat, 'line1\\nline2\\t\\"q\\"')
	)

	byteEscapedWat := runtimeCodegen.renderWasmBundle({}, fn(_) {
		'A' << char(255) << char(0)
	})
	'wasm data segment escapes non-ascii and nul bytes' |> t.assert(
		str.contains?(byteEscapedWat, 'A\\ff\\00')
	)
	'wasm bundle_len counts utf-8 byte length' |> t.assert(
		str.contains?(byteEscapedWat, '(global $__oak_bundle_len (export "__oak_bundle_len") i32 (i32.const 3))')
	)
}

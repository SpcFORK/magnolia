msgpack := import('msgpack')

fn bytesOf(s) msgpack.packet(s)

fn run(t) {
	'null encodes as c0' |> t.eq(
		msgpack.serialize(?) |> bytesOf()
		[0 xC0]
	)

	'bool true/false encoding' |> t.eq(
		[
			msgpack.serialize(true) |> bytesOf()
			msgpack.serialize(false) |> bytesOf()
		]
		[
			[0 xC3]
			[0 xC2]
		]
	)

	'positive and negative fixint encoding' |> t.eq(
		[
			msgpack.serialize(42) |> bytesOf()
			msgpack.serialize(-1) |> bytesOf()
			msgpack.serialize(-32) |> bytesOf()
		]
		[
			[42]
			[255]
			[224]
		]
	)

	'uint16 and int16 encoding' |> t.eq(
		[
			msgpack.serialize(500) |> bytesOf()
			msgpack.serialize(-200) |> bytesOf()
		]
		[
			[0 xCD, 0 x01, 0 xF4]
			[0 xD1, 0 xFF, 0 x38]
		]
	)

	'fixstr and str8 encoding' |> t.eq(
		[
			msgpack.serialize('oak') |> bytesOf()
			{
				encoded := msgpack.serialize('abcdefghijklmnopqrstuvwxyzabcdef') |> bytesOf()
				encoded.0
			}
		]
		[
			[0 xA3, 111, 97, 107]
			0 xD9
		]
	)

	'array encoding' |> t.eq(
		msgpack.serialize([1, 2, 3]) |> bytesOf()
		[0 x93, 0 x01, 0 x02, 0 x03]
	)

	'single-key map encoding' |> t.eq(
		msgpack.serialize({ a: 1 }) |> bytesOf()
		[0 x81, 0 xA1, 97, 0 x01]
	)

	'binary payload wrapper encodes as bin' |> t.eq(
		msgpack.serialize(msgpack.Binary('\x00\xFF')) |> bytesOf()
		[0 xC4, 0 x02, 0 x00, 0 xFF]
	)

	'serializePacket equals packet(serialize)' |> t.eq(
		msgpack.serializePacket([:ok, 'v'])
		msgpack.packet(msgpack.serialize([:ok, 'v']))
	)

	'serializeSafe rejects unsupported value' |> t.eq(
		type(msgpack.serializeSafe(fn() 0))
		:atom
	)

	'serialize fallback for unsupported value is nil' |> t.eq(
		msgpack.serialize(fn() 0) |> bytesOf()
		[0 xC0]
	)

	'float64 tag byte is 0xCB' |> t.eq(
		(msgpack.serializePacket(1.5)).0
		0 xCB
	)

	'float64 1.5 bytes' |> t.eq(
		msgpack.encodeFloat64(1.5) |> bytesOf()
		[0 xCB, 0 x3F, 0 xF8, 0, 0, 0, 0, 0, 0]
	)

	'float32 tag byte is 0xCA' |> t.eq(
		(msgpack.encodeFloat32(1.5) |> bytesOf()).0
		0 xCA
	)

	'float32 1.5 bytes' |> t.eq(
		msgpack.encodeFloat32(1.5) |> bytesOf()
		[0 xCA, 0 x3F, 0 xC0, 0, 0]
	)

	'parse null round-trip' |> t.eq(
		msgpack.parse(msgpack.serialize(?))
		?
	)

	'parse bool round-trip' |> t.eq(
		[msgpack.parse(msgpack.serialize(true)), msgpack.parse(msgpack.serialize(false))]
		[true, false]
	)

	'parse int round-trip' |> t.eq(
		[msgpack.parse(msgpack.serialize(0)), msgpack.parse(msgpack.serialize(42)), msgpack.parse(msgpack.serialize(-100))]
		[0, 42, -100]
	)

	'parse string round-trip' |> t.eq(
		msgpack.parse(msgpack.serialize('hello'))
		'hello'
	)

	'parse list round-trip' |> t.eq(
		msgpack.parse(msgpack.serialize([1, true, 'x']))
		[1, true, 'x']
	)

	'parse map round-trip' |> t.eq(
		msgpack.parse(msgpack.serialize({ a: 1, b: 'ok' }))
		{ a: 1, b: 'ok' }
	)

	'parse float64 1.5 round-trip' |> t.eq(
		msgpack.parse(msgpack.encodeFloat64(1.5))
		1.5
	)

	'parse float32 1.5 round-trip' |> t.eq(
		msgpack.parse(msgpack.encodeFloat32(1.5))
		1.5
	)

	'parsePacket is inverse of serializePacket' |> t.eq(
		msgpack.parsePacket(msgpack.serializePacket('world'))
		'world'
	)
}

thread := import('thread')

fn run(t) {
	'makeChannel/send/recv transports value' |> t.eq(
		{
			ch := thread.makeChannel(1)
			thread.send(ch, 42)
			thread.recv(ch).data
		}
		42
	)

	'spawn can send on an unbuffered channel' |> t.eq(
		{
			ch := thread.makeChannel()
			thread.spawn(fn() thread.send(ch, 99))
			thread.recv(ch).data
		}
		99
	)

	'Mutex lock/unlock allows critical section update' |> t.eq(
		{
			m := thread.Mutex()
			counter := 0
			m.lock()
			counter := counter + 1
			m.unlock()
			counter
		}
		1
	)

	'Mutex tryLock reports success' |> t.eq(
		{
			m := thread.Mutex()
			locked := m.tryLock()
			m.unlock()
			locked
		}
		true
	)

	'Future constructor returns object' |> t.eq(
		type(thread.Future(fn() 7 * 6))
		:object
	)

	'retry retries until non-null result' |> t.eq(
		{
			attempts := 0
			result := thread.retry(fn() {
				attempts <- attempts + 1
				if attempts < 3 {
					true -> ?
					_ -> 'ok'
				}
			}, 5)
			[result, attempts]
		}
		['ok', 3]
	)

	'Semaphore acquire/release and count work' |> t.eq(
		{
			sem := thread.Semaphore(1)
			sem.acquire()
			sem.release()
			sem.count()
		}
		1
	)

	'close is a no-op returning null' |> t.eq(
		thread.close(thread.makeChannel())
		?
	)
}

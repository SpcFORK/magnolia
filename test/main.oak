#!/usr/bin/env oak
// standard library tests

std := import('std')
test := import('test')

// when adding a stdlib here, also add to Makefile/test-js to get JS coverage
TestRunners := [
	'ai'
	'std'
	'str'
	'math'
	'sort'
	'random'
	'fmt'
	'json'
	'msgpack'
	'datetime'
	'dataprot'
	'path'
	'compression'
	'http'
	'debug'
	'cli'
	'build'
	'pack'
	'md'
	'crypto'
	'bitwise'
	'bmp'
	'gpu'
	'video'
	'syntax'
	'macro'
	'class'
	'go'
	'gui'
	'gui-raster'
	'gui-shader'
	'gui-lighting'
	'gui-fonts'
	'mg'
	'import-ext'
	'syscall'
	'thread'
	'transpile'
	'vfs-bundle'
	'websocket'
	'windows'
	'writes'
	'Linux'
	'shell'
	'virtual'
	'VirtualToken'
]

// allow selection of tests to run with CLI arguments
TestsToRun := if len(args()) > 2 {
	true -> std.slice(args(), 2)
	_ -> TestRunners
}

t := test.new('Oak stdlib')

TestRunners |> std.each(fn(name) if TestsToRun |> std.contains?(name) {
	true -> {
		runner := import(name + '.test')
		runner.run(t)
	}
})

t.reportFailed()
t.exit()


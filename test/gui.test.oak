gui := import('GUI')

fn run(t) {
	// color packing
	'rgb packs channels as little-endian int' |> t.eq(
		gui.rgb(255, 128, 64)
		255 | (128 << 8) | (64 << 16)
	)

	'windows layer state exposes init/fallback metadata' |> t.eq(
		if gui.backend() = :windows {
			true -> {
				window := gui.createWindow('Magnolia Layer Test', 240, 140, {
					layer2D: 'auto'
					layer3D: 'auto'
				})
				if window.type {
					:ok -> {
						vulkanInit := window.layers.twoD.vulkanInit
						vulkanInitOk := if type(vulkanInit) = :object {
							true ->
								((type(vulkanInit.physicalDeviceCount) = :int) | (type(vulkanInit.physicalDeviceCount) = :null)) &
								((type(vulkanInit.surfaceCreated) = :bool) | (type(vulkanInit.surfaceCreated) = :null)) &
								((type(vulkanInit.selectedQueueFamily) = :int) | (type(vulkanInit.selectedQueueFamily) = :null))
							_ -> type(vulkanInit) = :null
						}
						twoDInit := window.layers.twoD.init
						twoDInitOk := if type(twoDInit) = :object {
							true -> (type(twoDInit.primarySurfaceCreated) = :bool) | (type(twoDInit.primarySurfaceCreated) = :null)
							_ -> type(twoDInit) = :null
						}
						ok :=
							(type(window.layers) = :object) &
							((type(window.ddrawPrimarySurface) = :int) | (type(window.ddrawPrimarySurface) = :null)) &
							((type(window.vulkanInstance) = :int) | (type(window.vulkanInstance) = :null)) &
							((type(window.vulkanSurface) = :int) | (type(window.vulkanSurface) = :null)) &
							((type(window.vulkanPhysicalDevice) = :int) | (type(window.vulkanPhysicalDevice) = :null)) &
							((type(window.vulkanQueueFamily) = :int) | (type(window.vulkanQueueFamily) = :null)) &
							(type(window.layers.twoD) = :object) &
							((type(window.layers.twoD.vulkan) = :object) | (type(window.layers.twoD.vulkan) = :null)) &
							((type(window.layers.twoD.opengl) = :object) | (type(window.layers.twoD.opengl) = :null)) &
							vulkanInitOk &
							((type(window.layers.twoD.openglInit) = :object) | (type(window.layers.twoD.openglInit) = :null)) &
							(type(window.layers.threeD) = :object) &
							twoDInitOk &
							((type(window.layers.threeD.init) = :object) | (type(window.layers.threeD.init) = :null)) &
							((type(window.layers.twoD.staged) = :object) | (type(window.layers.twoD.staged) = :null))
						gui.close(window)
						ok
					}
					_ -> false
				}
			}
			_ -> true
		}
		true
	)

	'explicit Vulkan requests preserve staged fallback metadata on Windows' |> t.eq(
		if gui.backend() = :windows {
			true -> {
				window := gui.createWindow('Magnolia Vulkan Stage Test', 240, 140, {
					layer2D: 'vulkan'
					layer3D: 'auto'
				})
				if window.type {
					:ok -> {
						staged := window.layers.twoD.staged
						stagedCheck := if type(staged) = :object {
							true ->
								if (staged.requested = :vulkan) & (type(staged.bootstrapped) = :bool) & staged.bootstrapped {
									true ->
										(window.layers.twoD.selected != :vulkan) &
										(type(window.layers.twoD.fallback) = :object) &
										(window.layers.twoD.fallback.from = :vulkan)
									_ -> true
								}
							_ -> true
						}
						ok :=
							(window.layers.twoD.requested = 'vulkan') &
							((type(window.layers.twoD.vulkanInit) = :object) | (type(window.layers.twoD.vulkanInit) = :null)) &
							((type(window.layers.twoD.staged) = :object) | (type(window.layers.twoD.staged) = :null)) &
							stagedCheck
						gui.close(window)
						ok
					}
					_ -> false
				}
			}
			_ -> true
		}
		true
	)

	'windows poll is safe immediately after window creation' |> t.eq(
		if gui.backend() = :windows {
			true -> {
				window := gui.createWindow('Magnolia Poll Bootstrap Test', 240, 140, {
					layer2D: 'auto'
					layer3D: 'auto'
				})
				if window.type {
					:ok -> {
						readyBefore := window.ready
						step := gui.poll(window)
						ok :=
							(type(step) = :object) &
							((step.type = :idle) | (step.type = :dispatch) | (step.type = :closed)) &
							((readyBefore = false) | (readyBefore = ?)) &
							(window.ready = true) &
							(type(window.layers.twoD.init) = :object)
						gui.close(window)
						ok
					}
					_ -> false
				}
			}
			_ -> true
		}
		true
	)

	'windows async dllLoadMode keeps startup responsive' |> t.eq(
		if gui.backend() = :windows {
			true -> {
				window := gui.createWindow('Magnolia Async DLL Probe Test', 240, 140, {
					layer2D: 'auto'
					layer3D: 'auto'
					dllLoadMode: 'async'
				})
				if window.type {
					:ok -> {
						step := gui.poll(window)
						ok :=
							(window._dllLoadMode = 'async') &
							(type(window._dllProbePending) = :bool) &
							(type(step) = :object) &
							((step.type = :idle) | (step.type = :dispatch) | (step.type = :closed))
						gui.close(window)
						ok
					}
					_ -> false
				}
			}
			_ -> true
		}
		true
	)

	// form geometry helpers
	'formInRect? includes rectangle boundaries' |> t.eq(
		[
			gui.formInRect?(10, 10, 10, 10, 20, 20)
			gui.formInRect?(30, 30, 10, 10, 20, 20)
			gui.formInRect?(31, 30, 10, 10, 20, 20)
		]
		[true, true, false]
	)

	'formClamp clamps to [min, max]' |> t.eq(
		[
			gui.formClamp(-1, 0, 10)
			gui.formClamp(5, 0, 10)
			gui.formClamp(20, 0, 10)
		]
		[0, 5, 10]
	)

	'formHitListIndex returns hit item or -1' |> t.eq(
		[
			gui.formHitListIndex(12, 25, 10, 10, 40, 20, 4)
			gui.formHitListIndex(2, 25, 10, 10, 40, 20, 4)
		]
		[0, -1]
	)

	{
		rects := [
			{ key: :a, x: 0, y: 0, w: 10, h: 10 }
			{ key: :b, x: 20, y: 0, w: 10, h: 10 }
		]

		'formHitRectKey returns matching key or null' |> t.eq(
			[
				gui.formHitRectKey(5, 5, rects)
				gui.formHitRectKey(25, 5, rects)
				gui.formHitRectKey(15, 5, rects)
			]
			[:a, :b, ?]
		)

		'formToggleIfHit toggles only when cursor is inside' |> t.eq(
			[
				gui.formToggleIfHit(false, 3, 3, 0, 0, 10, 10)
				gui.formToggleIfHit(false, 30, 30, 0, 0, 10, 10)
			]
			[true, false]
		)

		'formSelectByHit keeps current value on miss' |> t.eq(
			[
				gui.formSelectByHit(:start, 5, 5, rects)
				gui.formSelectByHit(:start, 50, 50, rects)
			]
			[:a, :start]
		)
	}

	// form state mutation helpers
	{
		state := {
			a: false
			b: false
			hoverA: false
			hoverB: false
			choice: :none
			drag: :vol
			valueA: 0
			valueB: 0
		}

		gui.formSetByAssignments(state, [
			{ key: :valueA, value: 11 }
			{ key: :valueB, value: 22 }
		])
		'formSetByAssignments writes all values' |> t.eq([state.valueA, state.valueB], [11, 22])

		gui.formResetFlags(state, [:a, :b], true)
		'formResetFlags sets listed keys to provided value' |> t.eq([state.a, state.b], [true, true])

		gui.formSetHoverFromRects(state, 2, 2, [
			{ key: :hoverA, x: 0, y: 0, w: 5, h: 5 }
			{ key: :hoverB, x: 10, y: 10, w: 5, h: 5 }
		])
		'formSetHoverFromRects maps rect hits to booleans' |> t.eq([state.hoverA, state.hoverB], [true, false])

		gui.formToggleKeysByHit(state, 2, 2, [
			{ key: :a, x: 0, y: 0, w: 5, h: 5 }
			{ key: :b, x: 10, y: 10, w: 5, h: 5 }
		])
		'formToggleKeysByHit toggles only matching key' |> t.eq([state.a, state.b], [false, true])

		gui.formSetKeyByHit(state, :choice, 12, 12, [
			{ key: :low, x: 0, y: 0, w: 10, h: 10 }
			{ key: :high, x: 10, y: 10, w: 10, h: 10 }
		])
		'formSetKeyByHit assigns target key from hit key' |> t.eq(state.choice, :high)

		gui.formApplySliderDrag(state, :drag, 50, 10, 100, 10, 0, 100, [
			{ drag: :vol, valueKey: :valueA }
			{ drag: :other, valueKey: :valueB }
		])
		'formApplySliderDrag writes value for matching drag key only' |> t.eq(
			[state.valueA > 0, state.valueB]
			[true, 22]
		)
	}

	// text and notes helpers
	'formTruncateText appends ellipsis when exceeding max' |> t.eq(
		[
			gui.formTruncateText('abcd', 3)
			gui.formTruncateText('abc', 3)
		]
		['abc..', 'abc']
	)

	'formIsPrintableChar? checks ASCII printable range' |> t.eq(
		[
			gui.formIsPrintableChar?(31)
			gui.formIsPrintableChar?(32)
			gui.formIsPrintableChar?(126)
			gui.formIsPrintableChar?(127)
		]
		[false, true, true, false]
	)

	'formNotesAppendChar appends to last line' |> t.eq(
		gui.formNotesAppendChar(['ab', 'cd'], 'x')
		['ab', 'cdx']
	)

	'formNotesBackspace removes char and drops empty trailing line' |> t.eq(
		[
			gui.formNotesBackspace(['ab', 'cd'])
			gui.formNotesBackspace(['ab', ''])
		]
		[
			['ab', 'c']
			['ab']
		]
	)

	'formNotesNewLine respects max lines' |> t.eq(
		[
			gui.formNotesNewLine(['a'], 3)
			gui.formNotesNewLine(['a', 'b', 'c'], 3)
		]
		[
			['a', '']
			['a', 'b', 'c']
		]
	)

	'formSliderValue clamps and maps linearly' |> t.eq(
		[
			gui.formSliderValue(10, 10, 100, 10, 0, 100)
			gui.formSliderValue(55, 10, 100, 10, 0, 100)
			gui.formSliderValue(500, 10, 100, 10, 0, 100)
		]
		[0, 50, 100]
	)

	'formNextField rotates through focus order' |> t.eq(
		[
			gui.formNextField(:a, [:a, :b, :c])
			gui.formNextField(:c, [:a, :b, :c])
			gui.formNextField(:missing, [:a, :b, :c])
		]
		[:b, :a, :a]
	)

	'formMaskText returns one mask char per input char' |> t.eq(
		[
			gui.formMaskText('')
			gui.formMaskText('secret')
		]
		['', '******']
	)

	// mesh helper shape
	{
		cube := gui.CubeMesh(2)
		'CubeMesh returns expected vertex/edge/face counts' |> t.eq(
			[
				len(cube.vertices)
				len(cube.edges)
				len(cube.faces)
				len(cube.faceColors)
			]
			[8, 12, 6, 6]
		)
		'CubeMesh for size 2 is centered on origin' |> t.eq(
			[
				cube.vertices.(0)
				cube.vertices.(6)
			]
			[
				{ x: -1, y: -1, z: -1 }
				{ x: 1, y: 1, z: 1 }
			]
		)
	}

	// ─── New input events: WM_ constants are defined ────────────────────
	'WM_MOUSEWHEEL constant is 522' |> t.eq(gui.FORM_WM_MOUSEWHEEL, 522)
	'WM_MBUTTONDOWN constant is 519' |> t.eq(gui.FORM_WM_MBUTTONDOWN, 519)
	'WM_MBUTTONUP constant is 520' |> t.eq(gui.FORM_WM_MBUTTONUP, 520)
	'WM_LBUTTONDBLCLK constant is 515' |> t.eq(gui.FORM_WM_LBUTTONDBLCLK, 515)

	// ─── Event handler functions exist ──────────────────────────────────
	'onMouseWheel handler is a function' |> t.eq(type(gui.onMouseWheel), :function)
	'onMButtonDown handler is a function' |> t.eq(type(gui.onMButtonDown), :function)
	'onMButtonUp handler is a function' |> t.eq(type(gui.onMButtonUp), :function)
	'onLButtonDblClk handler is a function' |> t.eq(type(gui.onLButtonDblClk), :function)

	// ─── Modifier key constants and helpers ─────────────────────────────
	'VK_SHIFT constant is 16' |> t.eq(gui.FORM_VK_SHIFT, 16)
	'VK_CONTROL constant is 17' |> t.eq(gui.FORM_VK_CONTROL, 17)
	'VK_ALT constant is 18' |> t.eq(gui.FORM_VK_ALT, 18)
	'MK_SHIFT flag is 4' |> t.eq(gui.MK_SHIFT, 4)
	'MK_CONTROL flag is 8' |> t.eq(gui.MK_CONTROL, 8)
	'MK_MBUTTON flag is 16' |> t.eq(gui.MK_MBUTTON, 16)

	'modShift? detects MK_SHIFT in wParam' |> t.eq(
		[gui.modShift?(4), gui.modShift?(0), gui.modShift?(12)]
		[true, false, true]
	)
	'modCtrl? detects MK_CONTROL in wParam' |> t.eq(
		[gui.modCtrl?(8), gui.modCtrl?(0), gui.modCtrl?(12)]
		[true, false, true]
	)

	'keyShiftDown? is a function' |> t.eq(type(gui.keyShiftDown?), :function)
	'keyCtrlDown? is a function' |> t.eq(type(gui.keyCtrlDown?), :function)
	'keyAltDown? is a function' |> t.eq(type(gui.keyAltDown?), :function)

	// ─── Clipboard API exists ───────────────────────────────────────────
	'clipboardGetText is a function' |> t.eq(type(gui.clipboardGetText), :function)
	'clipboardSetText is a function' |> t.eq(type(gui.clipboardSetText), :function)
	'clipboardHasText is a function' |> t.eq(type(gui.clipboardHasText), :function)

	// Clipboard round-trip test (Windows only)
	'clipboard set/get round-trip on Windows' |> t.eq(
		if gui.backend() = :windows {
			true -> {
				marker := 'magnolia-test-' + string(nanotime())
				gui.clipboardSetText(marker)
				got := gui.clipboardGetText()
				got = marker
			}
			_ -> true
		}
		true
	)

	// ─── Clipboard form field helpers ───────────────────────────────────
	'formCopyByFocus is a function' |> t.eq(type(gui.formCopyByFocus), :function)
	'formPasteByFocus is a function' |> t.eq(type(gui.formPasteByFocus), :function)
	'formCutByFocus is a function' |> t.eq(type(gui.formCutByFocus), :function)

	'formCopyByFocus copies focused field to clipboard (Windows)' |> t.eq(
		if gui.backend() = :windows {
			true -> {
				state := { name: 'hello-clipboard' }
				gui.formCopyByFocus(state, :name, [:name])
				got := gui.clipboardGetText()
				got = 'hello-clipboard'
			}
			_ -> true
		}
		true
	)

	'formCutByFocus copies and clears focused field (Windows)' |> t.eq(
		if gui.backend() = :windows {
			true -> {
				state := { email: 'cut-me' }
				gui.formCutByFocus(state, :email, [:email])
				got := gui.clipboardGetText()
				(got = 'cut-me') & (state.email = '')
			}
			_ -> true
		}
		true
	)

	'formPasteByFocus pastes into focused field with limit (Windows)' |> t.eq(
		if gui.backend() = :windows {
			true -> {
				gui.clipboardSetText('pasted')
				state := { msg: 'hi' }
				gui.formPasteByFocus(state, :msg, [{ key: :msg, max: 10 }])
				state.msg = 'hipasted'
			}
			_ -> true
		}
		true
	)

	// ─── File drop API exists ───────────────────────────────────────────
	'enableFileDrop is a function' |> t.eq(type(gui.enableFileDrop), :function)
	'disableFileDrop is a function' |> t.eq(type(gui.disableFileDrop), :function)
	'onFileDrop is a function' |> t.eq(type(gui.onFileDrop), :function)
}

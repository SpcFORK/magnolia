ws := import('websocket')

fn run(t) {
	{
		'websocket stdlib exports connect function' |> t.eq(
			type(ws.connect)
			:function
		)

		'websocket exports close code constants' |> t.eq(
			ws.CloseCode.normal
			1000
		)

		'ws connect failures return error object' |> t.eq(
			ws.connect('ws://127.0.0.1:1').type
			:error
		)
	}
}

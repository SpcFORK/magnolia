// Test bitwise operations for integers
// Testing left shift (<<)
print("Left shift tests:")
print(1 << 0) // 1
print(1 << 1) // 2
print(1 << 2) // 4
print(1 << 3) // 8
print(5 << 2) // 20

// Testing right shift (>>)
print("Right shift tests:")
print(8 >> 0)  // 8
print(8 >> 1)  // 4
print(8 >> 2)  // 2
print(8 >> 3)  // 1
print(20 >> 2) // 5

// Testing bitwise AND (&)
print("Bitwise AND tests:")
print(12 & 10)  // 0b1100 & 0b1010 = 0b1000 = 8
print(15 & 7)   // 0b1111 & 0b0111 = 0b0111 = 7
print(255 & 15) // 0b11111111 & 0b00001111 = 0b00001111 = 15

// Testing bitwise OR (|)
print("Bitwise OR tests:")
print(12 | 10)  // 0b1100 | 0b1010 = 0b1110 = 14
print(8 | 4)    // 0b1000 | 0b0100 = 0b1100 = 12
print(1 | 2)    // 0b0001 | 0b0010 = 0b0011 = 3

// Testing bitwise XOR (^)
print("Bitwise XOR tests:")
print(12 ^ 10)  // 0b1100 ^ 0b1010 = 0b0110 = 6
print(15 ^ 7)   // 0b1111 ^ 0b0111 = 0b1000 = 8
print(255 ^ 0)  // 0b11111111 ^ 0b00000000 = 0b11111111 = 255

// Testing bitwise NOT (~)
print("Bitwise NOT tests:")
print(~0)       // All bits set to 1 (in two's complement: -1)
print(~1)       // ~0b0001 = 0b...1110 = -2
print(~(-1))    // ~0b...1111 = 0b0000 = 0

// Testing combinations
print("Combined bitwise operations:")
print((1 << 4) | (1 << 2))  // (16) | (4) = 20
print((5 << 1) & 15)        // (10) & 15 = 10
print(~(~5))                // ~~5 = 5

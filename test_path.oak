path := import('path')
std := import('std')

fn say(s) print(s + char(10))

// Test what path functions return for 'main.oak'
d := path.dir('main.oak')
say('dir("main.oak") = "' + d + '" len=' + string(len(d)))

r := path.resolve('comps/save', d)
say('resolve("comps/save", "' + d + '") = "' + r + '"')

importPath := r + '.oak'
say('importPath = "' + importPath + '"')

// Also check slice behavior
s := std.slice('main.oak', 0, -1)
say('slice("main.oak", 0, -1) = "' + string(s) + '" len=' + string(len(s)))

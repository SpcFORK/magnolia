{
	println: println
	string: string
} := import('std')

gui := import('GUI')
baseScene := import('base')

window := gui.createWindow('Blank Space', 960, 540, {
	frameMs: 16
	layer2D: 'auto'
})

if window.type {
	:ok -> baseScene.runGame(window)
	_ -> {
		println('Failed to create GUI window.')
		println(string(window))
	}
}
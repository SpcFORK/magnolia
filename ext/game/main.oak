{
	println: println
	string: string
} := import('std')

gui := import('GUI')
baseScene := import('base')

window := gui.createWindow('MG', 960, 540, {
	frameMs: 16
	layer2D: 'auto'
	icon: './magnolia.ico'
	taskbarIcon: './magnolia.ico'
	windowIcon: './magnolia.ico'
})

if window.type {
	:ok -> baseScene.runGame(window)
	_ -> {
		println('Failed to create GUI window.')
		println(string(window))
	}
}

// oak pack -- CLI adapter

{
	default: default
} := import('std')
cli := import('cli')
pack := import('pack')

Cli := cli.parse()

pack.run({
	entry: Cli.opts.entry
	output: Cli.opts.output |> default(Cli.opts.o)
	includes: Cli.opts.include
	web?: Cli.opts.web != ?
	wasm?: Cli.opts.wasm != ?
	interp: Cli.opts.interp
	oakExe: Cli.exe
})

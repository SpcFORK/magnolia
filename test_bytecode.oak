// Simple bytecode VM test program

// Test basic arithmetic
x := 2 + 3
y := x * 4
z := y - 5

// Test function definition and calls
fn add(a, b) a + b

result := add(10, 20)

// Test recursive function (fibonacci)
fn fib(n) if n {
	0 -> 0
	1 -> 1
	_ -> fib(n - 1) + fib(n - 2)
}

fibResult := fib(10)

// Test if-expression
status := if fibResult {
	55 -> 'correct'
	_ -> 'wrong'
}

// Test list and object creation
myList := [1, 2, 3]
myObj := { name: 'test', value: 42 }

// Test property access
objName := myObj.name
listFirst := myList.0

// Test string operations
greeting := 'hello' + ' ' + 'world'

// Test print
print(string(x) + ' ' + string(result) + ' ' + string(fibResult) + ' ' + status + ' ' + greeting)
